.learn {
  min-height: 100vh;
}

.top-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.lesson {
  font-size: 26rpx;
  font-weight: 800;
  color: #4a4458;
}

.progress {
  font-size: 26rpx;
  font-weight: 900;
  color: #22b8a8;
}

.mode-row {
  display: flex;
  gap: 10rpx;
  margin-bottom: 18rpx;
}

.mode {
  flex: 1;
  text-align: center;
  padding: 14rpx 8rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 800;
  background: #fff;
  color: #22b8a8;
  border: 3rpx solid #9ee5db;
}

.mode.on {
  background: #ffc93c;
  color: #5a4300;
  border-color: #ffc93c;
}

.hint {
  font-size: 24rpx;
  font-weight: 700;
  color: #4a4458;
  margin-bottom: 14rpx;
}

.main-card {
  text-align: center;
  padding: 36rpx 24rpx;
  margin-bottom: 20rpx;
}

.formula {
  font-size: 30rpx;
  font-weight: 800;
  color: #1a1430;
  margin-bottom: 20rpx;
}

.formula .ini,
.big-pinyin .ini {
  color: #22b8a8;
}

.formula .op {
  color: #9a93a8;
}

.formula .full {
  color: #ff6f61;
}

.big-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.big-pinyin {
  font-size: 72rpx;
  font-weight: 900;
  color: #1a1430;
}

.speak {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #ff9f1c;
  color: #fff;
  font-size: 28rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 0 #d96a10;
}

.char-box {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 160rpx;
  min-height: 160rpx;
  border: 6rpx solid #22b8a8;
  border-radius: 20rpx;
  font-size: 88rpx;
  font-weight: 900;
  color: #1a1430;
  background: #fff;
}

.char-box.big {
  min-width: 200rpx;
  min-height: 200rpx;
  font-size: 120rpx;
}

.nav-row {
  display: flex;
  gap: 12rpx;
}

.nav-btn {
  flex: 1;
  min-height: 84rpx;
  font-size: 28rpx;
}

.nav-btn.play {
  flex: 1.2;
}

.fill-feedback {
  margin-top: 20rpx;
  font-size: 28rpx;
  font-weight: 900;
}

.fill-feedback.ok {
  color: #2fbf7e;
}

.fill-feedback.bad {
  color: #e84b6a;
}

.fill-opts {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.fill-opt {
  background: #fff;
  border: 3rpx solid #ece7df;
  border-radius: 20rpx;
  padding: 28rpx 16rpx;
  text-align: center;
  font-size: 36rpx;
  font-weight: 900;
  box-shadow: 0 8rpx 0 rgba(26, 20, 48, 0.08);
}

.fill-opt.correct {
  background: #e8fff8;
  border-color: #22b8a8;
  color: #0f8f82;
}

.list-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
}

.list-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 18rpx 8rpx;
  text-align: center;
  border: 3rpx solid #ece7df;
}

.list-item.on {
  border-color: #22b8a8;
  background: #e8fff8;
}

.list-py {
  font-size: 24rpx;
  font-weight: 900;
  color: #1a1430;
}

.list-ch {
  margin-top: 6rpx;
  font-size: 36rpx;
  font-weight: 900;
  color: #1a1430;
}
