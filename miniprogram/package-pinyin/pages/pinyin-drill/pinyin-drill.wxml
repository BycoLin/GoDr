<view class="safe-pad drill">
  <view class="top" wx:if="{{!done && question}}">
    <view class="tag">{{kind === 'final' ? '韵母认读' : '声母认读'}}</view>
    <view class="progress">第 {{index + 1}} / {{total}} 题 · 已对 {{correct}}</view>
  </view>

  <block wx:if="{{!done && question}}">
    <view class="card">
      <view class="char">{{question.char}}</view>
      <view class="py">{{question.pinyin}}</view>
      <view class="prompt">{{question.prompt}}</view>
      <view class="speak pressable" bindtap="onSpeak">读一读</view>
    </view>

    <view class="options">
      <view
        class="opt {{feedback === 'ok' && item.id === question.answerId ? 'correct' : ''}} {{feedback === 'bad' ? 'dim' : ''}}"
        wx:for="{{options}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="onChoose"
      >{{item.label}}</view>
    </view>

    <view class="hint ok" wx:if="{{feedback === 'ok'}}">答对啦！</view>
    <view class="hint bad" wx:elif="{{feedback === 'bad'}}">再试一次～</view>
  </block>

  <view class="done-card" wx:if="{{done}}">
    <view class="done-title">练完啦</view>
    <view class="done-score">答对 {{correct}} / {{total}}</view>
    <view class="done-actions">
      <button class="btn btn-primary" bindtap="onAgain">再练一组</button>
      <button class="btn btn-ghost" bindtap="onBackHub">返回</button>
    </view>
  </view>
</view>
