<view class="safe-pad pinyin">
  <view class="banner">
    <view class="banner-title">{{tab === 'final' ? '韵母练习' : '声母练习'}}</view>
    <view class="banner-desc">
      {{tab === 'final' ? '点韵母学拼读，再练认读' : '点声母学拼读，再练认读'}}
    </view>
  </view>

  <view class="tab-row">
    <view class="tab {{tab === 'initial' ? 'on' : ''}}" data-tab="initial" bindtap="onSwitchTab">声母</view>
    <view class="tab {{tab === 'final' ? 'on' : ''}}" data-tab="final" bindtap="onSwitchTab">韵母</view>
  </view>

  <view class="drill-row">
    <view class="drill-btn pressable" data-kind="{{tab}}" bindtap="onTapDrill">
      {{tab === 'final' ? '韵母认读练' : '声母认读练'}}
    </view>
  </view>

  <block wx:if="{{tab === 'initial'}}">
    <view class="grid">
      <view
        class="tile {{item.toneClass}}"
        wx:for="{{initials}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="onTapInitial"
      >
        <view class="letter">{{item.id}}</view>
        <view class="tip">{{item.tip}}</view>
      </view>
    </view>
  </block>

  <block wx:else>
    <view class="final-section" wx:for="{{finalGroups}}" wx:key="group">
      <view class="sec-label">{{item.group}}</view>
      <view class="grid final-grid">
        <view
          class="tile {{tile.toneClass}}"
          wx:for="{{item.items}}"
          wx:for-item="tile"
          wx:key="id"
          data-id="{{tile.id}}"
          bindtap="onTapFinal"
        >
          <view class="letter">{{tile.label}}</view>
          <view class="tip">{{tile.tip}}</view>
        </view>
      </view>
    </view>
  </block>
</view>
