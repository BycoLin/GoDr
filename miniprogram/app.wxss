page {
  --color-bg: #fff8ef;
  --color-surface: #ffffff;
  --color-ink: #1a1430;
  --color-muted: #4a4458;
  --color-primary: #22b8a8;
  --color-primary-deep: #0f8f82;
  --color-primary-soft: #d6f8f2;
  --color-accent: #ff6f61;
  --color-accent-soft: #ffe2de;
  --color-sky: #5b8cff;
  --color-sky-soft: #e2ebff;
  --color-sun: #ffc93c;
  --color-sun-soft: #fff3c4;
  --color-danger: #e84b6a;
  --color-ok: #2fbf7e;
  --radius: 32rpx;
  --shadow: 0 10rpx 0 rgba(26, 20, 48, 0.1);
}

page {
  background: #fff8ef;
  color: var(--color-ink);
  font-size: 30rpx;
  min-height: 100vh;
  box-sizing: border-box;
  line-height: 1.45;
}

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 92rpx;
  padding: 0 40rpx;
  border-radius: 999rpx;
  font-size: 32rpx;
  font-weight: 800;
  border: none;
  line-height: 1.2;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: #22b8a8;
  color: #fff;
  box-shadow: 0 10rpx 0 #0f8f82;
}

.btn-primary:active {
  opacity: 0.92;
  box-shadow: 0 6rpx 0 #0f8f82;
}

.btn-secondary {
  background: #fff;
  color: var(--color-primary-deep);
  border: 4rpx solid #9ee5db;
  box-shadow: 0 8rpx 0 rgba(15, 143, 130, 0.18);
}

.btn-ghost {
  background: transparent;
  color: var(--color-muted);
}

.card {
  background: #ffffff;
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  padding: 32rpx;
  border: 3rpx solid #ece7df;
  position: relative;
}

.safe-pad {
  padding: 28rpx 28rpx;
  padding-bottom: calc(56rpx + env(safe-area-inset-bottom));
}

.section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 30rpx;
  color: var(--color-ink);
  margin: 8rpx 0 18rpx;
  font-weight: 800;
}

.section-title::before {
  content: '';
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--color-sun);
  box-shadow: 8rpx 0 0 var(--color-accent), 16rpx 0 0 var(--color-sky);
}
