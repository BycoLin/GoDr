page {
  --color-bg: #e6fff6;
  --color-surface: #ffffff;
  --color-ink: #1a1430;
  --color-muted: #4a4458;
  --color-primary: #22b8a8;
  --color-primary-deep: #0f8f82;
  --color-primary-soft: #d6f8f2;
  --color-accent: #ff6f61;
  --color-accent-soft: #ffe2de;
  --color-sky: #5b8cff;
  --color-sky-soft: #e2ebff;
  --color-sun: #ffc93c;
  --color-sun-soft: #fff3c4;
  --color-grass: #5ecf7b;
  --color-danger: #e84b6a;
  --color-ok: #2fbf7e;
  --radius: 36rpx;
  --radius-lg: 48rpx;
  --shadow: 0 12rpx 0 rgba(26, 20, 48, 0.1);
  --gap: 28rpx;
  --tap-min: 120rpx;
  --font-hero: 48rpx;
  --font-title: 36rpx;
  --font-body: 32rpx;
  --font-sub: 26rpx;
}

.path-dock {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(230, 255, 246, 0) 0%, rgba(255, 255, 255, 0.92) 35%, #fff 100%);
  z-index: 30;
}

.path-dock-btn {
  min-height: 96rpx;
  border-radius: 999rpx;
  background: #22b8a8;
  color: #fff;
  font-size: 30rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 0 #0f8f82;
}

.path-dock-btn:active {
  transform: translateY(6rpx);
  box-shadow: 0 4rpx 0 #0f8f82;
}

.path-page-pad {
  padding-bottom: 180rpx;
}

/* 首页 / 关卡页共用底部 CTA，随页面内容滚动 */
.adventure-dock {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 0 0;
  box-sizing: border-box;
}

.adventure-dock--hero {
  margin-bottom: 8rpx;
}

.adventure-dock--dock {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(230, 255, 246, 0) 0%, rgba(255, 255, 255, 0.92) 35%, #fff 100%);
  z-index: 30;
}

.adventure-bubble {
  background: #fff;
  border: 3rpx solid #ece7df;
  border-radius: 999rpx;
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  font-weight: 800;
  color: #1a1430;
  margin-bottom: 14rpx;
  box-shadow: 0 6rpx 0 rgba(26, 20, 48, 0.06);
  max-width: 92%;
  text-align: center;
}

.adventure-dock .btn-cta {
  width: 80%;
  margin: 0;
}

.adventure-sub {
  margin-top: 12rpx;
  font-size: 24rpx;
  font-weight: 800;
  color: #5b8cff;
  min-height: 48rpx;
  line-height: 48rpx;
}

page {
  background:
    radial-gradient(circle at 48% 100%, rgba(255, 176, 160, 0.42) 0%, transparent 42%),
    radial-gradient(circle at 8% 88%, rgba(255, 210, 120, 0.3) 0%, transparent 30%),
    radial-gradient(circle at 92% 92%, rgba(255, 190, 170, 0.26) 0%, transparent 28%),
    radial-gradient(circle at 16% 6%, rgba(64, 200, 180, 0.28) 0%, transparent 34%),
    radial-gradient(circle at 84% 4%, rgba(120, 210, 200, 0.22) 0%, transparent 30%),
    linear-gradient(180deg, #e6fff6 0%, #eef3ff 48%, #ffe8dc 100%);
  color: var(--color-ink);
  font-size: var(--font-body);
  min-height: 100vh;
  box-sizing: border-box;
  line-height: 1.45;
  font-family: "PingFang SC", "Noto Sans SC", "Microsoft YaHei", sans-serif;
}

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: var(--tap-min);
  padding: 0 48rpx;
  border-radius: 999rpx;
  font-size: var(--font-title);
  font-weight: 900;
  border: none;
  line-height: 1.2;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: #22b8a8;
  color: #fff;
  box-shadow: 0 12rpx 0 #0f8f82;
}

.btn-primary:active {
  transform: translateY(6rpx);
  box-shadow: 0 6rpx 0 #0f8f82;
}

.btn-cta {
  width: 80%;
  margin: 0 auto;
  min-height: 140rpx;
  font-size: 40rpx;
  letter-spacing: 2rpx;
}

/* 学科主按钮色：首页与关卡页共用 */
.cta-btn {
  color: #fff;
}

.cta-btn.tone-cn {
  background: #22b8a8;
  box-shadow: 0 12rpx 0 #0f8f82;
}

.cta-btn.tone-math {
  background: #5b8cff;
  box-shadow: 0 12rpx 0 #4470e0;
}

.cta-btn.tone-en {
  background: #ff9f1c;
  box-shadow: 0 12rpx 0 #e07f10;
}

.cta-btn.tone-cn:active {
  transform: translateY(8rpx);
  box-shadow: 0 4rpx 0 #0f8f82;
}

.cta-btn.tone-math:active {
  transform: translateY(8rpx);
  box-shadow: 0 4rpx 0 #4470e0;
}

.cta-btn.tone-en:active {
  transform: translateY(8rpx);
  box-shadow: 0 4rpx 0 #e07f10;
}

.cta-btn.disabled {
  background: #c8c2d4 !important;
  box-shadow: 0 12rpx 0 #9a93a8 !important;
}

.btn-secondary {
  background: #fff;
  color: var(--color-primary-deep);
  border: 4rpx solid #9ee5db;
  box-shadow: 0 10rpx 0 rgba(15, 143, 130, 0.18);
}

.btn-secondary:active {
  transform: translateY(4rpx);
  box-shadow: 0 6rpx 0 rgba(15, 143, 130, 0.18);
}

.btn-ghost {
  background: transparent;
  color: var(--color-muted);
}

.btn-share {
  background: linear-gradient(135deg, #fff8ef 0%, #fff 100%);
  color: var(--color-primary-deep);
  border: 4rpx solid #9ee5db;
  box-shadow: 0 10rpx 0 rgba(15, 143, 130, 0.14);
}

.btn-share:active {
  transform: translateY(4rpx);
  box-shadow: 0 6rpx 0 rgba(15, 143, 130, 0.14);
}

.card {
  background: #ffffff;
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  padding: 32rpx;
  border: 3rpx solid #ece7df;
  position: relative;
}

.safe-pad {
  padding: 32rpx 32rpx;
  padding-bottom: calc(64rpx + env(safe-area-inset-bottom));
}

.section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: var(--font-title);
  color: var(--color-ink);
  margin: 8rpx 0 20rpx;
  font-weight: 900;
}

.section-title::before {
  content: '';
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--color-sun);
  box-shadow: 8rpx 0 0 var(--color-accent), 16rpx 0 0 var(--color-sky);
}

/* 按压反馈通用 */
.pressable:active {
  transform: translateY(4rpx);
  opacity: 0.96;
}
