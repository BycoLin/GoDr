.number {
  min-height: 100vh;
}

.head .title {
  font-size: 40rpx;
  font-weight: 900;
  color: #1a1430;
}

.head .desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #4a4458;
}

.level-row {
  display: flex;
  gap: 8rpx;
  margin: 18rpx 0;
  flex-wrap: wrap;
}

.level {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #fff;
  border: 3rpx solid #ece7df;
  font-size: 24rpx;
  font-weight: 800;
  color: #4a4458;
}

.level.on {
  background: #22b8a8;
  color: #fff;
  border-color: #22b8a8;
  box-shadow: 0 6rpx 0 #0f8f82;
}

.stage {
  background: linear-gradient(180deg, #e8f7ff, #f3fff6);
  margin-bottom: 12rpx;
}

.seq {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.slot {
  width: 120rpx;
  height: 120rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  font-weight: 900;
  background: #fff;
  border: 4rpx solid #d7dee8;
}

.slot.show {
  border-color: #22b8a8;
  color: #0f8f82;
  background: #e8fff8;
}

.slot.blank {
  color: #9a93a8;
}

.slot.focus {
  border-color: #ff9f1c;
  box-shadow: 0 0 0 4rpx rgba(255, 159, 28, 0.25);
}

.tip {
  text-align: center;
  font-size: 28rpx;
  font-weight: 900;
  margin-bottom: 8rpx;
}

.tip.ok {
  color: #2fbf7e;
}

.tip.bad {
  color: #e84b6a;
}

.link {
  text-align: center;
  color: #5b8cff;
  font-size: 26rpx;
  font-weight: 800;
  margin-bottom: 12rpx;
}
