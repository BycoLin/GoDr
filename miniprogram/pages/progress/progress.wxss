.progress-page {
  min-height: 100vh;
}

.pack-tabs {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-bottom: 18rpx;
}

.pack-tab {
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  background: #ffffff;
  font-size: 28rpx;
  color: #5a5268;
  font-weight: 800;
  box-shadow: 0 6rpx 0 rgba(43, 37, 64, 0.06);
  line-height: 1.2;
}

.pack-tab.on {
  color: #ffffff;
  background: linear-gradient(135deg, #42d6c5, #22b8a8);
  box-shadow: 0 8rpx 0 #11998a;
}

.hero {
  margin-bottom: 20rpx;
  background: linear-gradient(150deg, #e8fff8 0%, #ffffff 48%, #fff3d6 100%);
  overflow: hidden;
}

.hero-top {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  align-items: flex-start;
}

.hero-badge {
  display: inline-block;
  background: var(--color-sun);
  color: #6a5000;
  font-size: 20rpx;
  font-weight: 900;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  margin-bottom: 10rpx;
}

.hero-title {
  font-size: 32rpx;
  font-weight: 900;
}

.hero-cheer {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--color-muted);
  font-weight: 700;
  line-height: 1.4;
  max-width: 360rpx;
}

.ring {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: radial-gradient(circle at center, #ffffff 52%, #d4f5f1 53%, #22b8a8 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 8rpx 0 rgba(17, 153, 138, 0.2);
}

.ring-num {
  font-size: 34rpx;
  font-weight: 900;
  color: var(--color-primary-deep);
  line-height: 1;
}

.ring-label {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: var(--color-muted);
  font-weight: 700;
}

.stat-row {
  display: flex;
  gap: 12rpx;
  margin-top: 24rpx;
}

.stat {
  flex: 1;
  text-align: center;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 22rpx;
  padding: 16rpx 8rpx;
  box-shadow: 0 6rpx 0 rgba(43, 37, 64, 0.05);
}

.stat-num {
  font-size: 34rpx;
  font-weight: 900;
  color: var(--color-primary-deep);
}

.stat-label {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: var(--color-muted);
  font-weight: 700;
}

.bar {
  margin-top: 20rpx;
  height: 16rpx;
  background: #eef2f8;
  border-radius: 999rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #ffc93c, #22b8a8 55%, #5b8cff);
}

.continue-btn {
  margin-top: 24rpx;
}

.filter-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.filter-chip {
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.85);
  color: var(--color-muted);
  font-size: 24rpx;
  font-weight: 800;
}

.filter-chip.on {
  background: var(--color-ink);
  color: #fff;
}

.grade-card {
  background: #fff;
  border-radius: 32rpx;
  box-shadow: 0 10rpx 0 rgba(43, 37, 64, 0.07);
  padding: 22rpx 20rpx;
  margin-bottom: 16rpx;
  border: 4rpx solid #fff;
}

.grade-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
}

.grade-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
}

.grade-dot {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #ffc93c, #ff9f1c);
  color: #fff;
  font-size: 28rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 6rpx 0 rgba(224, 173, 32, 0.4);
}

.grade-title {
  font-size: 30rpx;
  font-weight: 900;
}

.grade-meta {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: var(--color-muted);
  font-weight: 700;
}

.grade-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}

.grade-percent {
  font-size: 26rpx;
  font-weight: 900;
  color: var(--color-primary-deep);
}

.grade-arrow {
  font-size: 36rpx;
  color: #a8b5c6;
  transform: rotate(90deg);
  transition: transform 0.2s ease;
  font-weight: 700;
}

.grade-arrow.up {
  transform: rotate(-90deg);
}

.grade-bar {
  margin-top: 16rpx;
  height: 12rpx;
  background: #eef2f8;
  border-radius: 999rpx;
  overflow: hidden;
}

.grade-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #42d6c5, #5b8cff);
}

.grade-body {
  margin-top: 16rpx;
  padding-top: 8rpx;
  border-top: 2rpx dashed #e8eef5;
}

.empty-tip {
  padding: 24rpx 8rpx;
  text-align: center;
  color: var(--color-muted);
  font-size: 24rpx;
  font-weight: 700;
}

.item-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  padding: 18rpx 8rpx;
  border-bottom: 2rpx dashed #f0f3f8;
}

.item-row:last-child {
  border-bottom: none;
}

.item-title {
  font-size: 28rpx;
  font-weight: 800;
}

.item-status {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: var(--color-muted);
  font-weight: 700;
}

.item-status.ok {
  color: var(--color-ok);
}

.star {
  color: #d7dee8;
  font-size: 28rpx;
}

.star.on {
  color: #ffc93c;
}

.clear-btn {
  margin-top: 28rpx;
  opacity: 0.75;
}
