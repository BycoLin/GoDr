.progress-page {
  min-height: 100vh;
}

.subject-line {
  margin-bottom: 16rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #4a4458;
}

.pack-tabs {
  display: none;
}

.pack-tab {
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  background: #ffffff;
  font-size: 28rpx;
  color: #4a4458;
  font-weight: 800;
  border: 3rpx solid #ece7df;
  box-shadow: 0 6rpx 0 rgba(26, 20, 48, 0.08);
  line-height: 1.2;
}

.pack-tab.on {
  color: #ffffff;
  background: #22b8a8;
  border-color: #22b8a8;
  box-shadow: 0 8rpx 0 #0f8f82;
}

.hero {
  margin-bottom: 20rpx;
  background: #ffffff;
  overflow: hidden;
}

.hero-top {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  align-items: flex-start;
}

.hero-badge {
  display: inline-block;
  background: var(--color-sun);
  color: #5a4300;
  font-size: 22rpx;
  font-weight: 900;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  margin-bottom: 10rpx;
}

.hero-title {
  font-size: 32rpx;
  font-weight: 900;
  color: #1a1430;
}

.hero-cheer {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #4a4458;
  font-weight: 700;
  line-height: 1.4;
  max-width: 360rpx;
}

.ring {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: #22b8a8;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 8rpx 0 #0f8f82;
}

.ring-num {
  font-size: 34rpx;
  font-weight: 900;
  color: #ffffff;
  line-height: 1;
}

.ring-label {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.92);
  font-weight: 700;
}

.stat-row {
  display: flex;
  gap: 12rpx;
  margin-top: 24rpx;
}

.stat {
  flex: 1;
  text-align: center;
  background: #f7f4ee;
  border-radius: 22rpx;
  padding: 16rpx 8rpx;
  border: 2rpx solid #ece7df;
}

.stat-num {
  font-size: 34rpx;
  font-weight: 900;
  color: #0f8f82;
}

.stat-label {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #4a4458;
  font-weight: 700;
}

.bar {
  margin-top: 20rpx;
  height: 16rpx;
  background: #ece7df;
  border-radius: 999rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  background: #22b8a8;
}

.continue-btn {
  margin-top: 24rpx;
}

.filter-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.filter-chip {
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #4a4458;
  font-size: 24rpx;
  font-weight: 800;
  border: 3rpx solid #ece7df;
}

.filter-chip.on {
  background: #1a1430;
  border-color: #1a1430;
  color: #fff;
}

.grade-card {
  background: #fff;
  border-radius: 32rpx;
  box-shadow: 0 10rpx 0 rgba(26, 20, 48, 0.1);
  padding: 22rpx 20rpx;
  margin-bottom: 16rpx;
  border: 3rpx solid #ece7df;
}

.grade-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
}

.grade-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
}

.grade-dot {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #ffc93c;
  color: #5a4300;
  font-size: 28rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 6rpx 0 #d4a010;
}

.grade-title {
  font-size: 30rpx;
  font-weight: 900;
  color: #1a1430;
}

.grade-meta {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #4a4458;
  font-weight: 700;
}

.grade-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}

.grade-percent {
  font-size: 26rpx;
  font-weight: 900;
  color: #0f8f82;
}

.grade-arrow {
  font-size: 36rpx;
  color: #7a7390;
  font-weight: 700;
  transform: rotate(90deg);
}

.grade-arrow.up {
  color: #1a1430;
  transform: rotate(-90deg);
}

.grade-bar {
  margin-top: 16rpx;
  height: 12rpx;
  background: #ece7df;
  border-radius: 999rpx;
  overflow: hidden;
}

.grade-bar-fill {
  height: 100%;
  background: #22b8a8;
}

.grade-body {
  margin-top: 16rpx;
  padding-top: 8rpx;
  border-top: 2rpx solid #ece7df;
}

.empty-tip {
  padding: 24rpx 8rpx;
  text-align: center;
  color: #4a4458;
  font-size: 24rpx;
  font-weight: 700;
}

.item-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  padding: 18rpx 8rpx;
  border-bottom: 2rpx solid #f0ebe3;
}

.item-row:last-child {
  border-bottom: none;
}

.item-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #1a1430;
}

.item-status {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #4a4458;
  font-weight: 700;
}

.item-status.ok {
  color: var(--color-ok);
}

.star {
  color: #d0cbc3;
  font-size: 28rpx;
}

.star.on {
  color: #f0b400;
}

.clear-btn {
  margin-top: 28rpx;
}
