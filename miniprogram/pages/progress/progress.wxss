.progress-page {
  min-height: 100vh;
}

.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.page-kicker {
  font-size: 22rpx;
  font-weight: 900;
  color: #5a4300;
  background: #ffc93c;
  display: inline-block;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  margin-bottom: 10rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 900;
  color: #1a1430;
}

.page-sub {
  margin-top: 6rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #4a4458;
}

.star-badge {
  flex-shrink: 0;
  background: #fff;
  border: 3rpx solid #ffe08a;
  color: #5a4300;
  font-size: 28rpx;
  font-weight: 900;
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  box-shadow: 0 8rpx 0 rgba(224, 173, 32, 0.35);
}

.hero-banner {
  position: relative;
  overflow: hidden;
  border-radius: 36rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 18rpx;
  color: #fff;
  border: 4rpx solid transparent;
  box-shadow: 0 12rpx 0 rgba(26, 20, 48, 0.12);
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.hero-banner.tone-cn {
  background: linear-gradient(135deg, #6fe0d2 0%, #22b8a8 55%, #0f8f82 100%);
  border-color: #22b8a8;
  box-shadow: 0 12rpx 0 #0f8f82;
}

.hero-banner.tone-math {
  background: linear-gradient(135deg, #9bb8ff 0%, #5b8cff 55%, #3d6ef5 100%);
  border-color: #5b8cff;
  box-shadow: 0 12rpx 0 #4470e0;
}

.hero-banner.tone-en {
  background: linear-gradient(135deg, #ffd28a 0%, #ff9f1c 55%, #f08a10 100%);
  border-color: #ff9f1c;
  box-shadow: 0 12rpx 0 #e07f10;
}

.hero-copy {
  flex: 1;
  min-width: 0;
}

.hero-label {
  font-size: 22rpx;
  font-weight: 800;
  opacity: 0.9;
}

.hero-title {
  margin-top: 6rpx;
  font-size: 56rpx;
  font-weight: 900;
  line-height: 1.1;
}

.hero-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.4;
  opacity: 0.95;
}

.hero-btn {
  display: inline-block;
  margin-top: 18rpx;
  background: #fff;
  color: #1a1430;
  font-size: 26rpx;
  font-weight: 900;
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
}

.tone-cn .hero-btn { color: #0f8f82; }
.tone-math .hero-btn { color: #2f5fce; }
.tone-en .hero-btn { color: #e07f10; }

.hero-ring {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.28);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ring-num {
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1;
}

.ring-label {
  margin-top: 6rpx;
  font-size: 20rpx;
  font-weight: 700;
  opacity: 0.92;
}

.stat-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 28rpx;
}

.stat-card {
  flex: 1;
  text-align: center;
  background: #fff;
  border: 3rpx solid #ece7df;
  border-radius: 24rpx;
  padding: 18rpx 8rpx;
  box-shadow: 0 8rpx 0 rgba(26, 20, 48, 0.06);
}

.stat-card.sun {
  background: #fff8df;
  border-color: #ffe08a;
}

.stat-num {
  font-size: 34rpx;
  font-weight: 900;
  color: #0f8f82;
}

.stat-card.sun .stat-num {
  color: #5a4300;
}

.stat-label {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #4a4458;
  font-weight: 700;
}

.block-head {
  margin-bottom: 14rpx;
}

.block-title {
  font-size: 32rpx;
  font-weight: 900;
  color: #1a1430;
  margin-bottom: 12rpx;
}

.filter-row {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.filter-chip {
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: #fff;
  color: #4a4458;
  font-size: 24rpx;
  font-weight: 800;
  border: 3rpx solid #ece7df;
}

.filter-chip.on {
  background: #22b8a8;
  border-color: #22b8a8;
  color: #fff;
  box-shadow: 0 6rpx 0 #0f8f82;
}

.grade-card {
  background: #fff;
  border-radius: 32rpx;
  box-shadow: 0 10rpx 0 rgba(26, 20, 48, 0.08);
  padding: 22rpx 20rpx;
  margin-bottom: 14rpx;
  border: 3rpx solid #ece7df;
}

.grade-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
}

.grade-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
}

.grade-dot {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #ffc93c;
  color: #5a4300;
  font-size: 28rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 6rpx 0 #d4a010;
}

.grade-title {
  font-size: 30rpx;
  font-weight: 900;
  color: #1a1430;
}

.grade-meta {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #4a4458;
  font-weight: 700;
}

.grade-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}

.grade-percent {
  font-size: 26rpx;
  font-weight: 900;
  color: #0f8f82;
}

.grade-arrow {
  font-size: 24rpx;
  color: #22b8a8;
  font-weight: 800;
}

.grade-bar {
  margin-top: 16rpx;
  height: 12rpx;
  background: #ece7df;
  border-radius: 999rpx;
  overflow: hidden;
}

.grade-bar-fill {
  height: 100%;
  background: #22b8a8;
}

.level-list {
  background: #fff;
  border-radius: 28rpx;
  border: 3rpx solid #ece7df;
  padding: 8rpx 20rpx;
  box-shadow: 0 8rpx 0 rgba(26, 20, 48, 0.06);
}

.empty-tip {
  padding: 24rpx 8rpx;
  text-align: center;
  color: #4a4458;
  font-size: 24rpx;
  font-weight: 700;
}

.item-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  padding: 18rpx 8rpx;
  border-bottom: 2rpx solid #f0ebe3;
}

.item-row:last-child {
  border-bottom: none;
}

.item-row.done .item-title {
  color: #0f8f82;
}

.item-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #1a1430;
}

.item-status {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #4a4458;
  font-weight: 700;
}

.star {
  color: #d0cbc3;
  font-size: 28rpx;
}

.star.on {
  color: #ffc93c;
}

.foot-link {
  margin-top: 28rpx;
  margin-bottom: 12rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 800;
  color: #9a93a8;
}

.hero-btn:active,
.item-row:active,
.grade-card:active {
  opacity: 0.92;
}
