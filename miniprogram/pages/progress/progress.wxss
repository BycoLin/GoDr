.pack-tabs {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-bottom: 20rpx;
}

.pack-tab {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.85);
  font-size: 24rpx;
  color: var(--color-muted);
}

.pack-tab.on {
  color: #fff;
  background: linear-gradient(135deg, #2ec4bb, #1fa8a0);
  font-weight: 700;
}

.summary {
  margin-bottom: 24rpx;
  background: linear-gradient(145deg, #dceeff 0%, #ffffff 70%);
}

.summary-title {
  font-size: 34rpx;
  font-weight: 800;
}

.summary-progress {
  margin-top: 8rpx;
  color: var(--color-muted);
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--color-surface);
  border-radius: var(--radius);
  padding: 24rpx;
  margin-bottom: 14rpx;
  box-shadow: var(--shadow);
}

.row-title {
  font-size: 30rpx;
  font-weight: 700;
}

.row-meta {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: var(--color-muted);
}

.star {
  color: #d7dee8;
  font-size: 28rpx;
}

.star.on {
  color: #ffb020;
}

.clear-btn {
  margin-top: 40rpx;
}
