<view class="safe-pad">
  <view class="card summary">
    <view class="summary-title">{{packTitle}}</view>
    <view class="summary-progress">已掌握 {{clearedCount}} / {{totalCount}} 首</view>
  </view>

  <view class="row" wx:for="{{rows}}" wx:key="id">
    <view class="row-main">
      <view class="row-title">《{{item.title}}》</view>
      <view class="row-meta">{{item.grade}} 年级 · {{item.cleared ? '已掌握' : '未通关'}}</view>
    </view>
    <view class="stars">
      <text class="star {{item.stars >= 1 ? 'on' : ''}}">★</text>
      <text class="star {{item.stars >= 2 ? 'on' : ''}}">★</text>
      <text class="star {{item.stars >= 3 ? 'on' : ''}}">★</text>
    </view>
  </view>

  <button class="btn btn-ghost clear-btn" bindtap="onClearAll">清空本包进度</button>
</view>
