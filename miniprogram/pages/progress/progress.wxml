<view class="safe-pad progress-page">
  <view class="top-bar">
    <view>
      <view class="page-kicker">星星收集</view>
      <view class="page-title">{{worldName}}</view>
      <view class="page-sub">{{subject}} · {{grade}} 年级 · 闯关页可切换</view>
    </view>
    <view class="star-badge">★ {{starSum}}</view>
  </view>

  <view class="hero-banner {{toneClass}}">
    <view class="hero-copy">
      <view class="hero-label">闯关进度</view>
      <view class="hero-title">{{percent}}%</view>
      <view class="hero-desc">{{cheerText}}</view>
      <view class="hero-btn" bindtap="onContinue">继续闯关</view>
    </view>
    <view class="hero-ring">
      <view class="ring-num">{{clearedCount}}</view>
      <view class="ring-label">已通关</view>
    </view>
  </view>

  <view class="stat-row">
    <view class="stat-card">
      <view class="stat-num">{{clearedCount}}</view>
      <view class="stat-label">已完成</view>
    </view>
    <view class="stat-card">
      <view class="stat-num">{{todoCount}}</view>
      <view class="stat-label">还差{{unitLabel}}</view>
    </view>
    <view class="stat-card sun">
      <view class="stat-num">{{starSum}}</view>
      <view class="stat-label">星星</view>
    </view>
  </view>

  <view class="block">
    <view class="block-head">
      <view class="block-title">关卡星星</view>
      <view class="filter-row">
        <view class="filter-chip {{filter === 'all' ? 'on' : ''}}" data-filter="all" bindtap="onSelectFilter">全部</view>
        <view class="filter-chip {{filter === 'done' ? 'on' : ''}}" data-filter="done" bindtap="onSelectFilter">已完成</view>
        <view class="filter-chip {{filter === 'todo' ? 'on' : ''}}" data-filter="todo" bindtap="onSelectFilter">未完成</view>
      </view>
    </view>

    <view class="level-list">
      <view wx:if="{{!items.length}}" class="empty-tip">这里暂时没有符合筛选的关卡</view>
      <view
        class="item-row {{item.cleared ? 'done' : ''}}"
        wx:for="{{items}}"
        wx:key="id"
        bindtap="onTapGradeMap"
      >
        <view class="item-main">
          <view class="item-title">{{item.title}}</view>
          <view class="item-status">{{item.cleared ? '已通关 · 去再练' : '未通关 · 去地图'}}</view>
        </view>
        <view class="stars">
          <text class="star {{item.stars >= 1 ? 'on' : ''}}">★</text>
          <text class="star {{item.stars >= 2 ? 'on' : ''}}">★</text>
          <text class="star {{item.stars >= 3 ? 'on' : ''}}">★</text>
        </view>
      </view>
    </view>
  </view>

  <view class="foot-link" bindtap="onClearAll">清空本学科闯关进度</view>
</view>
