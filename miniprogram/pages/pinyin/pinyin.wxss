.pinyin {
  min-height: 100vh;
}

.banner {
  background: linear-gradient(135deg, #5b8cff, #3d6ef5);
  color: #fff;
  border-radius: 28rpx;
  padding: 36rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 10rpx 0 #2f57c8;
}

.banner-title {
  font-size: 44rpx;
  font-weight: 900;
}

.banner-desc {
  margin-top: 8rpx;
  font-size: 26rpx;
  font-weight: 700;
  opacity: 0.92;
}

.grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 12rpx;
}

.tile {
  aspect-ratio: 1;
  border-radius: 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 3rpx solid;
  background: #fff;
}

.tile:active {
  opacity: 0.85;
}

.letter {
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.1;
}

.tip {
  margin-top: 6rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.c0 {
  border-color: #ff9a74;
  color: #e85d30;
  background: linear-gradient(180deg, #fff4ef, #fff);
}

.c1 {
  border-color: #5b8cff;
  color: #3d6ef5;
  background: linear-gradient(180deg, #eef3ff, #fff);
}

.c2 {
  border-color: #22b8a8;
  color: #0f8f82;
  background: linear-gradient(180deg, #e8fff8, #fff);
}

.c3 {
  border-color: #a78bfa;
  color: #7c5cbf;
  background: linear-gradient(180deg, #f5f0ff, #fff);
}

.c4 {
  border-color: #ffc93c;
  color: #c49a10;
  background: linear-gradient(180deg, #fff8df, #fff);
}
