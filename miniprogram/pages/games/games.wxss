.games {
  min-height: 100vh;
}

.intro {
  margin-bottom: 8rpx;
}

.intro-badge {
  display: inline-block;
  background: var(--color-sun);
  color: #5a4300;
  font-size: 22rpx;
  font-weight: 900;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  margin-bottom: 10rpx;
}

.intro-title {
  font-size: 48rpx;
  font-weight: 900;
  color: #1a1430;
}

.intro-desc {
  margin-top: 10rpx;
  font-size: 28rpx;
  color: #4a4458;
  font-weight: 700;
}

.pack-row {
  display: flex;
  gap: 12rpx;
  margin-top: 22rpx;
  flex-wrap: wrap;
}

.pack-chip {
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #4a4458;
  font-size: 28rpx;
  font-weight: 800;
  border: 3rpx solid #ece7df;
  box-shadow: 0 6rpx 0 rgba(26, 20, 48, 0.08);
  line-height: 1.2;
}

.pack-chip.on {
  color: #ffffff;
  background: #5b8cff;
  border-color: #5b8cff;
  box-shadow: 0 8rpx 0 #4470e0;
}

.grade-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 20rpx 0 22rpx;
  flex-wrap: wrap;
}

.grade-label {
  font-size: 26rpx;
  color: #4a4458;
  font-weight: 800;
}

.grade-chip {
  padding: 12rpx 26rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #4a4458;
  font-size: 26rpx;
  font-weight: 700;
  border: 3rpx solid #ece7df;
}

.grade-chip.on {
  color: #fff;
  background: #22b8a8;
  border-color: #22b8a8;
  box-shadow: 0 8rpx 0 #0f8f82;
  font-weight: 800;
}

.feature-row {
  display: flex;
  gap: 14rpx;
  margin-bottom: 14rpx;
}

.feature-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-bottom: 22rpx;
}

.play-tile {
  min-height: 200rpx;
  padding: 24rpx 20rpx 28rpx;
  color: #fff;
  position: relative;
  overflow: hidden;
}

.play-tile::after {
  content: '';
  position: absolute;
  right: -30rpx;
  bottom: -40rpx;
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.16);
}

.tile-tag {
  display: inline-block;
  font-size: 20rpx;
  font-weight: 900;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.28);
  margin-bottom: 14rpx;
}

.tile-title {
  font-size: 34rpx;
  font-weight: 900;
  position: relative;
  z-index: 1;
}

.tile-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.4;
  font-weight: 700;
  opacity: 0.92;
  position: relative;
  z-index: 1;
}

.f-duel {
  background: linear-gradient(145deg, #5b8cff 0%, #3d6ef5 100%);
  box-shadow: 0 10rpx 0 #2f57c8;
}

.f-sprint {
  background: linear-gradient(145deg, #ff9f1c 0%, #ff7a18 100%);
  box-shadow: 0 10rpx 0 #d96a10;
}

.f-exam {
  background: linear-gradient(145deg, #22b8a8 0%, #159f90 100%);
  box-shadow: 0 10rpx 0 #0f8f82;
}

.f-flash {
  background: linear-gradient(145deg, #a78bfa 0%, #8b5cf6 100%);
  box-shadow: 0 10rpx 0 #6d3fd4;
}

.extra-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 22rpx;
}

.extra-item {
  display: none;
}

.tools-foot {
  margin: 8rpx 0 12rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 800;
  color: #5b8cff;
}

.tools-foot.soft {
  margin-bottom: 28rpx;
  color: #9a93a8;
  font-size: 24rpx;
}

.feature-card {
  flex: 1;
  padding: 24rpx 20rpx;
  min-height: 200rpx;
  background: #ffffff;
}

.feature-emoji {
  display: inline-block;
  font-size: 20rpx;
  font-weight: 900;
  color: #fff;
  background: var(--color-danger);
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.feature-card.daily .feature-emoji {
  background: #ff9f1c;
}

.feature-title {
  font-size: 30rpx;
  font-weight: 900;
  color: #1a1430;
}

.feature-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #4a4458;
  line-height: 1.4;
  font-weight: 700;
}

.campaign {
  margin-bottom: 14rpx;
  background: #ffffff;
  overflow: hidden;
}

.campaign-badge {
  position: absolute;
  top: 18rpx;
  right: 18rpx;
  background: var(--color-accent);
  color: #fff;
  font-size: 20rpx;
  font-weight: 900;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
}

.campaign-tag {
  display: inline-block;
  font-size: 22rpx;
  color: #2f5fce;
  background: #e8eeff;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  margin-bottom: 12rpx;
  font-weight: 800;
}

.campaign-title,
.game-title {
  font-size: 32rpx;
  font-weight: 900;
  color: #1a1430;
}

.campaign-desc,
.game-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #4a4458;
  line-height: 1.4;
  font-weight: 700;
}

.link-wrong {
  margin-bottom: 20rpx;
  color: var(--color-accent);
  font-size: 26rpx;
  font-weight: 800;
}

.game-list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.game-card {
  padding: 22rpx 18rpx 28rpx;
  min-height: 210rpx;
  overflow: hidden;
  background: #ffffff;
}

.tone-0,
.tone-1,
.tone-2 {
  background: #ffffff;
}

.game-tag {
  display: inline-block;
  font-size: 20rpx;
  color: #fff;
  background: #1a1430;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  margin-bottom: 12rpx;
  font-weight: 800;
}

.game-go {
  position: absolute;
  right: 14rpx;
  bottom: 14rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--color-sun);
  color: #5a4300;
  font-weight: 900;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 0 #e0ad20;
}

.game-card:active,
.campaign:active,
.feature-card:active {
  opacity: 0.92;
}
