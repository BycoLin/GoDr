.games {
  min-height: 100vh;
}

.head-title {
  font-size: 44rpx;
  font-weight: 900;
  color: #1a1430;
}

.head-sub {
  margin-top: 8rpx;
  margin-bottom: 24rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #4a4458;
}

.hero-card {
  border-radius: 40rpx;
  padding: 36rpx 28rpx 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 14rpx 0 rgba(26, 20, 48, 0.1);
  text-align: center;
}

.hero-card.tone-sun {
  background: #ffc93c;
  box-shadow: 0 14rpx 0 #e0ad20;
  color: #5a4300;
}

.hero-card.tone-coral {
  background: #ff6f61;
  box-shadow: 0 14rpx 0 #d4453f;
  color: #fff;
}

.hero-badge {
  display: inline-block;
  font-size: 22rpx;
  font-weight: 900;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.45);
  margin-bottom: 12rpx;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 900;
}

.hero-desc {
  margin-top: 10rpx;
  font-size: 26rpx;
  font-weight: 700;
  opacity: 0.9;
  line-height: 1.4;
}

.hero-go {
  margin: 24rpx auto 0;
  width: 70%;
  min-height: 96rpx;
  border-radius: 999rpx;
  background: #1a1430;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 900;
}

.tone-coral .hero-go {
  background: #fff;
  color: #ff6f61;
}

.side-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-height: 120rpx;
  background: #fff;
  border: 3rpx solid #ece7df;
  border-radius: 32rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 10rpx 0 rgba(26, 20, 48, 0.06);
}

.path-entry {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-height: 120rpx;
  background: #effffb;
  border: 3rpx solid #9ee5db;
  border-radius: 32rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 10rpx 0 rgba(15, 143, 130, 0.12);
}

.path-entry.q-duel {
  background: #f3f6ff;
  border-color: #c9d6ff;
  box-shadow: 0 10rpx 0 rgba(91, 140, 255, 0.12);
}

.path-entry.q-duel .path-entry-tag {
  background: #5b8cff;
  box-shadow: 0 4rpx 0 #4470e0;
}

.path-entry-tag {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #22b8a8;
  color: #fff;
  font-size: 22rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 0 #0f8f82;
}

.path-entry-body {
  flex: 1;
  min-width: 0;
}

.path-entry-title {
  font-size: 32rpx;
  font-weight: 900;
  color: #1a1430;
}

.path-entry-desc {
  margin-top: 4rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #0f8f82;
}

.path-entry-go {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #ffc93c;
  color: #5a4300;
  font-size: 26rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 0 #e0ad20;
}

.theme-block {
  margin-bottom: 8rpx;
}

.theme-unit-label {
  font-size: 24rpx;
  font-weight: 800;
  color: #9a93a8;
  margin: 0 0 12rpx 4rpx;
}

.side-left {
  flex: 1;
  min-width: 0;
}

.side-tag {
  display: inline-block;
  font-size: 22rpx;
  font-weight: 900;
  color: #2f5fce;
  background: #e2ebff;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  margin-bottom: 8rpx;
}

.side-title {
  font-size: 32rpx;
  font-weight: 900;
}

.side-desc {
  margin-top: 4rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #4a4458;
}

.side-go {
  flex-shrink: 0;
  min-width: 96rpx;
  min-height: 72rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #5b8cff;
  color: #fff;
  font-size: 28rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
}

.sec-title {
  margin: 8rpx 0 16rpx;
  font-size: 32rpx;
  font-weight: 900;
  color: #1a1430;
}

.play-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 128rpx;
  background: #fff;
  border-radius: 32rpx;
  border: 3rpx solid #ece7df;
  padding: 20rpx 22rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 10rpx 0 rgba(26, 20, 48, 0.06);
}

.play-row.q-duel { background: #f3f6ff; border-color: #c9d6ff; }
.play-row.q-sprint,
.play-row.q-flash { background: #fff8ef; border-color: #ffe0a8; }
.play-row.q-exam { background: #effffb; border-color: #9ee5db; }

.play-row.m-teal { background: #effffb; border-color: #9ee5db; }
.play-row.m-coral { background: #fff5f3; border-color: #ffd0c8; }
.play-row.m-sky { background: #f3f6ff; border-color: #c9d6ff; }
.play-row.m-sun { background: #fff8ef; border-color: #ffe08a; }
.play-row.m-orange { background: #fff8ef; border-color: #ffe0a8; }
.play-row.m-grass { background: #f0fff4; border-color: #b8eec8; }

.play-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  background: #22b8a8;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 900;
  flex-shrink: 0;
}

.q-duel .play-icon { background: #5b8cff; }
.q-sprint .play-icon,
.q-flash .play-icon { background: #ff9f1c; }

.m-teal .play-icon { background: #22b8a8; }
.m-coral .play-icon { background: #ff6f61; }
.m-sky .play-icon { background: #5b8cff; }
.m-sun .play-icon { background: #ffc93c; color: #5a4300; }
.m-orange .play-icon { background: #ff9f1c; }
.m-grass .play-icon { background: #5ecf7b; }

.play-body {
  flex: 1;
  min-width: 0;
}

.play-name {
  font-size: 32rpx;
  font-weight: 900;
}

.play-tip {
  margin-top: 4rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #4a4458;
}

.play-go {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #1a1430;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 900;
  flex-shrink: 0;
}
