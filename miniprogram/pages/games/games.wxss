.games {
  min-height: 100vh;
}

.intro {
  position: relative;
  padding-right: 120rpx;
  margin-bottom: 8rpx;
}

.intro-badge {
  display: inline-block;
  background: var(--color-sun);
  color: #6a5000;
  font-size: 20rpx;
  font-weight: 900;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  margin-bottom: 10rpx;
}

.intro-title {
  font-size: 48rpx;
  font-weight: 900;
  color: #1f1a33;
}

.intro-desc {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: var(--color-muted);
  font-weight: 600;
}

.pack-row {
  display: flex;
  gap: 12rpx;
  margin-top: 22rpx;
  flex-wrap: wrap;
}

.pack-chip {
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #5a5268;
  font-size: 28rpx;
  font-weight: 800;
  box-shadow: 0 6rpx 0 rgba(43, 37, 64, 0.06);
  line-height: 1.2;
}

.pack-chip.on {
  color: #ffffff;
  background: linear-gradient(135deg, #7aa7ff, #5b8cff);
  box-shadow: 0 8rpx 0 #4470e0;
}

.grade-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 20rpx 0 22rpx;
  flex-wrap: wrap;
}

.grade-label {
  font-size: 26rpx;
  color: var(--color-muted);
  font-weight: 800;
}

.grade-chip {
  padding: 12rpx 26rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  color: var(--color-muted);
  font-size: 26rpx;
  font-weight: 700;
}

.grade-chip.on {
  color: #fff;
  background: linear-gradient(135deg, #42d6c5, #22b8a8);
  box-shadow: 0 8rpx 0 #11998a;
  font-weight: 800;
}

.feature-row {
  display: flex;
  gap: 14rpx;
  margin-bottom: 14rpx;
}

.feature-card {
  flex: 1;
  padding: 24rpx 20rpx;
  min-height: 200rpx;
}

.feature-card.boss {
  background: linear-gradient(160deg, #ffe5ea, #ffffff 62%);
}

.feature-card.daily {
  background: linear-gradient(160deg, #ffe9c8, #ffffff 62%);
}

.feature-emoji {
  display: inline-block;
  font-size: 20rpx;
  font-weight: 900;
  color: #fff;
  background: var(--color-danger);
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  transform: rotate(-6deg);
}

.feature-card.daily .feature-emoji {
  background: #ff9f1c;
}

.feature-title {
  font-size: 30rpx;
  font-weight: 900;
}

.feature-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: var(--color-muted);
  line-height: 1.4;
  font-weight: 600;
}

.campaign {
  margin-bottom: 14rpx;
  background: linear-gradient(135deg, #e8f0ff 0%, #ffffff 58%);
  overflow: hidden;
}

.campaign-badge {
  position: absolute;
  top: 18rpx;
  right: -8rpx;
  background: var(--color-accent);
  color: #fff;
  font-size: 20rpx;
  font-weight: 900;
  padding: 8rpx 22rpx;
  transform: rotate(12deg);
}

.campaign-tag {
  display: inline-block;
  font-size: 20rpx;
  color: var(--color-sky);
  background: var(--color-sky-soft);
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  margin-bottom: 12rpx;
  font-weight: 800;
}

.campaign-title,
.game-title {
  font-size: 32rpx;
  font-weight: 900;
}

.campaign-desc,
.game-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--color-muted);
  line-height: 1.4;
  font-weight: 600;
}

.link-wrong {
  margin-bottom: 20rpx;
  color: var(--color-accent);
  font-size: 26rpx;
  font-weight: 800;
}

.game-list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.game-card {
  padding: 22rpx 18rpx 28rpx;
  min-height: 210rpx;
  overflow: hidden;
}

.tone-0 {
  background: linear-gradient(165deg, #e8fff8, #ffffff);
}

.tone-1 {
  background: linear-gradient(165deg, #fff4e0, #ffffff);
}

.tone-2 {
  background: linear-gradient(165deg, #eef2ff, #ffffff);
}

.game-tag {
  display: inline-block;
  font-size: 20rpx;
  color: #fff;
  background: var(--color-ink);
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  margin-bottom: 12rpx;
  font-weight: 800;
}

.game-go {
  position: absolute;
  right: 14rpx;
  bottom: 14rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--color-sun);
  color: #6a5000;
  font-weight: 900;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 0 #e0ad20;
}

.game-card:active,
.campaign:active,
.feature-card:active {
  transform: translateY(4rpx) scale(0.98);
  transition: transform 0.12s ease;
}
