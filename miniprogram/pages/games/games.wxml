<view class="safe-pad games">
  <view class="head-title">趣味加练</view>
  <view class="head-sub">当前 {{packSubject}} · {{gradeLabel}} · 自由练，不涨星</view>

  <view class="hero-card {{heroTone}} pressable" bindtap="onTapHero">
    <view class="hero-badge">{{heroBadge}}</view>
    <view class="hero-title">{{heroTitle}}</view>
    <view class="hero-desc">{{heroDesc}}</view>
    <view class="hero-go">{{heroGo}}</view>
  </view>

  <view class="side-card pressable" bindtap="onTapAlt" wx:if="{{altTitle}}">
    <view class="side-left">
      <view class="side-tag">{{altTag}}</view>
      <view class="side-title">{{altTitle}}</view>
      <view class="side-desc">{{altDesc}}</view>
    </view>
    <view class="side-go">去练</view>
  </view>

  <view class="path-entry pressable q-duel" bindtap="onTapDuel">
    <view class="path-entry-tag">对练</view>
    <view class="path-entry-body">
      <view class="path-entry-title">趣味对练</view>
      <view class="path-entry-desc">90 秒比一比，看谁答得又快又准</view>
    </view>
    <view class="path-entry-go">开</view>
  </view>

  <view class="path-entry pressable q-exam" bindtap="onTapUnitTest">
    <view class="path-entry-tag">单元</view>
    <view class="path-entry-body">
      <view class="path-entry-title">单元测验</view>
      <view class="path-entry-desc">按课本单元 · 固定 10 题 · 错题进错题本</view>
    </view>
    <view class="path-entry-go">选</view>
  </view>

  <view class="path-entry pressable" wx:if="{{showPath}}" bindtap="onTapPath">
    <view class="path-entry-tag">进阶</view>
    <view class="path-entry-body">
      <view class="path-entry-title">{{pathTitle}}</view>
      <view class="path-entry-desc">{{pathDesc}}</view>
    </view>
    <view class="path-entry-go">开</view>
  </view>

  <block wx:if="{{themeUnits.length}}">
    <view class="sec-title">主题闯关</view>
    <view class="theme-block" wx:for="{{themeUnits}}" wx:key="id">
      <view class="theme-unit-label">{{item.title}}</view>
      <view
        class="play-row {{game.tone}} pressable"
        wx:for="{{item.games}}"
        wx:for-item="game"
        wx:key="id"
        data-mode="{{game.mode}}"
        bindtap="onTapThemeGame"
      >
        <view class="play-icon">{{game.tag}}</view>
        <view class="play-body">
          <view class="play-name">{{game.title}}</view>
          <view class="play-tip">{{game.subtitle}}</view>
        </view>
        <view class="play-go">开</view>
      </view>
    </view>
  </block>

  <view class="sec-title">专项练习</view>
  <view
    class="play-row {{item.tone}} pressable"
    wx:for="{{games}}"
    wx:key="title"
    data-mode="{{item.mode}}"
    data-link="{{item.link}}"
    bindtap="onTapGame"
  >
    <view class="play-icon">{{item.tag}}</view>
    <view class="play-body">
      <view class="play-name">{{item.title}}</view>
      <view class="play-tip">{{item.desc}}</view>
    </view>
    <view class="play-go">开</view>
  </view>
</view>
