<view class="safe-pad">
  <view class="intro card">
    <view class="intro-badge">选地图</view>
    <view class="intro-title">{{title}}</view>
    <view class="intro-desc">{{description}}</view>
  </view>

  <view class="section-title">你在几号地图？</view>
  <view class="grade-grid">
    <view
      class="grade-card"
      wx:for="{{gradeOptions}}"
      wx:key="value"
      data-grade="{{item.value}}"
      bindtap="onSelectGrade"
    >
      <view class="grade-num">{{item.short}}</view>
      <view class="grade-label">{{item.label}} · 开闯</view>
    </view>
  </view>
</view>
