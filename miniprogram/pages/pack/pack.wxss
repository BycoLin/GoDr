.intro {
  margin-bottom: 40rpx;
}

.intro-title {
  font-size: 40rpx;
  font-weight: 700;
}

.intro-desc {
  margin-top: 12rpx;
  color: var(--color-muted);
  line-height: 1.5;
}

.section-title {
  font-size: 28rpx;
  color: var(--color-muted);
  margin-bottom: 20rpx;
  font-weight: 600;
}

.grade-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.grade-card {
  width: calc(50% - 12rpx);
  background: var(--color-surface);
  border-radius: 24rpx;
  box-shadow: var(--shadow);
  padding: 48rpx 24rpx;
  text-align: center;
  border: 2rpx solid transparent;
}

.grade-card:active {
  border-color: var(--color-primary);
  transform: scale(0.98);
}

.grade-num {
  font-size: 72rpx;
  font-weight: 800;
  color: var(--color-primary);
  line-height: 1;
}

.grade-label {
  margin-top: 8rpx;
  color: var(--color-muted);
  font-size: 28rpx;
}
