.intro {
  margin-bottom: 36rpx;
}

.intro-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #0f6f6a;
}

.intro-desc {
  margin-top: 12rpx;
  color: var(--color-muted);
  line-height: 1.55;
}

.grade-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.grade-card {
  width: calc(50% - 8rpx);
  background: linear-gradient(160deg, #ffffff 0%, #e8fffa 100%);
  border-radius: 28rpx;
  box-shadow: var(--shadow);
  padding: 48rpx 24rpx;
  text-align: center;
  border: 2rpx solid transparent;
}

.grade-card:active {
  border-color: var(--color-primary);
  transform: scale(0.98);
}

.grade-num {
  font-size: 72rpx;
  font-weight: 800;
  color: var(--color-primary-deep);
  line-height: 1;
}

.grade-label {
  margin-top: 8rpx;
  color: var(--color-muted);
  font-size: 28rpx;
}
