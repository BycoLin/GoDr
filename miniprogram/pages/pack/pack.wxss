.intro {
  margin-bottom: 28rpx;
  background: linear-gradient(145deg, #fff4e0, #ffffff 60%);
  overflow: hidden;
}

.intro-badge {
  display: inline-block;
  background: var(--color-accent);
  color: #fff;
  font-size: 20rpx;
  font-weight: 900;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  margin-bottom: 12rpx;
}

.intro-title {
  font-size: 40rpx;
  font-weight: 900;
}

.intro-desc {
  margin-top: 12rpx;
  color: var(--color-muted);
  line-height: 1.55;
  font-weight: 600;
}

.grade-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.grade-card {
  width: calc(50% - 8rpx);
  background: linear-gradient(160deg, #ffffff 0%, #e8fff8 100%);
  border-radius: 32rpx;
  box-shadow: 0 10rpx 0 rgba(43, 37, 64, 0.07);
  padding: 48rpx 24rpx;
  text-align: center;
  border: 4rpx solid #fff;
}

.grade-card:active {
  transform: translateY(4rpx) scale(0.98);
}

.grade-num {
  font-size: 80rpx;
  font-weight: 900;
  color: var(--color-primary-deep);
  line-height: 1;
}

.grade-label {
  margin-top: 8rpx;
  color: var(--color-muted);
  font-size: 26rpx;
  font-weight: 800;
}
