<view class="safe-pad">
  <view class="summary card">
    <view class="summary-badge">关卡地图</view>
    <view class="summary-title">{{grade}} 年级{{subject}}冒险</view>
    <view class="summary-progress">已通关 {{clearedCount}} / {{totalCount}} {{unitLabel}}，继续加油！</view>
    <view class="bar">
      <view class="bar-fill" style="width: {{totalCount ? (clearedCount / totalCount * 100) : 0}}%;"></view>
    </view>
  </view>

  <view class="level-list">
    <view
      class="level-card {{item.unlocked ? '' : 'locked'}} {{item.cleared ? 'cleared' : ''}}"
      wx:for="{{levels}}"
      wx:key="id"
      data-id="{{item.id}}"
      data-unlocked="{{item.unlocked ? 1 : 0}}"
      bindtap="onTapLevel"
    >
      <view class="level-index">{{index + 1}}</view>
      <view class="level-body">
        <view class="level-title">{{item.title}}</view>
        <view class="level-meta">{{item.meta}}</view>
        <view class="stars">
          <text class="star {{item.stars >= 1 ? 'on' : ''}}">★</text>
          <text class="star {{item.stars >= 2 ? 'on' : ''}}">★</text>
          <text class="star {{item.stars >= 3 ? 'on' : ''}}">★</text>
        </view>
      </view>
      <view class="level-status {{item.unlocked ? (item.cleared ? 'again' : 'go') : 'lock'}}">
        {{item.unlocked ? (item.cleared ? '再玩' : '开闯') : '锁住'}}
      </view>
    </view>
  </view>
</view>
