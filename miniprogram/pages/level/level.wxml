<view class="level-page">
  <view class="top-bar">
    <view class="top-left">
      <view class="top-title">{{gradeLabel}} · {{subject}}</view>
      <view class="top-sub">已通关 {{clearedCount}}/{{totalCount}} {{unitLabel}} · 点☆可收藏</view>
    </view>
    <view class="top-star">★ {{starSum}}</view>
  </view>

  <scroll-view
    class="path-scroll"
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
    style="height: {{scrollHeight}}px;"
  >
    <view class="path-empty" wx:if="{{!levels.length}}">
      <view class="path-empty-title">暂无关卡</view>
      <view class="path-empty-tip">换个年级或学科试试，或返回首页重新进入</view>
    </view>
    <view class="path" wx:else>
      <view
        class="node {{item.unlocked ? '' : 'locked'}} {{item.cleared ? 'cleared' : ''}} {{item.id === focusId ? 'focus' : ''}}"
        wx:for="{{levels}}"
        wx:key="id"
        data-id="{{item.id}}"
        data-unlocked="{{item.unlocked ? 1 : 0}}"
        bindtap="onTapLevel"
        bindlongpress="onLongPressLevel"
      >
        <view class="rail" wx:if="{{index < levels.length - 1}}"></view>
        <view class="node-dot">
          <text wx:if="{{item.cleared}}">✓</text>
          <text wx:elif="{{!item.unlocked}}">锁</text>
          <text wx:else>{{index + 1}}</text>
        </view>
        <view class="node-card">
          <view class="node-main">
            <view class="node-title">第 {{index + 1}} 关 · {{item.title}}</view>
            <view class="node-meta">{{item.meta}}</view>
            <view class="stars">
              <text class="star {{item.stars >= 1 ? 'on' : ''}}">★</text>
              <text class="star {{item.stars >= 2 ? 'on' : ''}}">★</text>
              <text class="star {{item.stars >= 3 ? 'on' : ''}}">★</text>
            </view>
          </view>
          <view
            class="fav-btn {{item.favorited ? 'on' : ''}}"
            data-id="{{item.id}}"
            catchtap="onToggleFavorite"
          >{{item.favorited ? '★' : '☆'}}</view>
        </view>
      </view>
    </view>
    <view class="path-pad"></view>
  </scroll-view>

  <view class="adventure-dock adventure-dock--dock">
    <view class="adventure-bubble">{{goalText}}</view>
    <view
      class="btn btn-cta cta-btn {{toneClass}} {{focusUnlocked ? '' : 'disabled'}}"
      bindtap="onStartFocus"
    >{{focusCleared ? '再闯一关' : '开始冒险'}}</view>
  </view>
</view>
