.summary {
  margin-bottom: 28rpx;
  background: linear-gradient(145deg, #e8fffa 0%, #ffffff 70%);
}

.summary-title {
  font-size: 34rpx;
  font-weight: 800;
}

.summary-progress {
  margin-top: 8rpx;
  color: var(--color-muted);
  font-size: 26rpx;
}

.bar {
  margin-top: 20rpx;
  height: 16rpx;
  background: #e4eef7;
  border-radius: 999rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #4ba3ff, #1fa8a0);
  border-radius: 999rpx;
  transition: width 0.3s ease;
}

.level-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.level-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: var(--color-surface);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  padding: 26rpx 22rpx;
}

.level-card.locked {
  opacity: 0.5;
}

.level-card.cleared {
  background: linear-gradient(135deg, #e8fffa 0%, #ffffff 70%);
}

.level-index {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #dceeff, #d4f5f1);
  color: var(--color-primary-deep);
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 800;
  flex-shrink: 0;
}

.level-body {
  flex: 1;
  min-width: 0;
}

.level-title {
  font-size: 32rpx;
  font-weight: 800;
}

.level-meta {
  margin-top: 4rpx;
  font-size: 24rpx;
  color: var(--color-muted);
}

.stars {
  margin-top: 8rpx;
}

.star {
  color: #d7dee8;
  margin-right: 4rpx;
  font-size: 28rpx;
}

.star.on {
  color: #ffb020;
}

.level-status {
  font-size: 24rpx;
  color: var(--color-primary-deep);
  font-weight: 700;
  flex-shrink: 0;
}

.locked .level-status {
  color: var(--color-muted);
}
