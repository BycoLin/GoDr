.level-page {
  height: 100vh;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  overflow: hidden;
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx 12rpx;
  gap: 16rpx;
}

.top-title {
  font-size: 34rpx;
  font-weight: 900;
  color: #1a1430;
}

.top-sub {
  margin-top: 4rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #4a4458;
}

.top-star {
  background: #fff;
  border: 3rpx solid #ffe08a;
  color: #5a4300;
  font-size: 28rpx;
  font-weight: 900;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  box-shadow: 0 6rpx 0 #e0ad20;
  flex-shrink: 0;
}

.path-scroll {
  width: 100%;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.path {
  padding: 12rpx 0 0;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.node {
  display: flex;
  align-items: stretch;
  gap: 20rpx;
  position: relative;
  min-height: 140rpx;
}

.rail {
  position: absolute;
  left: 44rpx;
  top: 100rpx;
  bottom: -28rpx;
  width: 8rpx;
  background: #ffe08a;
  border-radius: 999rpx;
  z-index: 0;
}

.node-dot {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #ffc93c;
  color: #5a4300;
  font-size: 32rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 0 #e0ad20;
  flex-shrink: 0;
  z-index: 1;
  margin-top: 16rpx;
}

.node.cleared .node-dot {
  background: #2fbf7e;
  color: #fff;
  box-shadow: 0 10rpx 0 #1f9a62;
}

.node.locked .node-dot {
  background: #d8d2e0;
  color: #7a7388;
  box-shadow: 0 8rpx 0 #b8b2c0;
}

.node.focus .node-dot {
  width: 112rpx;
  height: 112rpx;
  font-size: 36rpx;
  margin-top: 8rpx;
  background: #22b8a8;
  color: #fff;
  box-shadow: 0 12rpx 0 #0f8f82;
  animation: pulse 1.6s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.06); }
}

.node-card {
  flex: 1;
  background: #fff;
  border-radius: 32rpx;
  border: 4rpx solid #ece7df;
  padding: 24rpx 16rpx 24rpx 22rpx;
  box-shadow: 0 10rpx 0 rgba(26, 20, 48, 0.06);
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.node-main {
  flex: 1;
  min-width: 0;
}

.fav-btn {
  width: 72rpx;
  height: 72rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #c8c2d4;
  font-weight: 900;
  border-radius: 50%;
}

.fav-btn.on {
  color: #ffc93c;
}

.fav-btn:active {
  transform: scale(0.9);
}

.node.focus .node-card {
  border-color: #9ee5db;
  background: #effffb;
  box-shadow: 0 12rpx 0 rgba(15, 143, 130, 0.18);
  transform: scale(1.02);
}

.node.locked {
  opacity: 0.55;
}

.node.locked .node-card {
  filter: grayscale(0.2);
}

.node-title {
  font-size: 32rpx;
  font-weight: 900;
  color: #1a1430;
}

.node-meta {
  margin-top: 6rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #4a4458;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.stars {
  margin-top: 10rpx;
}

.star {
  color: #d7dee8;
  margin-right: 6rpx;
  font-size: 32rpx;
}

.star.on {
  color: #ffc93c;
}

.path-pad {
  height: 280rpx;
}

.path-empty {
  margin-top: 80rpx;
  text-align: center;
  padding: 48rpx 32rpx;
}

.path-empty-title {
  font-size: 34rpx;
  font-weight: 900;
  color: #1a1430;
}

.path-empty-tip {
  margin-top: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #4a4458;
  line-height: 1.5;
}
