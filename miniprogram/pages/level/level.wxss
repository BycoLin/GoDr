.level-page {
  min-height: 100vh;
  background: #fff8ef;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx 12rpx;
  gap: 16rpx;
}

.top-title {
  font-size: 34rpx;
  font-weight: 900;
  color: #1a1430;
}

.top-sub {
  margin-top: 4rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #4a4458;
}

.top-star {
  background: #fff;
  border: 3rpx solid #ffe08a;
  color: #5a4300;
  font-size: 28rpx;
  font-weight: 900;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  box-shadow: 0 6rpx 0 #e0ad20;
  flex-shrink: 0;
}

.path-scroll {
  flex: 1;
  height: 0;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.path {
  padding: 12rpx 0 0;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.node {
  display: flex;
  align-items: stretch;
  gap: 20rpx;
  position: relative;
  min-height: 140rpx;
}

.rail {
  position: absolute;
  left: 44rpx;
  top: 100rpx;
  bottom: -28rpx;
  width: 8rpx;
  background: #ffe08a;
  border-radius: 999rpx;
  z-index: 0;
}

.node-dot {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #ffc93c;
  color: #5a4300;
  font-size: 32rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 0 #e0ad20;
  flex-shrink: 0;
  z-index: 1;
  margin-top: 16rpx;
}

.node.cleared .node-dot {
  background: #2fbf7e;
  color: #fff;
  box-shadow: 0 10rpx 0 #1f9a62;
}

.node.locked .node-dot {
  background: #d8d2e0;
  color: #7a7388;
  box-shadow: 0 8rpx 0 #b8b2c0;
}

.node.focus .node-dot {
  width: 112rpx;
  height: 112rpx;
  font-size: 36rpx;
  margin-top: 8rpx;
  background: #22b8a8;
  color: #fff;
  box-shadow: 0 12rpx 0 #0f8f82;
  animation: pulse 1.6s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.06); }
}

.node-card {
  flex: 1;
  background: #fff;
  border-radius: 32rpx;
  border: 4rpx solid #ece7df;
  padding: 24rpx 22rpx;
  box-shadow: 0 10rpx 0 rgba(26, 20, 48, 0.06);
  min-width: 0;
}

.node.focus .node-card {
  border-color: #9ee5db;
  background: #effffb;
  box-shadow: 0 12rpx 0 rgba(15, 143, 130, 0.18);
  transform: scale(1.02);
}

.node.locked {
  opacity: 0.55;
}

.node.locked .node-card {
  filter: grayscale(0.2);
}

.node-title {
  font-size: 32rpx;
  font-weight: 900;
  color: #1a1430;
}

.node-meta {
  margin-top: 6rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #4a4458;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.stars {
  margin-top: 10rpx;
}

.star {
  color: #d7dee8;
  margin-right: 6rpx;
  font-size: 32rpx;
}

.star.on {
  color: #ffc93c;
}

.path-pad {
  height: 280rpx;
}

.bottom-dock {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(255, 248, 239, 0) 0%, #fff8ef 28%, #fff8ef 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 20;
}

.goal-bubble {
  background: #fff;
  border: 3rpx solid #ece7df;
  border-radius: 999rpx;
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  font-weight: 800;
  color: #1a1430;
  margin-bottom: 14rpx;
  box-shadow: 0 6rpx 0 rgba(26, 20, 48, 0.06);
  max-width: 92%;
  text-align: center;
}

.start-btn {
  width: 82%;
}

.start-btn.disabled {
  background: #c8c2d4;
  box-shadow: 0 12rpx 0 #9a93a8;
  animation: none;
}

.start-btn:active {
  animation: none;
  transform: translateY(8rpx);
  box-shadow: 0 4rpx 0 #0f8f82;
}
