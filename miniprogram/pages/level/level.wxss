.summary {
  margin-bottom: 24rpx;
  background: linear-gradient(145deg, #e8fff8 0%, #ffffff 70%);
  overflow: hidden;
}

.summary-badge {
  display: inline-block;
  background: var(--color-primary);
  color: #fff;
  font-size: 20rpx;
  font-weight: 900;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  margin-bottom: 12rpx;
}

.summary-title {
  font-size: 36rpx;
  font-weight: 900;
}

.summary-progress {
  margin-top: 10rpx;
  color: var(--color-muted);
  font-size: 26rpx;
  font-weight: 600;
}

.bar {
  margin-top: 20rpx;
  height: 18rpx;
  background: #e8eef8;
  border-radius: 999rpx;
  overflow: hidden;
  border: 3rpx solid #fff;
}

.bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #ffc93c, #22b8a8);
  border-radius: 999rpx;
  transition: width 0.3s ease;
}

.level-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.level-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  background: #fff;
  border-radius: 32rpx;
  box-shadow: 0 10rpx 0 rgba(43, 37, 64, 0.07);
  padding: 22rpx 18rpx;
  border: 4rpx solid #fff;
}

.level-card.locked {
  opacity: 0.55;
  filter: grayscale(0.3);
}

.level-card.cleared {
  background: linear-gradient(135deg, #e8fff8 0%, #ffffff 70%);
}

.level-index {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #ffc93c, #ff9f1c);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 900;
  font-size: 30rpx;
  flex-shrink: 0;
  box-shadow: 0 6rpx 0 rgba(224, 173, 32, 0.45);
}

.locked .level-index {
  background: #cfd6e4;
  box-shadow: none;
}

.level-body {
  flex: 1;
  min-width: 0;
}

.level-title {
  font-size: 30rpx;
  font-weight: 900;
}

.level-meta {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: var(--color-muted);
  font-weight: 600;
}

.stars {
  margin-top: 8rpx;
}

.star {
  color: #d7dee8;
  margin-right: 4rpx;
  font-size: 28rpx;
}

.star.on {
  color: #ffc93c;
}

.level-status {
  font-size: 24rpx;
  font-weight: 900;
  flex-shrink: 0;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
}

.level-status.go {
  color: #fff;
  background: var(--color-primary);
}

.level-status.again {
  color: var(--color-primary-deep);
  background: var(--color-primary-soft);
}

.level-status.lock {
  color: var(--color-muted);
  background: #eef1f6;
}
