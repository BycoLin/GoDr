<view class="safe-pad home">
  <view class="hero">
    <view class="hero-copy">
      <view class="hello-chip">Hi 小朋友</view>
      <view class="brand">闯关叭叭</view>
      <view class="tagline">语文 · 数学 · 英语，趣味自测记牢一点</view>
    </view>
    <view class="mascot">
      <view class="mascot-body">
        <view class="mascot-face">
          <view class="eye eye-l"></view>
          <view class="eye eye-r"></view>
          <view class="cheek cheek-l"></view>
          <view class="cheek cheek-r"></view>
          <view class="smile"></view>
        </view>
        <view class="mascot-hat">叭</view>
      </view>
      <view class="sticker s1">练</view>
      <view class="sticker s2">GO</view>
      <view class="dot d1"></view>
      <view class="dot d2"></view>
      <view class="dot d3"></view>
    </view>
  </view>

  <view wx:if="{{continueTip}}" class="card continue" bindtap="onContinue">
    <view class="continue-badge">继续练</view>
    <view class="continue-label">你上次练到这里</view>
    <view class="continue-text">{{continueTip}}</view>
    <view class="continue-go">接着练习 →</view>
  </view>

  <view class="card games-entry" bindtap="onGoGames">
    <view class="game-art">
      <view class="orb orb-a"></view>
      <view class="orb orb-b"></view>
    </view>
    <view class="games-entry-label">趣味练习</view>
    <view class="games-entry-title">换种方式练一练</view>
    <view class="games-entry-desc">诗词默写 · 口算自测 · 单词认读 · 错题复习</view>
    <view class="go-pill">去练习</view>
  </view>

  <view class="section-title">选择学习内容</view>
  <view class="pack-list">
    <view
      class="card pack-card {{item.toneClass}}"
      wx:for="{{packs}}"
      wx:key="id"
      data-pack-id="{{item.id}}"
      bindtap="onTapPack"
    >
      <view class="pack-icon">{{item.iconText}}</view>
      <view class="pack-body">
        <view class="pack-subject">{{item.subject}}练习</view>
        <view class="pack-title">{{item.title}}</view>
        <view class="pack-desc">{{item.description}}</view>
        <view class="pack-meta">{{item.gradeLabel}} · 开始练习</view>
      </view>
    </view>
  </view>
</view>
