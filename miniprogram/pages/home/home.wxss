.home {
  min-height: 100vh;
}

.section-head {
  margin-bottom: 8rpx;
}

.section-head .section-title {
  margin-bottom: 0;
}

.section-hint {
  margin-top: 6rpx;
  margin-bottom: 16rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #4a4458;
}

.side-links {
  display: flex;
  gap: 12rpx;
  margin-top: 8rpx;
  margin-bottom: 24rpx;
}

.side-link {
  flex: 1;
  background: #fff;
  border: 3rpx solid #ece7df;
  border-radius: 24rpx;
  padding: 22rpx 18rpx;
  box-shadow: 0 8rpx 0 rgba(26, 20, 48, 0.06);
}

.side-link.play {
  background: linear-gradient(145deg, #e8eeff, #ffffff);
  border-color: #c9d6ff;
}

.side-link.soft {
  background: #fffaf0;
}

.side-emoji {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  border-radius: 14rpx;
  background: #ffc93c;
  color: #5a4300;
  font-size: 22rpx;
  font-weight: 900;
  margin-bottom: 10rpx;
}

.side-link.play .side-emoji {
  background: #5b8cff;
  color: #fff;
}

.side-title {
  font-size: 28rpx;
  font-weight: 900;
  color: #1a1430;
}

.side-desc {
  margin-top: 6rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #4a4458;
}

.pack-go {
  position: absolute;
  right: 22rpx;
  bottom: 22rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--color-sun);
  color: #5a4300;
  font-weight: 900;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 0 #e0ad20;
}

.hero {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
  padding: 8rpx 4rpx 28rpx;
  position: relative;
}

.hero-copy {
  flex: 1;
  min-width: 0;
  z-index: 1;
}

.hello-chip {
  display: inline-block;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #fff;
  color: var(--color-accent);
  font-size: 22rpx;
  font-weight: 800;
  border: 3rpx solid #ece7df;
  box-shadow: 0 6rpx 0 rgba(255, 111, 97, 0.2);
  margin-bottom: 12rpx;
}

.brand {
  font-size: 56rpx;
  font-weight: 900;
  color: #1a1430;
  line-height: 1.15;
  letter-spacing: 1rpx;
}

.tagline {
  margin-top: 12rpx;
  font-size: 28rpx;
  color: #4a4458;
  font-weight: 700;
  max-width: 380rpx;
  line-height: 1.45;
}

.mascot {
  position: relative;
  width: 220rpx;
  height: 200rpx;
  flex-shrink: 0;
}

.mascot-body {
  position: absolute;
  right: 20rpx;
  top: 28rpx;
  width: 140rpx;
  height: 140rpx;
  border-radius: 46% 54% 48% 52%;
  background: #22b8a8;
  box-shadow: 0 10rpx 0 #0f8f82;
}

.mascot-face {
  position: absolute;
  top: 34rpx;
  right: 28rpx;
  bottom: 40rpx;
  left: 28rpx;
}

.eye {
  position: absolute;
  top: 18rpx;
  width: 16rpx;
  height: 22rpx;
  background: #1a1430;
  border-radius: 50%;
}

.eye-l {
  left: 18rpx;
}

.eye-r {
  right: 18rpx;
}

.cheek {
  position: absolute;
  top: 42rpx;
  width: 18rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #ff8a8d;
}

.cheek-l {
  left: 4rpx;
}

.cheek-r {
  right: 4rpx;
}

.smile {
  position: absolute;
  left: 50%;
  bottom: 8rpx;
  width: 36rpx;
  height: 18rpx;
  margin-left: -18rpx;
  border: 4rpx solid #1a1430;
  border-top: 0;
  border-radius: 0 0 40rpx 40rpx;
}

.mascot-hat {
  position: absolute;
  top: -18rpx;
  left: 50%;
  margin-left: -34rpx;
  width: 68rpx;
  height: 40rpx;
  border-radius: 20rpx 20rpx 10rpx 10rpx;
  background: #ffc93c;
  color: #5a4300;
  font-size: 26rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 0 #d4a010;
}

.sticker {
  position: absolute;
  font-size: 22rpx;
  font-weight: 900;
  color: #fff;
  padding: 8rpx 14rpx;
  border-radius: 16rpx;
}

.s1 {
  top: 8rpx;
  left: 0;
  background: var(--color-accent);
  box-shadow: 0 6rpx 0 #e25549;
  transform: rotate(-10deg);
}

.s2 {
  right: 0;
  bottom: 18rpx;
  background: var(--color-sky);
  transform: rotate(8deg);
  box-shadow: 0 6rpx 0 #4470e0;
}

.dot {
  position: absolute;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: var(--color-sun);
}

.d1 {
  top: 0;
  right: 48rpx;
}

.d2 {
  left: 48rpx;
  bottom: 8rpx;
  background: #ff8fb8;
  width: 10rpx;
  height: 10rpx;
}

.d3 {
  right: 8rpx;
  top: 70rpx;
  background: #8ad7ff;
}

.mascot.bob .mascot-body {
  animation: mascotBob 2.2s ease-in-out infinite;
}

@keyframes mascotBob {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

.mono-entry {
  margin-bottom: 22rpx;
  background: linear-gradient(145deg, #ffe566 0%, #ffc93c 45%, #ff9f1c 100%);
  border-color: #ffc93c;
  box-shadow: 0 12rpx 0 #e0ad20;
  overflow: hidden;
  min-height: 220rpx;
}

.mono-badge {
  position: absolute;
  top: 18rpx;
  right: 18rpx;
  background: #ff6f61;
  color: #fff;
  font-size: 20rpx;
  font-weight: 900;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
}

.mono-art {
  position: absolute;
  right: 28rpx;
  bottom: 28rpx;
  width: 140rpx;
  height: 120rpx;
}

.mono-dice {
  font-size: 56rpx;
  position: absolute;
  right: 0;
  top: 0;
  animation: diceFloat 1.6s ease-in-out infinite;
}

.mono-piece {
  position: absolute;
  left: 10rpx;
  bottom: 8rpx;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #22b8a8;
  color: #fff;
  font-size: 24rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 0 #0f8f82;
}

.mono-piece.bounce {
  animation: pieceBounce 1.2s ease-in-out infinite;
}

@keyframes diceFloat {
  0%, 100% { transform: translateY(0) rotate(-6deg); }
  50% { transform: translateY(-12rpx) rotate(8deg); }
}

@keyframes pieceBounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-14rpx); }
}

.mono-label {
  font-size: 22rpx;
  font-weight: 900;
  color: #5a4300;
}

.mono-title {
  margin-top: 8rpx;
  font-size: 40rpx;
  font-weight: 900;
  color: #5a4300;
}

.mono-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #7a5a10;
  max-width: 420rpx;
  line-height: 1.45;
  padding-right: 120rpx;
}

.mono-go {
  display: inline-block;
  margin-top: 18rpx;
  background: #1a1430;
  color: #fff;
  font-size: 24rpx;
  font-weight: 900;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
}

.continue {
  margin-bottom: 22rpx;
  background: #ffffff;
  overflow: hidden;
}

.continue-badge {
  position: absolute;
  top: 18rpx;
  right: 18rpx;
  background: var(--color-accent);
  color: #fff;
  font-size: 20rpx;
  font-weight: 800;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
}

.continue-label {
  font-size: 22rpx;
  color: var(--color-accent);
  font-weight: 800;
}

.continue-text {
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 800;
  color: #1a1430;
  padding-right: 100rpx;
}

.continue-go {
  margin-top: 16rpx;
  color: var(--color-primary-deep);
  font-size: 26rpx;
  font-weight: 800;
}

.games-entry {
  margin-bottom: 30rpx;
  background: #ffffff;
  overflow: hidden;
  min-height: 180rpx;
}

.game-art {
  position: absolute;
  right: -20rpx;
  top: -20rpx;
  width: 180rpx;
  height: 180rpx;
  pointer-events: none;
}

.orb {
  position: absolute;
  border-radius: 50%;
}

.orb-a {
  width: 120rpx;
  height: 120rpx;
  right: 20rpx;
  top: 20rpx;
  background: #d8f7f1;
}

.orb-b {
  width: 70rpx;
  height: 70rpx;
  right: 110rpx;
  top: 90rpx;
  background: #dde6ff;
}

.games-entry-label {
  font-size: 22rpx;
  color: var(--color-primary-deep);
  font-weight: 800;
}

.games-entry-title {
  margin-top: 10rpx;
  font-size: 38rpx;
  font-weight: 900;
  color: #1a1430;
}

.games-entry-desc {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #4a4458;
  font-weight: 700;
  padding-right: 80rpx;
}

.go-pill {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  background: var(--color-sun);
  color: #5a4300;
  font-weight: 900;
  font-size: 24rpx;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  box-shadow: 0 6rpx 0 #e0ad20;
}

.pack-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.pack-card {
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
  background: #ffffff;
  padding-bottom: 40rpx;
  padding-right: 96rpx;
}

.pack-card:active {
  opacity: 0.92;
}

.pack-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 900;
  color: #fff;
  flex-shrink: 0;
  box-shadow: 0 8rpx 0 rgba(0, 0, 0, 0.12);
}

.pack-cn .pack-icon {
  background: #ff6f61;
}

.pack-math .pack-icon {
  background: #5b8cff;
}

.pack-en .pack-icon {
  background: #22b8a8;
}

.pack-body {
  flex: 1;
  min-width: 0;
}

.pack-subject {
  display: inline-block;
  font-size: 22rpx;
  color: #fff;
  background: #1a1430;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  margin-bottom: 10rpx;
  font-weight: 800;
}

.pack-title {
  font-size: 34rpx;
  font-weight: 900;
  color: #1a1430;
}

.pack-desc {
  margin-top: 8rpx;
  color: #4a4458;
  font-size: 26rpx;
  line-height: 1.5;
  font-weight: 600;
}

.pack-meta {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: var(--color-primary-deep);
  font-weight: 800;
}
