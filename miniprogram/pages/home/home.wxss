.home {
  min-height: 100vh;
}

.hero {
  position: relative;
  padding: 28rpx 8rpx 40rpx;
  overflow: hidden;
}

.brand {
  font-size: 56rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
  color: #0f6f6a;
  line-height: 1.2;
}

.tagline {
  margin-top: 12rpx;
  font-size: 28rpx;
  color: var(--color-muted);
}

.hero-art {
  position: absolute;
  right: -8rpx;
  top: 8rpx;
  width: 240rpx;
  height: 180rpx;
  pointer-events: none;
}

.leaf {
  position: absolute;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50% 40% 55% 45%;
  background: #5ad1c8;
  opacity: 0.45;
  animation: floaty 4s ease-in-out infinite;
}

.leaf-a {
  right: 36rpx;
  top: 16rpx;
  transform: rotate(18deg);
}

.leaf-b {
  right: 104rpx;
  top: 72rpx;
  background: #ff9a74;
  opacity: 0.4;
  animation-delay: 0.8s;
  transform: rotate(-20deg);
}

.scroll {
  position: absolute;
  right: 16rpx;
  bottom: 8rpx;
  width: 128rpx;
  height: 86rpx;
  border-radius: 20rpx;
  background: linear-gradient(145deg, #ffffff, #dceeff);
  border: 2rpx solid rgba(75, 163, 255, 0.25);
  box-shadow: var(--shadow);
  animation: softPulse 3.2s ease-in-out infinite;
}

@keyframes floaty {
  0%,
  100% {
    transform: translateY(0) rotate(18deg);
  }
  50% {
    transform: translateY(-14rpx) rotate(24deg);
  }
}

@keyframes softPulse {
  0%,
  100% {
    transform: scale(1);
    opacity: 1;
  }
  50% {
    transform: scale(1.05);
    opacity: 0.92;
  }
}

.continue {
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, #fff7f1 0%, #ffffff 70%);
}

.continue-label {
  font-size: 22rpx;
  color: var(--color-accent);
  font-weight: 700;
}

.continue-text {
  margin-top: 8rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.continue-go {
  margin-top: 14rpx;
  color: var(--color-primary-deep);
  font-size: 26rpx;
  font-weight: 600;
}

.games-entry {
  margin-bottom: 36rpx;
  background: linear-gradient(135deg, #e8fffa 0%, #ffffff 65%);
}

.games-entry-label {
  font-size: 22rpx;
  color: var(--color-primary-deep);
  font-weight: 700;
}

.games-entry-title {
  margin-top: 8rpx;
  font-size: 34rpx;
  font-weight: 800;
}

.games-entry-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--color-muted);
  line-height: 1.5;
}

.pack-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.pack-card {
  transition: transform 0.2s ease;
  background: linear-gradient(160deg, #ffffff 0%, #f4fbff 100%);
}

.pack-card:active {
  transform: scale(0.98);
}

.pack-subject {
  display: inline-block;
  font-size: 22rpx;
  color: var(--color-sky);
  background: var(--color-sky-soft);
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  margin-bottom: 14rpx;
  font-weight: 700;
}

.pack-title {
  font-size: 36rpx;
  font-weight: 800;
}

.pack-desc {
  margin-top: 10rpx;
  color: var(--color-muted);
  font-size: 26rpx;
  line-height: 1.55;
}

.pack-meta {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: var(--color-primary-deep);
  font-weight: 600;
}
