.home {
  min-height: 100vh;
  padding-bottom: 24rpx;
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
  gap: 12rpx;
}

.top-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
  flex: 1;
}

.top-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
  flex-shrink: 0;
}

.pill {
  font-size: 20rpx;
  font-weight: 900;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  line-height: 1.2;
}

.pill.rank {
  background: #ffc93c;
  color: #5a4300;
}

.pill.streak {
  background: #d6f8f2;
  color: #0f8f82;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #22b8a8;
  box-shadow: 0 6rpx 0 #0f8f82;
  position: relative;
  flex-shrink: 0;
}

.avatar-face {
  position: absolute;
  top: 20rpx;
  right: 18rpx;
  bottom: 22rpx;
  left: 18rpx;
}

.a-eye {
  position: absolute;
  top: 6rpx;
  width: 8rpx;
  height: 12rpx;
  background: #1a1430;
  border-radius: 50%;
}

.a-l { left: 10rpx; }
.a-r { right: 10rpx; }

.a-smile {
  position: absolute;
  left: 50%;
  bottom: 2rpx;
  width: 20rpx;
  height: 10rpx;
  margin-left: -10rpx;
  border: 3rpx solid #1a1430;
  border-top: 0;
  border-radius: 0 0 20rpx 20rpx;
}

.avatar.bob {
  animation: mascotBob 2.2s ease-in-out infinite;
}

@keyframes mascotBob {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6rpx); }
}

.hello {
  font-size: 30rpx;
  font-weight: 900;
  color: #1a1430;
}

.hello-sub {
  margin-top: 4rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #4a4458;
}

.banner {
  position: relative;
  overflow: hidden;
  border-radius: 36rpx;
  padding: 36rpx 32rpx;
  min-height: 240rpx;
  border: 4rpx solid transparent;
  box-shadow: 0 12rpx 0 rgba(26, 20, 48, 0.12);
  margin-bottom: 28rpx;
}

.banner.tone-cn {
  background: linear-gradient(135deg, #ffb4a8 0%, #ff6f61 55%, #f04d5a 100%);
  border-color: #ff6f61;
  box-shadow: 0 12rpx 0 #d4453f;
  color: #fff;
}

.banner.tone-math {
  background: linear-gradient(135deg, #9bb8ff 0%, #5b8cff 55%, #3d6ef5 100%);
  border-color: #5b8cff;
  box-shadow: 0 12rpx 0 #4470e0;
  color: #fff;
}

.banner.tone-en {
  background: linear-gradient(135deg, #6fe0d2 0%, #22b8a8 55%, #0f8f82 100%);
  border-color: #22b8a8;
  box-shadow: 0 12rpx 0 #0f8f82;
  color: #fff;
}

.banner-copy {
  position: relative;
  z-index: 1;
  max-width: 420rpx;
}

.banner-kicker {
  font-size: 22rpx;
  font-weight: 800;
  opacity: 0.9;
}

.banner-title {
  margin-top: 8rpx;
  font-size: 52rpx;
  font-weight: 900;
  line-height: 1.15;
}

.banner-desc {
  margin-top: 10rpx;
  font-size: 26rpx;
  font-weight: 700;
  opacity: 0.92;
}

.banner-btn {
  display: inline-block;
  margin-top: 22rpx;
  background: #fff;
  color: #1a1430;
  font-size: 26rpx;
  font-weight: 900;
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  box-shadow: 0 6rpx 0 rgba(255, 255, 255, 0.35);
}

.banner.tone-cn .banner-btn { color: #e84b6a; }
.banner.tone-math .banner-btn { color: #2f5fce; }
.banner.tone-en .banner-btn { color: #0f8f82; }

.banner-art {
  position: absolute;
  right: 28rpx;
  bottom: 28rpx;
  width: 140rpx;
  height: 120rpx;
}

.banner-dice {
  position: absolute;
  right: 8rpx;
  top: 0;
  font-size: 56rpx;
  animation: diceFloat 1.6s ease-in-out infinite;
}

.banner-piece {
  position: absolute;
  left: 16rpx;
  bottom: 8rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.35);
  color: #fff;
  font-size: 28rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: pieceBounce 1.2s ease-in-out infinite;
}

@keyframes diceFloat {
  0%, 100% { transform: translateY(0) rotate(-6deg); }
  50% { transform: translateY(-12rpx) rotate(8deg); }
}

@keyframes pieceBounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}

.cat-row {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  align-items: flex-start;
  margin-bottom: 24rpx;
  padding: 4rpx 8rpx 0;
}

.cat {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 30%;
}

.cat-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 900;
  color: #ffffff;
  border: 6rpx solid transparent;
  box-shadow: 0 8rpx 0 rgba(26, 20, 48, 0.1);
  box-sizing: border-box;
}

.cat-icon.tone-cn {
  background: #ff6f61;
}

.cat-icon.tone-math {
  background: #5b8cff;
}

.cat-icon.tone-en {
  background: #22b8a8;
}

.cat.on .cat-icon {
  border-color: #ffc93c;
  box-shadow: 0 10rpx 0 #e0ad20;
}

.cat-name {
  margin-top: 10rpx;
  font-size: 24rpx;
  font-weight: 800;
  color: #1a1430;
  line-height: 1.2;
  text-align: center;
}

.cat.on .cat-name {
  font-weight: 900;
  color: #0f8f82;
}

.block {
  margin-bottom: 28rpx;
}

.block-title {
  font-size: 32rpx;
  font-weight: 900;
  color: #1a1430;
  margin-bottom: 16rpx;
}

.reco-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 14rpx;
}

.reco-card {
  width: calc(50% - 7rpx);
  padding: 22rpx 18rpx 24rpx;
  border-radius: 28rpx;
  background: #fff;
  border: 3rpx solid #ece7df;
  box-shadow: 0 8rpx 0 rgba(26, 20, 48, 0.06);
  box-sizing: border-box;
}

.reco-card.r-review {
  background: linear-gradient(160deg, #ffe8e4, #ffffff);
  border-color: #ffc4bc;
}

.reco-card.r-map {
  background: linear-gradient(160deg, #ffe8e4, #ffffff);
  border-color: #ffc4bc;
}

.reco-card.r-cont {
  background: linear-gradient(160deg, #fff6df, #ffffff);
  border-color: #ffe08a;
}

.reco-card.r-games {
  background: linear-gradient(160deg, #e8eeff, #ffffff);
  border-color: #c9d6ff;
}

.reco-card.r-tools {
  background: linear-gradient(160deg, #e8fff8, #ffffff);
  border-color: #9ee5db;
}

.reco-tag {
  display: inline-block;
  align-self: flex-start;
  font-size: 20rpx;
  font-weight: 900;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(26, 20, 48, 0.08);
  color: #4a4458;
  margin-bottom: 14rpx;
}

.reco-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 22rpx;
  background: #ffc93c;
  color: #5a4300;
  font-size: 28rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 14rpx;
  box-shadow: 0 6rpx 0 #e0ad20;
}

.r-review .reco-icon { background: #ff6f61; color: #fff; box-shadow: 0 6rpx 0 #d4453f; }
.r-map .reco-icon { background: #ff6f61; color: #fff; box-shadow: 0 6rpx 0 #d4453f; }
.r-games .reco-icon { background: #5b8cff; color: #fff; box-shadow: 0 6rpx 0 #4470e0; }
.r-tools .reco-icon { background: #22b8a8; color: #fff; box-shadow: 0 6rpx 0 #0f8f82; }

.reco-title {
  font-size: 28rpx;
  font-weight: 900;
  color: #1a1430;
}

.reco-desc {
  margin-top: 6rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #4a4458;
  line-height: 1.35;
}

.plan-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #fff;
  border: 3rpx solid #ece7df;
  border-radius: 32rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 10rpx 0 rgba(26, 20, 48, 0.08);
}

.plan-left {
  flex: 1;
  min-width: 0;
}

.plan-badge {
  display: inline-block;
  font-size: 20rpx;
  font-weight: 900;
  color: #5a4300;
  background: #ffc93c;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  margin-bottom: 10rpx;
}

.plan-title {
  font-size: 32rpx;
  font-weight: 900;
  color: #1a1430;
}

.plan-meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #4a4458;
}

.plan-bar {
  margin-top: 14rpx;
  height: 14rpx;
  background: #ece7df;
  border-radius: 999rpx;
  overflow: hidden;
}

.plan-bar-fill {
  height: 100%;
  background: #22b8a8;
  border-radius: 999rpx;
}

.grade-mini {
  display: flex;
  gap: 10rpx;
  margin-top: 16rpx;
}

.g-chip {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #f7f4ee;
  border: 2rpx solid #ece7df;
  font-size: 22rpx;
  font-weight: 800;
  color: #4a4458;
}

.g-chip.on {
  background: #5b8cff;
  border-color: #5b8cff;
  color: #fff;
  box-shadow: 0 4rpx 0 #4470e0;
}

.plan-go {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #ffc93c;
  color: #5a4300;
  font-size: 28rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 0 #e0ad20;
}

.act-row {
  display: flex;
  gap: 14rpx;
}

.act-card {
  flex: 1;
  background: #fff;
  border: 3rpx solid #ece7df;
  border-radius: 28rpx;
  padding: 22rpx 14rpx;
  text-align: center;
  box-shadow: 0 8rpx 0 rgba(26, 20, 48, 0.06);
}

.act-icon {
  width: 56rpx;
  height: 56rpx;
  margin: 0 auto 12rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 900;
  color: #fff;
}

.a-mono .act-icon { background: #ff9f1c; }
.a-play .act-icon { background: #5b8cff; }
.a-box .act-icon { background: #22b8a8; }

.act-title {
  font-size: 26rpx;
  font-weight: 900;
  color: #1a1430;
}

.act-desc {
  margin-top: 4rpx;
  font-size: 20rpx;
  font-weight: 700;
  color: #4a4458;
}

.banner:active,
.reco-card:active,
.plan-card:active,
.act-card:active,
.cat:active {
  opacity: 0.92;
}
