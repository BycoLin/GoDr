.home {
  min-height: 100vh;
}

.hero {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
  padding: 8rpx 4rpx 28rpx;
  position: relative;
}

.hero-copy {
  flex: 1;
  min-width: 0;
  z-index: 1;
}

.hello-chip {
  display: inline-block;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #fff;
  color: var(--color-accent);
  font-size: 22rpx;
  font-weight: 800;
  box-shadow: 0 6rpx 0 rgba(255, 111, 97, 0.2);
  margin-bottom: 12rpx;
}

.brand {
  font-size: 52rpx;
  font-weight: 900;
  color: #1f1a33;
  line-height: 1.15;
}

.tagline {
  margin-top: 12rpx;
  font-size: 28rpx;
  color: var(--color-muted);
  font-weight: 600;
  max-width: 360rpx;
}

.mascot {
  position: relative;
  width: 220rpx;
  height: 200rpx;
  flex-shrink: 0;
}

.mascot-body {
  position: absolute;
  right: 20rpx;
  top: 28rpx;
  width: 140rpx;
  height: 140rpx;
  border-radius: 46% 54% 48% 52%;
  background: linear-gradient(160deg, #7cf0df, #22b8a8);
  box-shadow: 0 12rpx 0 rgba(17, 153, 138, 0.25);
  animation: bouncey 2.8s ease-in-out infinite;
}

.mascot-face {
  position: absolute;
  top: 34rpx;
  right: 28rpx;
  bottom: 40rpx;
  left: 28rpx;
}

.eye {
  position: absolute;
  top: 18rpx;
  width: 16rpx;
  height: 22rpx;
  background: #2b2540;
  border-radius: 50%;
}

.eye-l {
  left: 18rpx;
}

.eye-r {
  right: 18rpx;
}

.cheek {
  position: absolute;
  top: 42rpx;
  width: 18rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #ff9ea0;
  opacity: 0.8;
}

.cheek-l {
  left: 4rpx;
}

.cheek-r {
  right: 4rpx;
}

.smile {
  position: absolute;
  left: 50%;
  bottom: 8rpx;
  width: 36rpx;
  height: 18rpx;
  margin-left: -18rpx;
  border: 4rpx solid #2b2540;
  border-top: 0;
  border-radius: 0 0 40rpx 40rpx;
}

.mascot-hat {
  position: absolute;
  top: -18rpx;
  left: 50%;
  margin-left: -34rpx;
  width: 68rpx;
  height: 40rpx;
  border-radius: 20rpx 20rpx 10rpx 10rpx;
  background: linear-gradient(135deg, #ffc93c, #ff9f1c);
  color: #fff;
  font-size: 24rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 0 rgba(255, 159, 28, 0.35);
}

.sticker {
  position: absolute;
  font-size: 22rpx;
  font-weight: 900;
  color: #fff;
  padding: 8rpx 14rpx;
  border-radius: 16rpx;
  transform: rotate(-12deg);
  animation: wiggle 3s ease-in-out infinite;
}

.s1 {
  top: 8rpx;
  left: 0;
  background: var(--color-accent);
  box-shadow: 0 6rpx 0 #e25549;
}

.s2 {
  right: 0;
  bottom: 18rpx;
  background: var(--color-sky);
  transform: rotate(10deg);
  box-shadow: 0 6rpx 0 #4470e0;
  animation-delay: 0.6s;
}

.dot {
  position: absolute;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: var(--color-sun);
}

.d1 {
  top: 0;
  right: 48rpx;
}

.d2 {
  left: 48rpx;
  bottom: 8rpx;
  background: #ff8fb8;
  width: 10rpx;
  height: 10rpx;
}

.d3 {
  right: 8rpx;
  top: 70rpx;
  background: #8ad7ff;
}

@keyframes bouncey {
  0%,
  100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10rpx);
  }
}

@keyframes wiggle {
  0%,
  100% {
    transform: rotate(-12deg) scale(1);
  }
  50% {
    transform: rotate(-6deg) scale(1.06);
  }
}

.continue {
  margin-bottom: 22rpx;
  background: linear-gradient(145deg, #fff1e8, #ffffff 60%);
  overflow: hidden;
}

.continue-badge {
  position: absolute;
  top: 18rpx;
  right: 18rpx;
  background: var(--color-accent);
  color: #fff;
  font-size: 20rpx;
  font-weight: 800;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  transform: rotate(8deg);
}

.continue-label {
  font-size: 22rpx;
  color: var(--color-accent);
  font-weight: 800;
}

.continue-text {
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 800;
  padding-right: 100rpx;
}

.continue-go {
  margin-top: 16rpx;
  color: var(--color-primary-deep);
  font-size: 26rpx;
  font-weight: 800;
}

.games-entry {
  margin-bottom: 30rpx;
  background: linear-gradient(145deg, #e4fff8, #ffffff 55%, #eaf0ff);
  overflow: hidden;
  min-height: 180rpx;
}

.games-art {
  position: absolute;
  right: -20rpx;
  top: -20rpx;
  width: 180rpx;
  height: 180rpx;
  pointer-events: none;
}

.orb {
  position: absolute;
  border-radius: 50%;
  opacity: 0.55;
}

.orb-a {
  width: 120rpx;
  height: 120rpx;
  right: 20rpx;
  top: 20rpx;
  background: #b8f3ea;
  animation: bouncey 3.4s ease-in-out infinite;
}

.orb-b {
  width: 70rpx;
  height: 70rpx;
  right: 110rpx;
  top: 90rpx;
  background: #cdd9ff;
  animation: bouncey 2.6s ease-in-out infinite reverse;
}

.games-entry-label {
  font-size: 22rpx;
  color: var(--color-primary-deep);
  font-weight: 800;
}

.games-entry-title {
  margin-top: 10rpx;
  font-size: 38rpx;
  font-weight: 900;
}

.games-entry-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--color-muted);
  font-weight: 600;
  padding-right: 80rpx;
}

.go-pill {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  background: var(--color-sun);
  color: #5a4300;
  font-weight: 900;
  font-size: 24rpx;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  box-shadow: 0 6rpx 0 #e0ad20;
}

.pack-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.pack-card {
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
  transition: transform 0.15s ease;
}

.pack-card:active {
  transform: scale(0.98) translateY(4rpx);
}

.pack-cn {
  background: linear-gradient(145deg, #fff8e8, #ffffff 50%);
}

.pack-math {
  background: linear-gradient(145deg, #eef4ff, #ffffff 50%);
}

.pack-en {
  background: linear-gradient(145deg, #e8fff4, #ffffff 50%);
}

.pack-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 900;
  color: #fff;
  flex-shrink: 0;
  box-shadow: 0 8rpx 0 rgba(0, 0, 0, 0.08);
}

.pack-cn .pack-icon {
  background: linear-gradient(145deg, #ffb347, #ff6f61);
}

.pack-math .pack-icon {
  background: linear-gradient(145deg, #7aa7ff, #5b8cff);
}

.pack-en .pack-icon {
  background: linear-gradient(145deg, #3ecf8e, #22b8a8);
}

.pack-body {
  flex: 1;
  min-width: 0;
}

.pack-subject {
  display: inline-block;
  font-size: 22rpx;
  color: #fff;
  background: var(--color-ink);
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  margin-bottom: 10rpx;
  font-weight: 800;
}

.pack-title {
  font-size: 34rpx;
  font-weight: 900;
}

.pack-desc {
  margin-top: 8rpx;
  color: var(--color-muted);
  font-size: 24rpx;
  line-height: 1.5;
  font-weight: 600;
}

.pack-meta {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: var(--color-primary-deep);
  font-weight: 800;
}
