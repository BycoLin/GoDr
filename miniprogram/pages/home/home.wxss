.home {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
}

.deco {
  position: absolute;
  pointer-events: none;
  z-index: 0;
  opacity: 0.35;
}

.deco-cloud {
  width: 140rpx;
  height: 56rpx;
  background: #fff;
  border-radius: 999rpx;
}

.deco-cloud::before,
.deco-cloud::after {
  content: '';
  position: absolute;
  background: #fff;
  border-radius: 50%;
}

.deco-cloud::before {
  width: 60rpx;
  height: 60rpx;
  top: -28rpx;
  left: 24rpx;
}

.deco-cloud::after {
  width: 80rpx;
  height: 80rpx;
  top: -40rpx;
  right: 20rpx;
}

.deco-cloud.a {
  top: 20rpx;
  right: -20rpx;
}

.deco-cloud.b {
  top: 280rpx;
  left: -40rpx;
  transform: scale(0.7);
  opacity: 0.22;
}

.deco-star {
  top: 120rpx;
  left: 40rpx;
  width: 24rpx;
  height: 24rpx;
  background: #ffc93c;
  border-radius: 4rpx;
  transform: rotate(20deg);
  opacity: 0.4;
}

.status-row,
.subject-pills,
.grade-pills,
.scene-card,
.cta-wrap,
.more-list {
  position: relative;
  z-index: 1;
}

.status-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  background: #fff4e4;
  border: 4rpx solid #fff;
  box-shadow: 0 8rpx 0 rgba(26, 20, 48, 0.08);
  animation: pet-bounce 1.8s ease-in-out infinite;
}

.avatar-img {
  width: 100%;
  height: 100%;
  display: block;
}

@keyframes pet-bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}

.status-mid {
  flex: 1;
  min-width: 0;
}

.hello {
  font-size: 34rpx;
  font-weight: 900;
  color: #1a1430;
}

.hello-sub {
  margin-top: 4rpx;
  font-size: 26rpx;
  font-weight: 800;
  color: #e08a12;
}

.status-chips {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  align-items: flex-end;
}

.chip {
  background: #fff;
  border: 3rpx solid #ece7df;
  border-radius: 999rpx;
  padding: 8rpx 16rpx;
  font-size: 24rpx;
  font-weight: 900;
  color: #1a1430;
  box-shadow: 0 4rpx 0 rgba(26, 20, 48, 0.06);
}

.chip.fire {
  color: #ff6f61;
  border-color: #ffd0c8;
  background: #fff5f3;
}

.subject-pills {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.sp {
  flex: 1;
  text-align: center;
  min-height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: #fff;
  border: 4rpx solid #ece7df;
  font-size: 32rpx;
  font-weight: 900;
  color: #4a4458;
  box-shadow: 0 8rpx 0 rgba(26, 20, 48, 0.06);
}

.sp:active {
  transform: translateY(4rpx);
  box-shadow: 0 4rpx 0 rgba(26, 20, 48, 0.06);
}

.sp.on.cn {
  background: #22b8a8;
  border-color: #22b8a8;
  color: #fff;
  box-shadow: 0 8rpx 0 #0f8f82;
}

.sp.on.math {
  background: #5b8cff;
  border-color: #5b8cff;
  color: #fff;
  box-shadow: 0 8rpx 0 #4470e0;
}

.sp.on.en {
  background: #ff9f1c;
  border-color: #ff9f1c;
  color: #fff;
  box-shadow: 0 8rpx 0 #e07f10;
}

.grade-pills {
  display: flex;
  gap: 14rpx;
  margin-bottom: 28rpx;
}

.gp {
  min-height: 72rpx;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  border-radius: 999rpx;
  background: #fff;
  border: 3rpx solid #ece7df;
  font-size: 28rpx;
  font-weight: 800;
  color: #4a4458;
}

.gp.on {
  background: #ffc93c;
  border-color: #ffc93c;
  color: #5a4300;
  box-shadow: 0 6rpx 0 #e0ad20;
}

.scene-card {
  border-radius: 40rpx;
  padding: 36rpx 32rpx 28rpx;
  color: #fff;
  margin-bottom: 36rpx;
  text-align: center;
  position: relative;
}

.scene-card.tone-cn {
  background: #22b8a8;
  box-shadow: 0 14rpx 0 #0f8f82;
}

.scene-card.tone-math {
  background: #5b8cff;
  box-shadow: 0 14rpx 0 #4470e0;
}

.scene-card.tone-en {
  background: #ff9f1c;
  box-shadow: 0 14rpx 0 #e07f10;
}

.scene-mark {
  width: 88rpx;
  height: 88rpx;
  margin: 0 auto 16rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.28);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 900;
}

.scene-title {
  font-size: 44rpx;
  font-weight: 900;
}

.scene-desc {
  margin-top: 8rpx;
  font-size: 26rpx;
  font-weight: 700;
  opacity: 0.92;
}

.scene-bar {
  margin: 22rpx auto 10rpx;
  width: 86%;
  height: 22rpx;
  background: rgba(255, 255, 255, 0.28);
  border-radius: 999rpx;
  overflow: hidden;
}

.scene-fill {
  height: 100%;
  background: #ffc93c;
  border-radius: 999rpx;
}

.scene-pct {
  font-size: 40rpx;
  font-weight: 900;
}

.cta-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.cta-bubble {
  background: #fff;
  color: #1a1430;
  font-size: 26rpx;
  font-weight: 800;
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  border: 3rpx solid #ece7df;
  margin-bottom: 18rpx;
  box-shadow: 0 6rpx 0 rgba(26, 20, 48, 0.06);
  max-width: 90%;
  text-align: center;
}

.cta-bubble.soft {
  color: #4a4458;
}

.cta-btn {
  color: #fff;
  animation: cta-bounce 1.8s ease-in-out infinite;
}

.cta-btn.tone-cn {
  background: #22b8a8;
  box-shadow: 0 12rpx 0 #0f8f82;
}

.cta-btn.tone-math {
  background: #5b8cff;
  box-shadow: 0 12rpx 0 #4470e0;
}

.cta-btn.tone-en {
  background: #ff9f1c;
  box-shadow: 0 12rpx 0 #e07f10;
}

@keyframes cta-bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6rpx); }
}

.cta-btn:active {
  animation: none;
  transform: translateY(8rpx);
}

.cta-btn.tone-cn:active { box-shadow: 0 4rpx 0 #0f8f82; }
.cta-btn.tone-math:active { box-shadow: 0 4rpx 0 #4470e0; }
.cta-btn.tone-en:active { box-shadow: 0 4rpx 0 #e07f10; }

.cta-sub {
  margin-top: 18rpx;
  font-size: 26rpx;
  font-weight: 800;
  color: #5b8cff;
  min-height: 56rpx;
  display: flex;
  align-items: center;
}

.sec-title {
  position: relative;
  z-index: 1;
  font-size: 32rpx;
  font-weight: 900;
  color: #1a1430;
  margin-bottom: 16rpx;
}

.feature-list {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 120rpx;
  background: #fff;
  border-radius: 32rpx;
  border: 3rpx solid #ece7df;
  padding: 20rpx 22rpx;
  box-shadow: 0 10rpx 0 rgba(26, 20, 48, 0.06);
}

.feature-item.q-duel {
  background: #f3f6ff;
  border-color: #c9d6ff;
}

.feature-item.q-sprint,
.feature-item.q-flash {
  background: #fff8ef;
  border-color: #ffe0a8;
}

.feature-item.q-teal {
  background: #effffb;
  border-color: #9ee5db;
}

.feature-item.q-coral {
  background: #fff5f3;
  border-color: #ffd0c8;
}

.feature-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  background: #22b8a8;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 900;
  flex-shrink: 0;
}

.q-duel .feature-icon { background: #5b8cff; }
.q-sprint .feature-icon,
.q-flash .feature-icon { background: #ff9f1c; }
.q-teal .feature-icon { background: #22b8a8; }
.q-coral .feature-icon { background: #ff6f61; }

.feature-body {
  flex: 1;
  min-width: 0;
}

.feature-name {
  font-size: 32rpx;
  font-weight: 900;
  color: #1a1430;
}

.feature-tip {
  margin-top: 4rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #4a4458;
}

.feature-go {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #1a1430;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 900;
  flex-shrink: 0;
}

.more-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.more-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  min-height: 120rpx;
  background: #fff;
  border-radius: 32rpx;
  border: 3rpx solid #ece7df;
  padding: 20rpx 22rpx;
  box-shadow: 0 10rpx 0 rgba(26, 20, 48, 0.06);
}

.more-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 900;
  color: #fff;
  flex-shrink: 0;
}

.e-review .more-icon { background: #ff6f61; }
.e-mono .more-icon { background: #ff9f1c; }

.e-review { background: #fff5f3; border-color: #ffd0c8; }
.e-mono { background: #fff8ef; border-color: #ffe0a8; }

.more-body {
  flex: 1;
  min-width: 0;
}

.more-name {
  font-size: 32rpx;
  font-weight: 900;
  color: #1a1430;
}

.more-tip {
  margin-top: 4rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #4a4458;
}

.more-go {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #1a1430;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 900;
  flex-shrink: 0;
}
