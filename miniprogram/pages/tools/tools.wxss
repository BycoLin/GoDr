.tools {
  min-height: 100vh;
}

.head-title {
  font-size: 44rpx;
  font-weight: 900;
  color: #1a1430;
}

.head-sub {
  margin-top: 8rpx;
  margin-bottom: 28rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #4a4458;
}

.tool-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  min-height: 140rpx;
  border-radius: 36rpx;
  border: 4rpx solid #ece7df;
  padding: 24rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 12rpx 0 rgba(26, 20, 48, 0.08);
  background: #fff;
}

.tool-card.tone-blue {
  background: #f3f6ff;
  border-color: #c9d6ff;
}

.tool-card.tone-green {
  background: #effffb;
  border-color: #9ee5db;
}

.tool-card.tone-cyan {
  background: #fff8ef;
  border-color: #ffe0a8;
}

.tool-card.tone-teal {
  background: #fff5f3;
  border-color: #ffd0c8;
}

.tool-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 900;
  color: #fff;
  flex-shrink: 0;
}

.tone-blue .tool-icon { background: #5b8cff; box-shadow: 0 8rpx 0 #4470e0; }
.tone-green .tool-icon { background: #22b8a8; box-shadow: 0 8rpx 0 #0f8f82; }
.tone-cyan .tool-icon { background: #ff9f1c; box-shadow: 0 8rpx 0 #e07f10; }
.tone-teal .tool-icon { background: #ff6f61; box-shadow: 0 8rpx 0 #d4453f; }

.tool-body {
  flex: 1;
  min-width: 0;
}

.tool-name {
  font-size: 34rpx;
  font-weight: 900;
  color: #1a1430;
}

.tool-tip {
  margin-top: 6rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #4a4458;
}

.tool-go {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #1a1430;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 900;
  flex-shrink: 0;
}
