.tools {
  min-height: 100vh;
}

.hero-bar {
  background: linear-gradient(135deg, #ffe566, #ffc93c);
  border-radius: 28rpx;
  padding: 28rpx 24rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 10rpx 0 #e0ad20;
  text-align: center;
}

.stickers {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.st {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #fff;
  color: #ff6f61;
  font-size: 22rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 0 rgba(0, 0, 0, 0.08);
}

.hero-title {
  font-size: 40rpx;
  font-weight: 900;
  color: #5a4300;
}

.hero-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #7a5a10;
}

.entry {
  border-radius: 28rpx;
  padding: 40rpx 28rpx;
  margin-bottom: 18rpx;
  color: #fff;
  text-align: center;
  box-shadow: 0 10rpx 0 rgba(26, 20, 48, 0.15);
}

.entry:active {
  opacity: 0.92;
  transform: translateY(2rpx);
}

.entry-title {
  font-size: 40rpx;
  font-weight: 900;
}

.entry-desc {
  margin-top: 10rpx;
  font-size: 26rpx;
  font-weight: 700;
  opacity: 0.92;
}

.tone-blue {
  background: linear-gradient(135deg, #5ecfff, #3aa0ff);
}

.tone-green {
  background: linear-gradient(135deg, #4ad67a, #22b85a);
}

.tone-cyan {
  background: linear-gradient(135deg, #3fd0d0, #1eb0c0);
}

.tone-teal {
  background: linear-gradient(135deg, #22b8a8, #0f8f82);
}
