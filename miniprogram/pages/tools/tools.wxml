<view class="safe-pad tools">
  <view class="head-title">趣味宝箱</view>
  <view class="head-sub">打开就能练的小工具</view>

  <view
    class="tool-card {{item.tone}} pressable"
    wx:for="{{entries}}"
    wx:key="id"
    data-action="{{item.action}}"
    bindtap="onTap"
  >
    <view class="tool-icon">{{item.mark}}</view>
    <view class="tool-body">
      <view class="tool-name">{{item.title}}</view>
      <view class="tool-tip">{{item.short}}</view>
    </view>
    <view class="tool-go">开</view>
  </view>
</view>
