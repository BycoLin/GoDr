<view class="safe-pad tools">
  <view class="hero-bar">
    <view class="stickers">
      <text class="st">花</text>
      <text class="st">赞</text>
      <text class="st">笑</text>
    </view>
    <view class="hero-title">趣味宝箱</view>
    <view class="hero-desc">打开看看！拼音、看图算、数字排队都在这儿</view>
  </view>

  <view
    class="entry {{item.tone}}"
    wx:for="{{entries}}"
    wx:key="id"
    data-action="{{item.action}}"
    bindtap="onTap"
  >
    <view class="entry-title">{{item.title}}</view>
    <view class="entry-desc">{{item.desc}}</view>
  </view>
</view>
