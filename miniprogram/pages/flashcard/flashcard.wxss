.flash {
  min-height: 100vh;
}

.meta {
  font-size: 26rpx;
  font-weight: 800;
  color: #4a4458;
  margin-bottom: 18rpx;
}

.flash-card {
  min-height: 520rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 28rpx;
  background: linear-gradient(160deg, #e8fff8 0%, #ffffff 55%, #fff6df 100%);
  margin-bottom: 28rpx;
}

.face {
  width: 100%;
  text-align: center;
}

.hint {
  display: inline-block;
  font-size: 22rpx;
  font-weight: 900;
  color: #fff;
  background: #1a1430;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  margin-bottom: 28rpx;
}

.main {
  font-size: 64rpx;
  font-weight: 900;
  color: #1a1430;
  line-height: 1.3;
  word-break: break-word;
}

.sub {
  margin-top: 18rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #4a4458;
}

.lines .line {
  font-size: 36rpx;
  font-weight: 800;
  color: #1a1430;
  line-height: 1.7;
}

.actions {
  display: flex;
  gap: 16rpx;
}

.actions .btn {
  flex: 1;
}

.done-card {
  text-align: center;
  padding: 48rpx 28rpx;
  margin-bottom: 20rpx;
  background: #fff;
}

.done-title {
  font-size: 40rpx;
  font-weight: 900;
  color: #1a1430;
}

.done-score {
  margin-top: 16rpx;
  font-size: 30rpx;
  font-weight: 800;
  color: #22b8a8;
}

.done-desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #4a4458;
}
