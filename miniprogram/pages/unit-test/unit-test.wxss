.unit-test {
  min-height: 100vh;
}

.hero {
  background: #22b8a8;
  color: #fff;
  border-radius: 36rpx;
  padding: 36rpx 32rpx 32rpx;
  box-shadow: 0 14rpx 0 #0f8f82;
  margin-bottom: 24rpx;
}

.hero-badge {
  display: inline-block;
  font-size: 22rpx;
  font-weight: 900;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.28);
  margin-bottom: 12rpx;
}

.hero-title {
  font-size: 44rpx;
  font-weight: 900;
}

.hero-desc {
  margin-top: 10rpx;
  font-size: 26rpx;
  font-weight: 700;
  opacity: 0.92;
  line-height: 1.45;
}

.compare {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.compare-item {
  flex: 1;
  background: #effffb;
  border: 3rpx solid #9ee5db;
  border-radius: 24rpx;
  padding: 18rpx 16rpx;
}

.compare-item.muted {
  background: #fff;
  border-color: #ece7df;
  opacity: 0.88;
}

.compare-tag {
  font-size: 22rpx;
  font-weight: 900;
  color: #0f8f82;
}

.compare-item.muted .compare-tag {
  color: #9a93a8;
}

.compare-text {
  margin-top: 6rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #4a4458;
  line-height: 1.4;
}

.unit-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.unit-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #fff;
  border: 3rpx solid #ece7df;
  border-radius: 28rpx;
  padding: 22rpx 20rpx;
  box-shadow: 0 8rpx 0 rgba(26, 20, 48, 0.06);
  min-height: 132rpx;
  box-sizing: border-box;
}

.unit-idx {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #22b8a8;
  color: #fff;
  font-size: 32rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 6rpx 0 #0f8f82;
}

.unit-body {
  flex: 1;
  min-width: 0;
}

.unit-title {
  font-size: 30rpx;
  font-weight: 900;
  color: #1a1430;
}

.unit-tip {
  margin-top: 4rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #4a4458;
}

.unit-score {
  margin-top: 6rpx;
  font-size: 22rpx;
  font-weight: 800;
  color: #0f8f82;
}

.unit-go {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #ffc93c;
  color: #5a4300;
  font-size: 28rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 0 #e0ad20;
}

.empty {
  text-align: center;
  padding: 80rpx 32rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #9a93a8;
}
