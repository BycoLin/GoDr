.play {
  min-height: 100vh;
}

.top {
  margin-bottom: 22rpx;
  padding: 22rpx;
  border-radius: 32rpx;
  background: #fff;
  box-shadow: 0 10rpx 0 rgba(43, 37, 64, 0.07);
  border: 4rpx solid #fff;
}

.hud {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.hud-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.combo {
  font-size: 24rpx;
  font-weight: 900;
  color: #fff;
  background: linear-gradient(135deg, #ff9a74, #ff6f61);
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  box-shadow: 0 6rpx 0 #e25549;
}

.combo.pulse {
  animation: comboPop 0.45s ease;
}

@keyframes comboPop {
  0% {
    transform: scale(0.85) rotate(-4deg);
  }
  50% {
    transform: scale(1.14) rotate(4deg);
  }
  100% {
    transform: scale(1) rotate(0);
  }
}

.timer {
  font-size: 28rpx;
  font-weight: 900;
  color: var(--color-sky);
  font-variant-numeric: tabular-nums;
  background: var(--color-sky-soft);
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}

.timer.urgent {
  color: #fff;
  background: var(--color-danger);
  animation: comboPop 0.6s ease infinite;
}

.poem-tag {
  font-size: 26rpx;
  color: var(--color-muted);
  flex: 1;
  font-weight: 700;
}

.progress-text {
  margin-top: 12rpx;
  font-size: 28rpx;
  font-weight: 900;
}

.bar {
  margin-top: 14rpx;
  height: 18rpx;
  background: #eef2f8;
  border-radius: 999rpx;
  overflow: hidden;
  border: 3rpx solid #f7f9fc;
}

.bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #ffc93c, #22b8a8 60%, #5b8cff);
  transition: width 0.25s ease;
}

.q-card {
  animation: riseIn 0.35s ease;
  padding: 36rpx 28rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f7fffc 100%);
}

@keyframes riseIn {
  from {
    opacity: 0;
    transform: translateY(18rpx) scale(0.98);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.q-type {
  display: inline-block;
  font-size: 22rpx;
  color: #fff;
  background: var(--color-ink);
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  margin-bottom: 20rpx;
  font-weight: 900;
}

.q-prompt {
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.45;
  margin-bottom: 28rpx;
}

.options {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.option {
  padding: 28rpx 24rpx;
  border-radius: 24rpx;
  background: #fff;
  border: 4rpx solid #e8eef8;
  font-size: 32rpx;
  line-height: 1.4;
  font-weight: 800;
  box-shadow: 0 8rpx 0 rgba(43, 37, 64, 0.05);
}

.option:active {
  border-color: var(--color-primary);
  background: var(--color-primary-soft);
  transform: translateY(4rpx);
  box-shadow: 0 4rpx 0 rgba(17, 153, 138, 0.15);
}

.option.correct {
  border-color: var(--color-ok);
  background: #d8fce9;
  box-shadow: 0 8rpx 0 rgba(62, 207, 142, 0.25);
}

.option.dim {
  opacity: 0.35;
}

.match-board {
  display: flex;
  gap: 14rpx;
}

.match-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.match-item {
  padding: 22rpx 12rpx;
  border-radius: 20rpx;
  background: #fff;
  font-size: 26rpx;
  line-height: 1.35;
  border: 4rpx solid #e8eef8;
  text-align: center;
  font-weight: 700;
  box-shadow: 0 6rpx 0 rgba(43, 37, 64, 0.05);
}

.match-item.selected {
  border-color: var(--color-accent);
  background: var(--color-accent-soft);
}

.match-item.done {
  opacity: 0.4;
  background: var(--color-primary-soft);
}

.match-actions {
  margin-top: 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.match-actions .btn-primary {
  flex: 1;
}

.options-chars {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
}

.option-char {
  text-align: center;
  font-size: 42rpx;
  font-weight: 900;
  padding: 28rpx 0;
}

.order-picked {
  margin-bottom: 24rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: var(--color-sun-soft);
  border: 3rpx dashed #ffc93c;
}

.order-picked-label {
  font-size: 22rpx;
  color: #9a7400;
  margin-bottom: 8rpx;
  font-weight: 900;
}

.order-picked-line {
  font-size: 28rpx;
  line-height: 1.5;
  margin-top: 4rpx;
  font-weight: 700;
}

.done-opt {
  opacity: 0.35;
  text-decoration: line-through;
}

.feedback {
  margin-top: 28rpx;
  text-align: center;
  font-size: 36rpx;
  font-weight: 900;
  animation: softPulse 0.5s ease;
}

.feedback.ok {
  color: var(--color-ok);
}

.feedback.bad {
  color: var(--color-danger);
}

@keyframes softPulse {
  from {
    transform: scale(0.85);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}
