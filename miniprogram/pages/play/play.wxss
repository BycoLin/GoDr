.play {
  min-height: 100vh;
}

.top {
  margin-bottom: 24rpx;
  padding: 20rpx 22rpx;
  border-radius: var(--radius);
  background: rgba(255, 255, 255, 0.78);
  box-shadow: var(--shadow);
}

.hud {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.hud-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.combo {
  font-size: 24rpx;
  font-weight: 800;
  color: #fff;
  background: linear-gradient(135deg, #ff9a74, #ff7b54);
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
}

.combo.pulse {
  animation: comboPop 0.45s ease;
}

@keyframes comboPop {
  0% {
    transform: scale(0.85);
  }
  50% {
    transform: scale(1.12);
  }
  100% {
    transform: scale(1);
  }
}

.timer {
  font-size: 26rpx;
  font-weight: 800;
  color: var(--color-sky);
  font-variant-numeric: tabular-nums;
}

.timer.urgent {
  color: var(--color-danger);
}

.poem-tag {
  font-size: 26rpx;
  color: var(--color-muted);
  flex: 1;
}

.progress-text {
  margin-top: 12rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.bar {
  margin-top: 14rpx;
  height: 16rpx;
  background: #e4eef7;
  border-radius: 999rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #4ba3ff, #1fa8a0);
  transition: width 0.25s ease;
}

.q-card {
  animation: riseIn 0.35s ease;
  padding: 36rpx 28rpx;
}

@keyframes riseIn {
  from {
    opacity: 0;
    transform: translateY(16rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.q-type {
  display: inline-block;
  font-size: 22rpx;
  color: var(--color-primary-deep);
  background: var(--color-primary-soft);
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  margin-bottom: 20rpx;
  font-weight: 700;
}

.q-prompt {
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.5;
  margin-bottom: 28rpx;
}

.options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option {
  padding: 28rpx 24rpx;
  border-radius: 22rpx;
  background: #f5faff;
  border: 2rpx solid #e4eef7;
  font-size: 30rpx;
  line-height: 1.4;
}

.option:active {
  border-color: var(--color-primary);
  background: var(--color-primary-soft);
}

.option.correct {
  border-color: var(--color-ok);
  background: #dcfce7;
}

.option.dim {
  opacity: 0.4;
}

.match-board {
  display: flex;
  gap: 16rpx;
}

.match-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.match-item {
  padding: 24rpx 14rpx;
  border-radius: 18rpx;
  background: #f5faff;
  font-size: 26rpx;
  line-height: 1.35;
  border: 2rpx solid #e4eef7;
  text-align: center;
}

.match-item.selected {
  border-color: var(--color-accent);
  background: var(--color-accent-soft);
}

.match-item.done {
  opacity: 0.45;
  background: var(--color-primary-soft);
}

.match-actions {
  margin-top: 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.match-actions .btn-primary {
  flex: 1;
}

.options-chars {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.option-char {
  text-align: center;
  font-size: 40rpx;
  font-weight: 800;
  padding: 28rpx 0;
}

.order-picked {
  margin-bottom: 24rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  background: var(--color-sky-soft);
}

.order-picked-label {
  font-size: 22rpx;
  color: var(--color-sky);
  margin-bottom: 8rpx;
  font-weight: 700;
}

.order-picked-line {
  font-size: 28rpx;
  line-height: 1.5;
  margin-top: 4rpx;
}

.done-opt {
  opacity: 0.35;
  text-decoration: line-through;
}

.feedback {
  margin-top: 28rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: 800;
  animation: softPulse 0.5s ease;
}

.feedback.ok {
  color: var(--color-ok);
}

.feedback.bad {
  color: var(--color-danger);
}

@keyframes softPulse {
  from {
    transform: scale(0.9);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}
