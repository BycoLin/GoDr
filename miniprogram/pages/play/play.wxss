.play {
  min-height: 100vh;
}

.top {
  margin-bottom: 22rpx;
  padding: 22rpx;
  border-radius: 32rpx;
  background: #fff;
  box-shadow: 0 10rpx 0 rgba(43, 37, 64, 0.07);
  border: 4rpx solid #fff;
}

.hud {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.hud-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.combo {
  font-size: 24rpx;
  font-weight: 900;
  color: #fff;
  background: linear-gradient(135deg, #ff9a74, #ff6f61);
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  box-shadow: 0 6rpx 0 #e25549;
}

.combo.pulse {
  animation: comboPop 0.45s ease;
}

@keyframes comboPop {
  0% {
    transform: scale(0.85) rotate(-4deg);
  }
  50% {
    transform: scale(1.14) rotate(4deg);
  }
  100% {
    transform: scale(1) rotate(0);
  }
}

.timer {
  font-size: 28rpx;
  font-weight: 900;
  color: var(--color-sky);
  font-variant-numeric: tabular-nums;
  background: var(--color-sky-soft);
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}

.timer.urgent {
  color: #fff;
  background: var(--color-danger);
  animation: comboPop 0.6s ease infinite;
}

.duel-board {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-top: 16rpx;
  padding: 14rpx 18rpx;
  border-radius: 24rpx;
  background: #f3f7ff;
}

.duel-side {
  flex: 1;
  text-align: center;
  padding: 10rpx;
  border-radius: 18rpx;
  background: #fff;
}

.duel-side.lead {
  background: #e8fff8;
  box-shadow: 0 0 0 4rpx #22b8a8;
}

.duel-side.rival.lead {
  background: #fff0f0;
  box-shadow: 0 0 0 4rpx #ff6f61;
}

.duel-name {
  font-size: 22rpx;
  font-weight: 800;
  color: #4a4458;
}

.duel-score {
  margin-top: 4rpx;
  font-size: 44rpx;
  font-weight: 900;
  color: #1a1430;
  font-variant-numeric: tabular-nums;
}

.duel-vs {
  font-size: 24rpx;
  font-weight: 900;
  color: #9a93a8;
}

.poem-tag {
  font-size: 26rpx;
  color: var(--color-muted);
  flex: 1;
  font-weight: 700;
}

.progress-text {
  margin-top: 12rpx;
  font-size: 28rpx;
  font-weight: 900;
}

.bar {
  margin-top: 14rpx;
  height: 18rpx;
  background: #eef2f8;
  border-radius: 999rpx;
  overflow: hidden;
  border: 3rpx solid #f7f9fc;
}

.bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #ffc93c, #22b8a8 60%, #5b8cff);
  transition: width 0.25s ease;
}

.q-card {
  animation: riseIn 0.35s ease;
  padding: 36rpx 28rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f7fffc 100%);
}

@keyframes riseIn {
  from {
    opacity: 0;
    transform: translateY(18rpx) scale(0.98);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.q-type {
  display: inline-block;
  font-size: 22rpx;
  color: #fff;
  background: var(--color-ink);
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  margin-bottom: 20rpx;
  font-weight: 900;
}

.q-prompt {
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.45;
  margin-bottom: 32rpx;
}

.q-prompt-center {
  text-align: center;
  letter-spacing: 2rpx;
}

.options {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.option {
  min-height: 120rpx;
  padding: 32rpx 28rpx;
  border-radius: 28rpx;
  background: #fff;
  border: 4rpx solid #e8eef8;
  font-size: 34rpx;
  line-height: 1.4;
  font-weight: 800;
  box-shadow: 0 10rpx 0 rgba(43, 37, 64, 0.06);
  display: flex;
  align-items: center;
}

.option:active {
  border-color: var(--color-primary);
  background: var(--color-primary-soft);
  transform: translateY(6rpx);
  box-shadow: 0 4rpx 0 rgba(17, 153, 138, 0.15);
}

.option.correct {
  border-color: var(--color-ok);
  background: #d8fce9;
  box-shadow: 0 8rpx 0 rgba(62, 207, 142, 0.25);
}

.option.dim {
  opacity: 0.35;
}

.match-board {
  display: flex;
  gap: 14rpx;
}

.match-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.match-item {
  padding: 22rpx 12rpx;
  border-radius: 20rpx;
  background: #fff;
  font-size: 26rpx;
  line-height: 1.35;
  border: 4rpx solid #e8eef8;
  text-align: center;
  font-weight: 700;
  box-shadow: 0 6rpx 0 rgba(43, 37, 64, 0.05);
}

.match-item.selected {
  border-color: var(--color-accent);
  background: var(--color-accent-soft);
}

.match-item.done {
  opacity: 0.4;
  background: var(--color-primary-soft);
}

.match-actions {
  margin-top: 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.match-actions .btn-primary {
  flex: 1;
}

.options-chars {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
}

.options-chars .option {
  justify-content: center;
}

.option-char {
  text-align: center;
  font-size: 42rpx;
  font-weight: 900;
  padding: 28rpx 0;
}

.order-picked {
  margin-bottom: 24rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: var(--color-sun-soft);
  border: 3rpx dashed #ffc93c;
}

.order-picked-label {
  font-size: 22rpx;
  color: #9a7400;
  margin-bottom: 8rpx;
  font-weight: 900;
}

.order-picked-line {
  font-size: 28rpx;
  line-height: 1.5;
  margin-top: 4rpx;
  font-weight: 700;
}

.done-opt {
  opacity: 0.35;
  text-decoration: line-through;
}

.play {
  min-height: 100vh;
  box-sizing: border-box;
}

.play--feedback {
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
}

.feedback-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 200;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(247, 255, 252, 0) 0%, rgba(247, 255, 252, 0.92) 28%, #f7fffc 100%);
  pointer-events: none;
}

.feedback-inner {
  text-align: center;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.35;
  padding: 22rpx 28rpx;
  border-radius: 24rpx;
  background: #fff;
  box-shadow: 0 8rpx 32rpx rgba(43, 37, 64, 0.12);
  animation: softPulse 0.5s ease;
}

.feedback-bar.ok .feedback-inner {
  color: var(--color-ok);
  border: 4rpx solid rgba(34, 184, 168, 0.35);
}

.feedback-bar.bad .feedback-inner {
  color: var(--color-danger);
  border: 4rpx solid rgba(255, 111, 97, 0.35);
}

@keyframes softPulse {
  from {
    transform: scale(0.85);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}

.visual-card {
  background: linear-gradient(180deg, #e8fff8, #fff);
}

.seq-row {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  flex-wrap: wrap;
  margin: 12rpx 0 20rpx;
}

.seq-slot {
  width: 120rpx;
  height: 120rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  font-weight: 900;
  background: #fff;
  border: 4rpx solid #d7dee8;
}

.seq-slot.show {
  border-color: #22b8a8;
  color: #0f8f82;
  background: #e8fff8;
}

.seq-slot.blank {
  color: #9a93a8;
}

.seq-slot.focus {
  border-color: #ff9f1c;
  box-shadow: 0 0 0 4rpx rgba(255, 159, 28, 0.25);
}

.visual-desc {
  text-align: center;
  font-size: 26rpx;
  color: #4a4458;
  margin-bottom: 16rpx;
}

.visual-icons {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  justify-content: center;
  min-height: 120rpx;
  align-content: center;
}

.visual-icon {
  font-size: 48rpx;
  line-height: 1;
  position: relative;
}

.visual-icon.gone {
  opacity: 0.35;
}

.visual-icon.gone::after {
  content: '/';
  position: absolute;
  left: 50%;
  top: 40%;
  transform: translate(-50%, -50%) rotate(-28deg);
  font-size: 52rpx;
  color: #1a1430;
  font-weight: 900;
}

.visual-add-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  flex-wrap: wrap;
  margin-bottom: 8rpx;
}

.visual-equation {
  margin: 20rpx 0 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.visual-num {
  min-width: 68rpx;
  height: 68rpx;
  border-radius: 14rpx;
  background: #f3f4f8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 900;
}

.visual-num.visual-ans {
  background: #22b8a8;
  color: #fff;
  min-width: 84rpx;
}

.visual-op {
  font-size: 36rpx;
  font-weight: 900;
  color: #1a1430;
}

.make-ten-groups {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.make-ten-tag {
  min-width: 64rpx;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  background: #22b8a8;
  color: #fff;
  font-size: 32rpx;
  font-weight: 900;
  text-align: center;
}

.make-ten-tag--b {
  background: #ff9f43;
}

.ten-frame {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 8rpx;
  padding: 12rpx;
  border: 4rpx solid #22b8a8;
  border-radius: 16rpx;
  background: #fff;
}

.ten-cell {
  aspect-ratio: 1;
  border: 2rpx dashed #c8ece8;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #22b8a8;
}

.ten-cell.on {
  background: #e8fff8;
  border-style: solid;
  border-color: #22b8a8;
}

.ten-cell.hi {
  background: #fff3e0;
  border-color: #ff9f43;
  color: #ff9f43;
}

.ten-frame-label {
  text-align: center;
  font-size: 22rpx;
  font-weight: 700;
  color: #6b7280;
  margin: 8rpx 0;
}

.ten-outside {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  flex-wrap: wrap;
  margin-bottom: 12rpx;
}

.ten-outside-dot {
  font-size: 32rpx;
  color: #ff9f43;
}

.ten-outside-tip {
  font-size: 24rpx;
  font-weight: 800;
  color: #ff9f43;
}

.numberline-wrap {
  position: relative;
  height: 160rpx;
  margin: 24rpx 16rpx 32rpx;
}

.numberline-bar {
  position: absolute;
  left: 0;
  right: 0;
  top: 88rpx;
  height: 8rpx;
  background: linear-gradient(90deg, #22b8a8, #4dabf7);
  border-radius: 999rpx;
}

.numberline-tick {
  position: absolute;
  top: 72rpx;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.numberline-tick-mark {
  width: 4rpx;
  height: 16rpx;
  background: #94a3b8;
  border-radius: 2rpx;
}

.numberline-tick-num {
  margin-top: 8rpx;
  font-size: 20rpx;
  font-weight: 700;
  color: #64748b;
}

.numberline-marker {
  position: absolute;
  top: 0;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.numberline-marker.left .numberline-bubble {
  background: #22b8a8;
}

.numberline-marker.right .numberline-bubble {
  background: #4dabf7;
}

.numberline-bubble {
  min-width: 56rpx;
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
  color: #fff;
  font-size: 28rpx;
  font-weight: 900;
  text-align: center;
}

.numberline-pin {
  width: 0;
  height: 0;
  border-left: 10rpx solid transparent;
  border-right: 10rpx solid transparent;
  border-top: 12rpx solid #64748b;
  margin-top: 4rpx;
}

.compare-pick {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  margin-top: 8rpx;
}

.compare-num {
  font-size: 40rpx;
  font-weight: 900;
  min-width: 64rpx;
  text-align: center;
}

.compare-num--left {
  color: #22b8a8;
}

.compare-num--right {
  color: #4dabf7;
}

.compare-symbol-row {
  display: flex;
  gap: 12rpx;
}

.compare-symbol-btn {
  width: 88rpx;
  height: 88rpx;
  border-radius: 16rpx;
  background: #fff;
  border: 4rpx solid #e2e8f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 900;
  color: #1a1430;
  box-shadow: 0 6rpx 0 #cbd5e1;
}

.compare-symbol-btn:active {
  transform: translateY(4rpx);
  box-shadow: 0 2rpx 0 #cbd5e1;
}

/* 拼图工坊 */
.puzzle-read {
  text-align: center;
  font-size: 32rpx;
  font-weight: 900;
  color: #0f8f82;
  margin: 8rpx 0 20rpx;
}

.puzzle-pieces {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 14rpx;
  margin-bottom: 12rpx;
}

.puzzle-piece {
  position: relative;
  min-width: 120rpx;
  padding: 22rpx 20rpx;
  border-radius: 16rpx;
  background: #b8e6b0;
  border: 4rpx solid #6fbf63;
  box-shadow: 0 8rpx 0 #4a9a40;
}

.puzzle-notch {
  position: absolute;
  width: 22rpx;
  height: 22rpx;
  background: #e8fff8;
  border: 3rpx solid #6fbf63;
  border-radius: 50%;
}

.puzzle-notch--tl {
  top: -12rpx;
  left: -12rpx;
}

.puzzle-notch--br {
  bottom: -12rpx;
  right: -12rpx;
}

.puzzle-text {
  font-size: 40rpx;
  font-weight: 900;
  color: #1a5018;
  letter-spacing: 2rpx;
}

.puzzle-tip {
  text-align: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #4a4458;
  margin-bottom: 8rpx;
}

.puzzle-ans {
  min-width: 280rpx;
  font-size: 40rpx;
}

/* 数位认识：高亮指定数字 */
.place-value-num {
  display: flex;
  justify-content: center;
  align-items: baseline;
  margin: 16rpx 0 8rpx;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  background: #f5f7fb;
  border: 2rpx solid #e2e8f0;
}

.place-value-char {
  font-size: 56rpx;
  font-weight: 700;
  line-height: 1.2;
  color: #334155;
  letter-spacing: 2rpx;
}

.place-value-char--hi {
  color: #e11d48;
  background: #ffe4e6;
  border-radius: 12rpx;
  padding: 0 8rpx;
  box-shadow: 0 0 0 3rpx rgba(225, 29, 72, 0.15);
}

/* 数字赛车场 */
.race-card {
  background: linear-gradient(180deg, #e8fff8 0%, #fff9e8 100%);
}

.race-track {
  position: relative;
  margin: 8rpx 0 12rpx;
  padding: 52rpx 20rpx 20rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #5c6370 0%, #4a5058 100%);
  border: 4rpx solid #3d4248;
  box-shadow: inset 0 6rpx 0 rgba(255, 255, 255, 0.08);
  overflow: hidden;
}

.race-finish {
  position: absolute;
  left: 50%;
  top: 12rpx;
  transform: translateX(-50%);
  font-size: 40rpx;
  line-height: 1;
  z-index: 2;
}

.race-columns {
  display: flex;
  align-items: stretch;
  gap: 0;
  min-height: 280rpx;
}

.race-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  padding: 0 8rpx;
}

.race-column--left {
  border-right: 4rpx dashed rgba(255, 255, 255, 0.4);
}

.race-column-label {
  font-size: 24rpx;
  font-weight: 900;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 12rpx;
  background: rgba(0, 0, 0, 0.2);
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
}

.race-column-track {
  flex: 1;
  width: 100%;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  align-items: center;
  min-height: 160rpx;
  position: relative;
}

.race-column-track::before {
  content: '';
  position: absolute;
  left: 50%;
  top: 0;
  bottom: 40rpx;
  border-left: 4rpx dashed rgba(255, 255, 255, 0.25);
  transform: translateX(-50%);
}

.race-car {
  flex-shrink: 0;
  width: 72rpx;
  height: 52rpx;
  border-radius: 14rpx 18rpx 10rpx 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 0 rgba(0, 0, 0, 0.25);
  position: relative;
  z-index: 1;
}

.race-car--red {
  background: linear-gradient(180deg, #ff6b6b, #e03131);
}

.race-car--blue {
  background: linear-gradient(180deg, #74c0fc, #339af0);
}

.race-car-icon {
  font-size: 36rpx;
  line-height: 1;
}

.race-num {
  margin-top: 12rpx;
  font-size: 30rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
  text-align: center;
  word-break: break-all;
  line-height: 1.3;
  padding: 0 4rpx;
}

.race-num--red {
  color: #ffc9c9;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.35);
}

.race-num--blue {
  color: #a5d8ff;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.35);
}

.race-formula {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
  padding: 16rpx 12rpx;
  border-radius: 18rpx;
  background: #fff;
  border: 3rpx solid #e8eef8;
}

.race-formula-num {
  font-size: 28rpx;
  font-weight: 900;
  max-width: 38%;
  word-break: break-all;
  text-align: center;
  line-height: 1.25;
}

.race-formula-num.race-num--red {
  color: #e03131;
  text-shadow: none;
}

.race-formula-num.race-num--blue {
  color: #339af0;
  text-shadow: none;
}

.race-formula-gap {
  font-size: 36rpx;
  font-weight: 900;
  color: #94a3b8;
  flex-shrink: 0;
}

.race-pick-label {
  text-align: center;
  font-size: 26rpx;
  font-weight: 800;
  color: #4a4458;
  margin-bottom: 16rpx;
}

.race-pick {
  display: flex;
  justify-content: center;
  gap: 20rpx;
}

.race-pick-btn {
  min-width: 120rpx;
  padding: 28rpx 32rpx;
  border-radius: 22rpx;
  background: #fff;
  border: 4rpx solid #ffc93c;
  font-size: 48rpx;
  font-weight: 900;
  color: #1a1430;
  text-align: center;
  box-shadow: 0 8rpx 0 #e6a800;
}

.race-pick-btn.correct {
  border-color: #22b8a8;
  background: #effffb;
  color: #0f8f82;
  box-shadow: 0 8rpx 0 #1a9e8f;
}

.race-pick-btn.dim {
  opacity: 0.45;
}

.race-pick-btn:active {
  transform: translateY(4rpx);
  box-shadow: 0 4rpx 0 #e6a800;
}

/* 量角器 */
.angle-measure-card .q-prompt {
  margin-bottom: 16rpx;
}

.angle-measure-diagram {
  flex-shrink: 0;
  min-height: 240rpx;
  margin-bottom: 8rpx;
}

.protractor-stage {
  display: flex;
  justify-content: center;
  align-items: flex-end;
  min-height: 210rpx;
  margin: 0;
  padding-top: 12rpx;
  overflow: hidden;
}

.protractor-arc {
  position: relative;
  width: 340rpx;
  height: 180rpx;
  border: 5rpx solid #5b8cff;
  border-bottom: none;
  border-radius: 170rpx 170rpx 0 0;
  background: linear-gradient(180deg, #eef4ff 0%, #fff 100%);
  overflow: hidden;
  flex-shrink: 0;
}

.protractor-tick {
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 0;
  height: 0;
  transform-origin: center bottom;
}

.tick-mark {
  position: absolute;
  left: -2rpx;
  bottom: 0;
  width: 4rpx;
  height: 14rpx;
  background: #94a3b8;
  transform: translateY(-148rpx);
}

.protractor-tick.major .tick-mark {
  height: 20rpx;
  width: 5rpx;
  background: #5b8cff;
}

.tick-label {
  position: absolute;
  left: 50%;
  bottom: 0;
  transform: translate(-50%, -168rpx);
  font-size: 18rpx;
  font-weight: 800;
  color: #475569;
  white-space: nowrap;
}

.protractor-arm-base {
  position: absolute;
  left: 50%;
  bottom: 8rpx;
  width: 155rpx;
  height: 8rpx;
  background: #1a1430;
  transform-origin: left center;
  border-radius: 4rpx;
  z-index: 1;
}

.protractor-arm {
  position: absolute;
  left: 50%;
  bottom: 8rpx;
  width: 148rpx;
  height: 8rpx;
  background: #22b8a8;
  transform-origin: left center;
  border-radius: 4rpx;
  z-index: 2;
  box-shadow: 0 0 0 3rpx rgba(34, 184, 168, 0.25);
}

.protractor-center {
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 20rpx;
  height: 20rpx;
  margin-left: -10rpx;
  margin-bottom: -2rpx;
  background: #ff6f61;
  border: 4rpx solid #fff;
  border-radius: 50%;
  z-index: 3;
  box-shadow: 0 4rpx 8rpx rgba(255, 111, 97, 0.35);
}

.angle-read-tip {
  text-align: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #4a4458;
  margin: 12rpx 0 0;
}

.angle-pick {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 14rpx;
}

.angle-pick--grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 20rpx;
  padding-top: 24rpx;
  border-top: 2rpx dashed #dce4ef;
}

.angle-pick-btn {
  min-width: 0;
  width: 100%;
  padding: 24rpx 16rpx;
  border-radius: 20rpx;
  background: #fff;
  border: 4rpx solid #e2e8f0;
  font-size: 34rpx;
  font-weight: 900;
  color: #1a1430;
  text-align: center;
  box-shadow: 0 6rpx 0 #cbd5e1;
  box-sizing: border-box;
}

.angle-pick-btn.correct {
  border-color: #22b8a8;
  background: #effffb;
  color: #0f8f82;
}

.angle-pick-btn.dim {
  opacity: 0.45;
}

.angle-pick-btn:active {
  transform: translateY(4rpx);
  box-shadow: 0 2rpx 0 #cbd5e1;
}

/* 几何示意图 */
.geo-diagram {
  margin: 8rpx 0 16rpx;
}

.geo-line-stage {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 120rpx;
  padding: 16rpx 0;
}

.geo-line-bar {
  position: relative;
  width: 420rpx;
  height: 8rpx;
  background: #2d3748;
  border-radius: 4rpx;
}

.geo-line-bar--segment {
  width: 320rpx;
}

.geo-line-bar--ray {
  width: 360rpx;
  margin-left: 40rpx;
}

.geo-dot {
  position: absolute;
  top: 50%;
  width: 22rpx;
  height: 22rpx;
  background: #ff6b6b;
  border: 4rpx solid #fff;
  border-radius: 50%;
  box-shadow: 0 0 0 3rpx #ff6b6b;
  transform: translate(-50%, -50%);
}

.geo-dot--a {
  left: 0;
}

.geo-dot--b {
  right: 0;
  transform: translate(50%, -50%);
}

.geo-arrow {
  position: absolute;
  top: 50%;
  width: 0;
  height: 0;
  transform: translateY(-50%);
}

.geo-arrow--right {
  right: -4rpx;
  border-top: 14rpx solid transparent;
  border-bottom: 14rpx solid transparent;
  border-left: 22rpx solid #2d3748;
}

.geo-arrow--left {
  left: -4rpx;
  border-top: 14rpx solid transparent;
  border-bottom: 14rpx solid transparent;
  border-right: 22rpx solid #2d3748;
}

.geo-parallel-stage {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 48rpx;
  min-height: 180rpx;
  padding: 20rpx 0;
}

.geo-parallel-line {
  width: 360rpx;
  height: 8rpx;
  background: #2d3748;
  border-radius: 4rpx;
}

.geo-scene-hint {
  position: absolute;
  right: 24rpx;
  bottom: 8rpx;
  font-size: 22rpx;
  font-weight: 800;
  color: #64748b;
  background: rgba(255, 255, 255, 0.88);
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
}

.geo-scene-hint--corner {
  left: 50%;
  right: auto;
  bottom: 12rpx;
  transform: translateX(-50%);
}

/* 垂直·拐角（课桌 / 邻边） */
.geo-corner-stage {
  position: relative;
  width: 340rpx;
  height: 240rpx;
  margin: 0 auto;
}

.geo-desk-surface {
  position: absolute;
  left: 48rpx;
  top: 24rpx;
  width: 250rpx;
  height: 168rpx;
  background: linear-gradient(145deg, #e8d5b5 0%, #d4bc96 100%);
  border: 4rpx solid #b8956a;
  border-radius: 12rpx 12rpx 4rpx 4rpx;
  box-shadow: inset 0 -8rpx 0 rgba(0, 0, 0, 0.06);
}

.geo-corner-v {
  position: absolute;
  left: 48rpx;
  bottom: 36rpx;
  width: 10rpx;
  height: 188rpx;
  background: #2d3748;
  border-radius: 4rpx;
  z-index: 2;
}

.geo-corner-h {
  position: absolute;
  left: 48rpx;
  bottom: 36rpx;
  width: 268rpx;
  height: 10rpx;
  background: #2d3748;
  border-radius: 4rpx;
  z-index: 2;
}

.geo-corner-mark {
  position: absolute;
  left: 58rpx;
  bottom: 46rpx;
  width: 32rpx;
  height: 32rpx;
  border-right: 5rpx solid #22b8a8;
  border-top: 5rpx solid #22b8a8;
  z-index: 3;
}

/* 垂直·十字路口 */
.geo-cross-stage {
  position: relative;
  width: 300rpx;
  height: 260rpx;
  margin: 0 auto;
}

.geo-cross-h {
  position: absolute;
  top: 50%;
  left: 0;
  width: 100%;
  height: 10rpx;
  background: #64748b;
  border-radius: 4rpx;
  transform: translateY(-50%);
}

.geo-cross-v {
  position: absolute;
  left: 50%;
  top: 0;
  width: 10rpx;
  height: 100%;
  background: #64748b;
  border-radius: 4rpx;
  transform: translateX(-50%);
}

.geo-cross-mark {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 32rpx;
  height: 32rpx;
  border-right: 5rpx solid #22b8a8;
  border-bottom: 5rpx solid #22b8a8;
  transform: translate(calc(-50% + 10rpx), calc(-50% - 10rpx));
}

/* 垂直·旗杆与地面 */
.geo-flag-stage {
  position: relative;
  width: 300rpx;
  height: 240rpx;
  margin: 0 auto;
}

.geo-flag-ground {
  position: absolute;
  left: 0;
  bottom: 48rpx;
  width: 100%;
  height: 10rpx;
  background: #2d3748;
  border-radius: 4rpx;
}

.geo-flag-pole {
  position: absolute;
  left: 50%;
  bottom: 48rpx;
  width: 10rpx;
  height: 170rpx;
  background: #ef4444;
  border-radius: 4rpx;
  transform: translateX(-50%);
}

.geo-flag-mark {
  position: absolute;
  left: 50%;
  bottom: 58rpx;
  width: 32rpx;
  height: 32rpx;
  border-right: 5rpx solid #22b8a8;
  border-top: 5rpx solid #22b8a8;
  transform: translateX(2rpx);
}

.geo-angle-stage {
  position: relative;
  width: 320rpx;
  height: 180rpx;
  margin: 0 auto;
}

.geo-angle-base {
  position: absolute;
  left: 24rpx;
  bottom: 0;
  width: 260rpx;
  height: 8rpx;
  background: #2d3748;
  border-radius: 4rpx;
}

.geo-angle-arm {
  position: absolute;
  left: 24rpx;
  bottom: 0;
  width: 200rpx;
  height: 8rpx;
  background: #22b8a8;
  border-radius: 4rpx;
  transform-origin: left center;
}

.geo-angle-label {
  position: absolute;
  left: 80rpx;
  bottom: 24rpx;
  font-size: 32rpx;
  font-weight: 900;
  color: #0f8f82;
}

