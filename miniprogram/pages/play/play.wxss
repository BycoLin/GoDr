.play {
  min-height: 100vh;
}

.top {
  margin-bottom: 22rpx;
  padding: 22rpx;
  border-radius: 32rpx;
  background: #fff;
  box-shadow: 0 10rpx 0 rgba(43, 37, 64, 0.07);
  border: 4rpx solid #fff;
}

.hud {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.hud-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.combo {
  font-size: 24rpx;
  font-weight: 900;
  color: #fff;
  background: linear-gradient(135deg, #ff9a74, #ff6f61);
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  box-shadow: 0 6rpx 0 #e25549;
}

.combo.pulse {
  animation: comboPop 0.45s ease;
}

@keyframes comboPop {
  0% {
    transform: scale(0.85) rotate(-4deg);
  }
  50% {
    transform: scale(1.14) rotate(4deg);
  }
  100% {
    transform: scale(1) rotate(0);
  }
}

.timer {
  font-size: 28rpx;
  font-weight: 900;
  color: var(--color-sky);
  font-variant-numeric: tabular-nums;
  background: var(--color-sky-soft);
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}

.timer.urgent {
  color: #fff;
  background: var(--color-danger);
  animation: comboPop 0.6s ease infinite;
}

.duel-board {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-top: 16rpx;
  padding: 14rpx 18rpx;
  border-radius: 24rpx;
  background: #f3f7ff;
}

.duel-side {
  flex: 1;
  text-align: center;
  padding: 10rpx;
  border-radius: 18rpx;
  background: #fff;
}

.duel-side.lead {
  background: #e8fff8;
  box-shadow: 0 0 0 4rpx #22b8a8;
}

.duel-side.rival.lead {
  background: #fff0f0;
  box-shadow: 0 0 0 4rpx #ff6f61;
}

.duel-name {
  font-size: 22rpx;
  font-weight: 800;
  color: #4a4458;
}

.duel-score {
  margin-top: 4rpx;
  font-size: 44rpx;
  font-weight: 900;
  color: #1a1430;
  font-variant-numeric: tabular-nums;
}

.duel-vs {
  font-size: 24rpx;
  font-weight: 900;
  color: #9a93a8;
}

.poem-tag {
  font-size: 26rpx;
  color: var(--color-muted);
  flex: 1;
  font-weight: 700;
}

.progress-text {
  margin-top: 12rpx;
  font-size: 28rpx;
  font-weight: 900;
}

.bar {
  margin-top: 14rpx;
  height: 18rpx;
  background: #eef2f8;
  border-radius: 999rpx;
  overflow: hidden;
  border: 3rpx solid #f7f9fc;
}

.bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #ffc93c, #22b8a8 60%, #5b8cff);
  transition: width 0.25s ease;
}

.q-card {
  animation: riseIn 0.35s ease;
  padding: 36rpx 28rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f7fffc 100%);
}

@keyframes riseIn {
  from {
    opacity: 0;
    transform: translateY(18rpx) scale(0.98);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.q-type {
  display: inline-block;
  font-size: 22rpx;
  color: #fff;
  background: var(--color-ink);
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  margin-bottom: 20rpx;
  font-weight: 900;
}

.q-prompt {
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.45;
  margin-bottom: 32rpx;
}

.q-prompt-center {
  text-align: center;
  letter-spacing: 2rpx;
}

.options {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.option {
  min-height: 120rpx;
  padding: 32rpx 28rpx;
  border-radius: 28rpx;
  background: #fff;
  border: 4rpx solid #e8eef8;
  font-size: 34rpx;
  line-height: 1.4;
  font-weight: 800;
  box-shadow: 0 10rpx 0 rgba(43, 37, 64, 0.06);
  display: flex;
  align-items: center;
}

.option:active {
  border-color: var(--color-primary);
  background: var(--color-primary-soft);
  transform: translateY(6rpx);
  box-shadow: 0 4rpx 0 rgba(17, 153, 138, 0.15);
}

.option.correct {
  border-color: var(--color-ok);
  background: #d8fce9;
  box-shadow: 0 8rpx 0 rgba(62, 207, 142, 0.25);
}

.option.dim {
  opacity: 0.35;
}

.match-board {
  display: flex;
  gap: 14rpx;
}

.match-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.match-item {
  padding: 22rpx 12rpx;
  border-radius: 20rpx;
  background: #fff;
  font-size: 26rpx;
  line-height: 1.35;
  border: 4rpx solid #e8eef8;
  text-align: center;
  font-weight: 700;
  box-shadow: 0 6rpx 0 rgba(43, 37, 64, 0.05);
}

.match-item.selected {
  border-color: var(--color-accent);
  background: var(--color-accent-soft);
}

.match-item.done {
  opacity: 0.4;
  background: var(--color-primary-soft);
}

.match-actions {
  margin-top: 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.match-actions .btn-primary {
  flex: 1;
}

.options-chars {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
}

.options-chars .option {
  justify-content: center;
}

.option-char {
  text-align: center;
  font-size: 42rpx;
  font-weight: 900;
  padding: 28rpx 0;
}

.order-picked {
  margin-bottom: 24rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: var(--color-sun-soft);
  border: 3rpx dashed #ffc93c;
}

.order-picked-label {
  font-size: 22rpx;
  color: #9a7400;
  margin-bottom: 8rpx;
  font-weight: 900;
}

.order-picked-line {
  font-size: 28rpx;
  line-height: 1.5;
  margin-top: 4rpx;
  font-weight: 700;
}

.done-opt {
  opacity: 0.35;
  text-decoration: line-through;
}

.feedback {
  margin-top: 28rpx;
  text-align: center;
  font-size: 36rpx;
  font-weight: 900;
  animation: softPulse 0.5s ease;
}

.feedback.ok {
  color: var(--color-ok);
}

.feedback.bad {
  color: var(--color-danger);
}

@keyframes softPulse {
  from {
    transform: scale(0.85);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}

.visual-card {
  background: linear-gradient(180deg, #e8fff8, #fff);
}

.seq-row {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  flex-wrap: wrap;
  margin: 12rpx 0 20rpx;
}

.seq-slot {
  width: 120rpx;
  height: 120rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  font-weight: 900;
  background: #fff;
  border: 4rpx solid #d7dee8;
}

.seq-slot.show {
  border-color: #22b8a8;
  color: #0f8f82;
  background: #e8fff8;
}

.seq-slot.blank {
  color: #9a93a8;
}

.seq-slot.focus {
  border-color: #ff9f1c;
  box-shadow: 0 0 0 4rpx rgba(255, 159, 28, 0.25);
}

.visual-desc {
  text-align: center;
  font-size: 26rpx;
  color: #4a4458;
  margin-bottom: 16rpx;
}

.visual-icons {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  justify-content: center;
  min-height: 120rpx;
  align-content: center;
}

.visual-icon {
  font-size: 48rpx;
  line-height: 1;
  position: relative;
}

.visual-icon.gone {
  opacity: 0.35;
}

.visual-icon.gone::after {
  content: '/';
  position: absolute;
  left: 50%;
  top: 40%;
  transform: translate(-50%, -50%) rotate(-28deg);
  font-size: 52rpx;
  color: #1a1430;
  font-weight: 900;
}

.visual-add-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  flex-wrap: wrap;
  margin-bottom: 8rpx;
}

.visual-equation {
  margin: 20rpx 0 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.visual-num {
  min-width: 68rpx;
  height: 68rpx;
  border-radius: 14rpx;
  background: #f3f4f8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 900;
}

.visual-num.visual-ans {
  background: #22b8a8;
  color: #fff;
  min-width: 84rpx;
}

.visual-op {
  font-size: 36rpx;
  font-weight: 900;
  color: #1a1430;
}

.make-ten-groups {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.make-ten-tag {
  min-width: 64rpx;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  background: #22b8a8;
  color: #fff;
  font-size: 32rpx;
  font-weight: 900;
  text-align: center;
}

.make-ten-tag--b {
  background: #ff9f43;
}

.ten-frame {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 8rpx;
  padding: 12rpx;
  border: 4rpx solid #22b8a8;
  border-radius: 16rpx;
  background: #fff;
}

.ten-cell {
  aspect-ratio: 1;
  border: 2rpx dashed #c8ece8;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #22b8a8;
}

.ten-cell.on {
  background: #e8fff8;
  border-style: solid;
  border-color: #22b8a8;
}

.ten-cell.hi {
  background: #fff3e0;
  border-color: #ff9f43;
  color: #ff9f43;
}

.ten-frame-label {
  text-align: center;
  font-size: 22rpx;
  font-weight: 700;
  color: #6b7280;
  margin: 8rpx 0;
}

.ten-outside {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  flex-wrap: wrap;
  margin-bottom: 12rpx;
}

.ten-outside-dot {
  font-size: 32rpx;
  color: #ff9f43;
}

.ten-outside-tip {
  font-size: 24rpx;
  font-weight: 800;
  color: #ff9f43;
}

.numberline-wrap {
  position: relative;
  height: 160rpx;
  margin: 24rpx 16rpx 32rpx;
}

.numberline-bar {
  position: absolute;
  left: 0;
  right: 0;
  top: 88rpx;
  height: 8rpx;
  background: linear-gradient(90deg, #22b8a8, #4dabf7);
  border-radius: 999rpx;
}

.numberline-tick {
  position: absolute;
  top: 72rpx;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.numberline-tick-mark {
  width: 4rpx;
  height: 16rpx;
  background: #94a3b8;
  border-radius: 2rpx;
}

.numberline-tick-num {
  margin-top: 8rpx;
  font-size: 20rpx;
  font-weight: 700;
  color: #64748b;
}

.numberline-marker {
  position: absolute;
  top: 0;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.numberline-marker.left .numberline-bubble {
  background: #22b8a8;
}

.numberline-marker.right .numberline-bubble {
  background: #4dabf7;
}

.numberline-bubble {
  min-width: 56rpx;
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
  color: #fff;
  font-size: 28rpx;
  font-weight: 900;
  text-align: center;
}

.numberline-pin {
  width: 0;
  height: 0;
  border-left: 10rpx solid transparent;
  border-right: 10rpx solid transparent;
  border-top: 12rpx solid #64748b;
  margin-top: 4rpx;
}

.compare-pick {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  margin-top: 8rpx;
}

.compare-num {
  font-size: 40rpx;
  font-weight: 900;
  min-width: 64rpx;
  text-align: center;
}

.compare-num--left {
  color: #22b8a8;
}

.compare-num--right {
  color: #4dabf7;
}

.compare-symbol-row {
  display: flex;
  gap: 12rpx;
}

.compare-symbol-btn {
  width: 88rpx;
  height: 88rpx;
  border-radius: 16rpx;
  background: #fff;
  border: 4rpx solid #e2e8f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 900;
  color: #1a1430;
  box-shadow: 0 6rpx 0 #cbd5e1;
}

.compare-symbol-btn:active {
  transform: translateY(4rpx);
  box-shadow: 0 2rpx 0 #cbd5e1;
}
