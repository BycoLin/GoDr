.play {
  min-height: 100vh;
}

.top {
  margin-bottom: 28rpx;
}

.poem-tag {
  font-size: 26rpx;
  color: var(--color-muted);
}

.progress-text {
  margin-top: 8rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.bar {
  margin-top: 16rpx;
  height: 14rpx;
  background: #e5ebe7;
  border-radius: 999rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  background: var(--color-primary);
  transition: width 0.25s ease;
}

.q-card {
  animation: riseIn 0.35s ease;
}

@keyframes riseIn {
  from {
    opacity: 0;
    transform: translateY(16rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.q-type {
  display: inline-block;
  font-size: 22rpx;
  color: var(--color-primary);
  background: var(--color-primary-soft);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
}

.q-prompt {
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.45;
  margin-bottom: 32rpx;
}

.options {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.option {
  padding: 28rpx 24rpx;
  border-radius: 16rpx;
  background: #f3f7f4;
  border: 2rpx solid transparent;
  font-size: 30rpx;
  line-height: 1.4;
}

.option:active {
  border-color: var(--color-primary);
  background: var(--color-primary-soft);
}

.option.correct {
  border-color: var(--color-ok);
  background: #dcfce7;
}

.option.dim {
  opacity: 0.45;
}

.match-board {
  display: flex;
  gap: 20rpx;
}

.match-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.match-item {
  padding: 24rpx 16rpx;
  border-radius: 14rpx;
  background: #f3f7f4;
  font-size: 26rpx;
  line-height: 1.35;
  border: 2rpx solid transparent;
  text-align: center;
}

.match-item.selected {
  border-color: var(--color-accent);
  background: var(--color-accent-soft);
}

.match-item.done {
  opacity: 0.45;
  background: var(--color-primary-soft);
}

.match-actions {
  margin-top: 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.match-actions .btn-primary {
  flex: 1;
}

.feedback {
  margin-top: 32rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  animation: softPulse 0.5s ease;
}

.feedback.ok {
  color: var(--color-ok);
}

.feedback.bad {
  color: var(--color-danger);
}

@keyframes softPulse {
  from {
    transform: scale(0.9);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}
