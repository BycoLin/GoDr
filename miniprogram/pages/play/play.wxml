<view class="safe-pad play {{feedback ? 'play--feedback' : ''}}">
  <view class="top">
    <view class="hud">
      <view class="poem-tag" wx:if="{{arcade}}">{{modeLabel}} · {{poemAuthor}}</view>
      <view class="poem-tag" wx:elif="{{isMathPack || isEnglishPack}}">{{poemTitle}} · {{poemAuthor}}</view>
      <view class="poem-tag" wx:else>《{{poemTitle}}》 · {{poemAuthor}}</view>
      <view class="hud-right">
        <view class="combo {{comboPulse ? 'pulse' : ''}}" wx:if="{{combo >= 2}}">连对 x{{combo}}</view>
        <view class="timer {{remainSec <= 10 ? 'urgent' : ''}}" wx:if="{{timed}}">{{remainSec}}s</view>
      </view>
    </view>

    <view class="duel-board" wx:if="{{duel}}">
      <view class="duel-side {{duelLead === 'win' ? 'lead' : ''}}">
        <view class="duel-name">我</view>
        <view class="duel-score">{{userScore}}</view>
      </view>
      <view class="duel-vs">VS</view>
      <view class="duel-side rival {{duelLead === 'lose' ? 'lead' : ''}}">
        <view class="duel-name">伙伴</view>
        <view class="duel-score">{{rivalScore}}</view>
      </view>
    </view>

    <view class="progress-text" wx:if="{{!duel}}">第 {{index + 1}} / {{total}} 题 · 攒了 {{sessionPoints}} 分</view>
    <view class="progress-text" wx:else>先得 {{total}} 分获胜 · 已答 {{index + 1}} 题</view>
    <view class="bar">
      <view class="bar-fill" style="width: {{total ? ((index + 1) / total * 100) : 0}}%;"></view>
    </view>
  </view>

  <block wx:if="{{current}}">
    <!-- mathVisual 看图口算 / 凑十 / 数轴 -->
    <view class="card q-card visual-card" wx:if="{{current.type === 'mathVisual'}}">
      <view class="q-type">
        <block wx:if="{{current.op === 'makeTen'}}">凑十法</block>
        <block wx:elif="{{current.op === 'compare'}}">数轴比大小</block>
        <block wx:else>看图口算</block>
      </view>
      <view class="q-prompt visual-desc">{{current.prompt}}</view>

      <block wx:if="{{current.op === 'sub'}}">
        <view class="visual-icons">
          <view
            class="visual-icon {{item.gone ? 'gone' : ''}}"
            wx:for="{{current.icons}}"
            wx:key="id"
          >{{current.icon}}</view>
        </view>
        <view class="visual-equation">
          <view class="visual-num">{{current.a}}</view>
          <view class="visual-op">-</view>
          <view class="visual-num">{{current.b}}</view>
          <view class="visual-op">=</view>
          <view class="visual-num visual-ans">{{visualInput || '?'}}</view>
        </view>
        <num-keypad wx:if="{{!locked}}" bind:key="onVisualKey" />
      </block>

      <block wx:elif="{{current.op === 'add'}}">
        <view class="visual-add-row">
          <view class="visual-icons">
            <view class="visual-icon" wx:for="{{current.iconsA}}" wx:key="id">{{current.icon}}</view>
          </view>
          <view class="visual-op">+</view>
          <view class="visual-icons">
            <view class="visual-icon" wx:for="{{current.iconsB}}" wx:key="id">{{current.icon}}</view>
          </view>
        </view>
        <view class="visual-equation">
          <view class="visual-num">{{current.a}}</view>
          <view class="visual-op">+</view>
          <view class="visual-num">{{current.b}}</view>
          <view class="visual-op">=</view>
          <view class="visual-num visual-ans">{{visualInput || '?'}}</view>
        </view>
        <num-keypad wx:if="{{!locked}}" bind:key="onVisualKey" />
      </block>

      <block wx:elif="{{current.op === 'makeTen'}}">
        <view class="make-ten-groups">
          <view class="make-ten-tag">{{current.a}}</view>
          <view class="visual-op">+</view>
          <view class="make-ten-tag make-ten-tag--b">{{current.b}}</view>
        </view>
        <view class="ten-frame">
          <view
            class="ten-cell {{item.filled ? 'on' : ''}} {{item.highlight ? 'hi' : ''}}"
            wx:for="{{current.tenFrame}}"
            wx:key="id"
          >
            <text wx:if="{{item.filled}}">●</text>
          </view>
        </view>
        <view class="ten-frame-label">凑满十格</view>
        <view class="ten-outside" wx:if="{{current.outsideDots.length}}">
          <text class="ten-outside-dot" wx:for="{{current.outsideDots}}" wx:key="id">●</text>
          <text class="ten-outside-tip">十格外 +{{current.outsideDots.length}}</text>
        </view>
        <view class="visual-equation">
          <view class="visual-num">{{current.a}}</view>
          <view class="visual-op">+</view>
          <view class="visual-num">{{current.b}}</view>
          <view class="visual-op">=</view>
          <view class="visual-num visual-ans">{{visualInput || '?'}}</view>
        </view>
        <num-keypad wx:if="{{!locked}}" bind:key="onVisualKey" />
      </block>

      <block wx:elif="{{current.op === 'compare'}}">
        <view class="numberline-wrap">
          <view class="numberline-bar"></view>
          <view
            class="numberline-tick"
            wx:for="{{current.lineTicks}}"
            wx:key="value"
            style="left: {{item.pct}}%;"
          >
            <view class="numberline-tick-mark"></view>
            <text class="numberline-tick-num">{{item.value}}</text>
          </view>
          <view class="numberline-marker left" style="left: {{current.leftPct}}%;">
            <view class="numberline-bubble">{{current.left}}</view>
            <view class="numberline-pin"></view>
          </view>
          <view class="numberline-marker right" style="left: {{current.rightPct}}%;">
            <view class="numberline-bubble">{{current.right}}</view>
            <view class="numberline-pin"></view>
          </view>
        </view>
        <view class="compare-pick">
          <view class="compare-num compare-num--left">{{current.left}}</view>
          <view class="compare-symbol-row" wx:if="{{!locked}}">
            <view class="compare-symbol-btn" data-symbol="gt" bindtap="onVisualCompare">＞</view>
            <view class="compare-symbol-btn" data-symbol="eq" bindtap="onVisualCompare">＝</view>
            <view class="compare-symbol-btn" data-symbol="lt" bindtap="onVisualCompare">＜</view>
          </view>
          <view class="compare-num compare-num--right">{{current.right}}</view>
        </view>
      </block>
    </view>

    <!-- mathSequence 数字排队 -->
    <view class="card q-card visual-card" wx:if="{{current.type === 'mathSequence'}}">
      <view class="q-type">数字排队</view>
      <view class="q-prompt visual-desc">{{current.prompt}}</view>
      <view class="seq-row">
        <view
          class="seq-slot {{item.show ? 'show' : 'blank'}} {{!item.show && sequenceFocusIndex === index ? 'focus' : ''}}"
          wx:for="{{sequenceSlots}}"
          wx:key="index"
          data-index="{{index}}"
          bindtap="onTapSequenceSlot"
        >
          <block wx:if="{{item.show}}">{{item.value}}</block>
          <block wx:else>{{item.filled || '?'}}</block>
        </view>
      </view>
      <num-keypad wx:if="{{!locked}}" bind:key="onSequenceKey" />
    </view>

    <!-- mathBigWrite 拼图工坊 -->
    <view class="card q-card visual-card" wx:if="{{current.type === 'mathBigWrite'}}">
      <view class="q-type">数字拼图工坊</view>
      <view class="q-prompt visual-desc">{{current.prompt}}</view>
      <view class="puzzle-read">读作：{{current.readText}}</view>
      <view class="puzzle-pieces">
        <view class="puzzle-piece" wx:for="{{current.puzzlePieces}}" wx:key="id">
          <view class="puzzle-notch puzzle-notch--tl"></view>
          <view class="puzzle-notch puzzle-notch--br"></view>
          <text class="puzzle-text">{{item.text}}</text>
        </view>
      </view>
      <view class="puzzle-tip">把数字块拼起来，写出完整的大数</view>
      <view class="visual-equation">
        <view class="visual-num visual-ans puzzle-ans">{{bigWriteInput || '?'}}</view>
      </view>
      <num-keypad wx:if="{{!locked}}" bind:key="onBigWriteKey" />
    </view>

    <!-- mathAngleMeasure 量角器 -->
    <view class="card q-card visual-card angle-measure-card" wx:if="{{current.type === 'mathAngleMeasure'}}">
      <view class="q-type">量角器小工匠</view>
      <view class="q-prompt visual-desc">{{current.prompt}}</view>
      <view class="angle-measure-diagram">
        <view class="protractor-stage">
          <view class="protractor-arc">
            <view
              class="protractor-tick {{item.major ? 'major' : ''}}"
              wx:for="{{current.ticks}}"
              wx:key="id"
              style="transform: rotate(-{{item.deg}}deg);"
            >
              <view class="tick-mark"></view>
              <text wx:if="{{item.label}}" class="tick-label">{{item.label}}</text>
            </view>
            <view class="protractor-arm-base"></view>
            <view class="protractor-arm" style="transform: rotate(-{{current.angleDeg}}deg);"></view>
            <view class="protractor-center"></view>
          </view>
        </view>
        <view class="angle-read-tip">红点在圆心，绿边是这个角的大小</view>
      </view>
      <view class="angle-pick angle-pick--grid">
        <view
          class="angle-pick-btn {{locked && item.id === current.answerId ? 'correct' : ''}} {{locked && feedback === 'bad' && item.id !== current.answerId ? 'dim' : ''}}"
          wx:for="{{current.options}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="onChooseOption"
        >{{item.text}}</view>
      </view>
    </view>

    <!-- mathBigCompare 数字赛车场 -->
    <view class="card q-card visual-card race-card" wx:if="{{current.type === 'mathBigCompare'}}">
      <view class="q-type">数字赛车场</view>
      <view class="q-prompt visual-desc">{{current.prompt}}</view>
      <view class="race-track">
        <view class="race-finish">🏁</view>
        <view class="race-columns">
          <view class="race-column race-column--left">
            <view class="race-column-label">左边</view>
            <view class="race-column-track">
              <view class="race-car race-car--red">
                <text class="race-car-icon">🏎</text>
              </view>
            </view>
            <view class="race-num race-num--red">{{current.compareLeft}}</view>
          </view>
          <view class="race-column race-column--right">
            <view class="race-column-label">右边</view>
            <view class="race-column-track">
              <view class="race-car race-car--blue">
                <text class="race-car-icon">🏎</text>
              </view>
            </view>
            <view class="race-num race-num--blue">{{current.compareRight}}</view>
          </view>
        </view>
      </view>
      <view class="race-formula">
        <text class="race-formula-num race-num--red">{{current.compareLeft}}</text>
        <text class="race-formula-gap">□</text>
        <text class="race-formula-num race-num--blue">{{current.compareRight}}</text>
      </view>
      <view class="race-pick-label">左边 □ 右边，选出正确符号</view>
      <view class="race-pick">
        <view
          class="race-pick-btn {{locked && item.id === current.answerId ? 'correct' : ''}} {{locked && feedback === 'bad' && item.id !== current.answerId ? 'dim' : ''}}"
          wx:for="{{current.options}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="onChooseOption"
        >{{item.text}}</view>
      </view>
    </view>

    <!-- fillNext / titleAuthor / fillBlank -->
    <view
      class="card q-card {{current.diagram ? 'visual-card' : ''}}"
      wx:if="{{current.type === 'fillNext' || current.type === 'titleAuthor' || current.type === 'fillBlank' || current.type === 'similarChar' || current.type === 'poetryPicture' || current.type === 'mathCalc' || current.type === 'mathCompare' || current.type === 'mathMissing' || current.type === 'mathPlaceValue' || current.type === 'mathBigRead' || current.type === 'mathRound' || current.type === 'mathLineType' || current.type === 'mathGeoRelation' || current.type === 'mathAngleClassify' || current.type === 'mathMakeTen' || current.type === 'mathBreakTen' || current.type === 'mathFlatTen' || current.type === 'mathBorrowTen' || current.type === 'enWordMean' || current.type === 'enMeanWord' || current.type === 'enSpell' || current.type === 'enPictureMean' || current.type === 'enPictureWord' || current.type === 'enPhoneticWord'}}"
    >
      <view class="q-type">
        <block wx:if="{{current.type === 'fillNext'}}">下一句</block>
        <block wx:elif="{{current.type === 'fillBlank'}}">缺字填空</block>
        <block wx:elif="{{current.type === 'similarChar'}}">形近字找茬</block>
        <block wx:elif="{{current.type === 'poetryPicture'}}">看图猜篇</block>
        <block wx:elif="{{current.type === 'mathCalc'}}">速算</block>
        <block wx:elif="{{current.type === 'mathCompare'}}">比大小</block>
        <block wx:elif="{{current.type === 'mathPlaceValue'}}">数位认识</block>
        <block wx:elif="{{current.type === 'mathBigRead'}}">大数读法</block>
        <block wx:elif="{{current.type === 'mathRound'}}">近似数</block>
        <block wx:elif="{{current.type === 'mathLineType'}}">线的认识</block>
        <block wx:elif="{{current.type === 'mathGeoRelation'}}">平行垂直</block>
        <block wx:elif="{{current.type === 'mathAngleClassify'}}">角的分类</block>
        <block wx:elif="{{current.type === 'mathMissing'}}">填空</block>
        <block wx:elif="{{current.type === 'mathMakeTen'}}">凑十法</block>
        <block wx:elif="{{current.type === 'mathBreakTen'}}">破十法</block>
        <block wx:elif="{{current.type === 'mathFlatTen'}}">平十法</block>
        <block wx:elif="{{current.type === 'mathBorrowTen'}}">借十法</block>
        <block wx:elif="{{current.type === 'enWordMean'}}">看词选义</block>
        <block wx:elif="{{current.type === 'enMeanWord'}}">看义选词</block>
        <block wx:elif="{{current.type === 'enSpell'}}">缺字母</block>
        <block wx:elif="{{current.type === 'enPictureMean'}}">看图选义</block>
        <block wx:elif="{{current.type === 'enPictureWord'}}">看图选词</block>
        <block wx:elif="{{current.type === 'enPhoneticWord'}}">音标选词</block>
        <block wx:else>{{current.typeLabel || (current.mode === 'title' ? '选诗名' : '选作者')}}</block>
      </view>
      <view class="q-source" wx:if="{{current.type === 'fillNext' && current.sourceTitle}}">《{{current.sourceTitle}}》</view>

      <!-- 几何示意图：线条 / 平行垂直 / 角的分类 -->
      <view class="geo-diagram" wx:if="{{current.diagram}}">
        <block wx:if="{{current.diagram.kind === 'line'}}">
          <view class="geo-line-stage">
            <view class="geo-line-bar geo-line-bar--{{current.diagram.lineKind}}">
              <view class="geo-arrow geo-arrow--left" wx:if="{{current.diagram.lineKind === 'line'}}"></view>
              <view class="geo-dot geo-dot--a" wx:if="{{current.diagram.lineKind === 'segment' || current.diagram.lineKind === 'ray'}}"></view>
              <view class="geo-dot geo-dot--b" wx:if="{{current.diagram.lineKind === 'segment'}}"></view>
              <view class="geo-arrow geo-arrow--right" wx:if="{{current.diagram.lineKind === 'line' || current.diagram.lineKind === 'ray'}}"></view>
            </view>
          </view>
        </block>
        <block wx:elif="{{current.diagram.kind === 'parallel'}}">
          <!-- 平行：双轨 / 双边 -->
          <view class="geo-parallel-stage" wx:if="{{current.diagram.relation === 'parallel'}}">
            <view class="geo-parallel-line"></view>
            <view class="geo-parallel-line"></view>
            <view class="geo-scene-hint" wx:if="{{current.diagram.scene === 'rail'}}">铁轨</view>
            <view class="geo-scene-hint" wx:elif="{{current.diagram.scene === 'book'}}">书边</view>
            <view class="geo-scene-hint" wx:elif="{{current.diagram.scene === 'road'}}">路边线</view>
            <view class="geo-scene-hint" wx:elif="{{current.diagram.scene === 'window'}}">窗框</view>
          </view>
          <!-- 垂直·拐角：课桌、长方形邻边 -->
          <view class="geo-corner-stage" wx:elif="{{current.diagram.scene === 'desk' || current.diagram.scene === 'corner'}}">
            <view class="geo-desk-surface" wx:if="{{current.diagram.scene === 'desk'}}"></view>
            <view class="geo-corner-v"></view>
            <view class="geo-corner-h"></view>
            <view class="geo-corner-mark"></view>
            <view class="geo-scene-hint geo-scene-hint--corner">{{current.diagram.scene === 'desk' ? '课桌面' : '邻边'}}</view>
          </view>
          <!-- 垂直·旗杆与地面 -->
          <view class="geo-flag-stage" wx:elif="{{current.diagram.scene === 'flag'}}">
            <view class="geo-flag-ground"></view>
            <view class="geo-flag-pole"></view>
            <view class="geo-flag-mark"></view>
            <view class="geo-scene-hint">旗杆 · 地面</view>
          </view>
          <!-- 垂直·十字路口 -->
          <view class="geo-cross-stage" wx:else>
            <view class="geo-cross-h"></view>
            <view class="geo-cross-v"></view>
            <view class="geo-cross-mark"></view>
            <view class="geo-scene-hint">路口</view>
          </view>
        </block>
        <block wx:elif="{{current.diagram.kind === 'angle'}}">
          <view class="geo-angle-stage">
            <view class="geo-angle-base"></view>
            <view class="geo-angle-arm" style="transform: rotate(-{{current.diagram.angleDeg}}deg);"></view>
            <view class="geo-angle-label">{{current.diagram.angleDeg}}°</view>
          </view>
        </block>
      </view>

      <view class="place-value-num" wx:if="{{current.placeValueChars && current.placeValueChars.length}}">
        <text
          class="place-value-char {{item.hi ? 'place-value-char--hi' : ''}}"
          wx:for="{{current.placeValueChars}}"
          wx:for-item="item"
          wx:key="index"
        >{{item.text}}</text>
      </view>

      <block wx:if="{{current.type === 'similarChar'}}">
        <view class="similar-hint">{{current.prompt}}</view>
        <view class="similar-line">
          <text
            class="similar-char {{index === current.wrongIdx ? 'similar-wrong' : ''}}"
            wx:for="{{current.displayChars}}"
            wx:for-index="index"
            wx:key="index"
          >{{item}}</text>
        </view>
      </block>
      <block wx:elif="{{current.type === 'titleAuthor'}}">
        <view class="similar-hint">{{current.prompt}}</view>
        <view class="excerpt-line">{{current.excerpt}}</view>
      </block>
      <block wx:elif="{{current.visualEmoji}}">
        <view class="emoji-visual">
          <text class="emoji-visual-chars">{{current.visualEmoji}}</text>
        </view>
        <view class="q-prompt visual-desc">{{current.prompt}}</view>
      </block>
      <view wx:else class="q-prompt {{current.diagram ? 'visual-desc' : ''}} {{current.type === 'fillBlank' ? 'q-prompt-center' : ''}}">{{current.prompt}}</view>
      <view class="options {{current.type === 'fillBlank' || current.type === 'similarChar' || current.type === 'mathCompare' || current.type === 'enSpell' ? 'options-chars' : ''}}">
        <view
          class="option {{current.type === 'fillBlank' || current.type === 'similarChar' || current.type === 'mathCompare' || current.type === 'enSpell' ? 'option-char' : ''}} {{locked && item.id === current.answerId ? 'correct' : ''}} {{locked && feedback === 'bad' && item.id !== current.answerId ? 'dim' : ''}}"
          wx:for="{{current.options}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="onChooseOption"
        >{{item.text}}</view>
      </view>
    </view>

    <!-- matchPair -->
    <view class="card q-card" wx:if="{{current.type === 'matchPair'}}">
      <view class="q-type">{{isEnglishPack ? '中英配对' : (current.couplet ? '对联配对' : '上下句配对')}}</view>
      <view class="q-prompt">{{current.couplet ? '点选上联，再点选对应的下联' : '点选左边一句，再点右边对应的下一句'}}</view>
      <view class="match-board">
        <view class="match-col">
          <view
            class="match-item {{match.leftDone[item.id] ? 'done' : ''}} {{match.selectedLeft === item.id ? 'selected' : ''}}"
            wx:for="{{current.left}}"
            wx:key="id"
            data-id="{{item.id}}"
            bindtap="onTapLeft"
          >{{item.text}}</view>
        </view>
        <view class="match-col">
          <view
            class="match-item {{match.rightDone[item.id] ? 'done' : ''}} {{match.selectedRight === item.id ? 'selected' : ''}}"
            wx:for="{{current.right}}"
            wx:key="id"
            data-id="{{item.id}}"
            bindtap="onTapRight"
          >{{item.text}}</view>
        </view>
      </view>
      <view class="match-actions">
        <button class="btn btn-ghost" size="mini" bindtap="onUndoMatch">重来</button>
        <button class="btn btn-primary" disabled="{{!matchReady || locked}}" bindtap="onSubmitMatch">确认配对</button>
      </view>
    </view>

    <!-- orderLines -->
    <view class="card q-card" wx:if="{{current.type === 'orderLines'}}">
      <view class="q-type">{{current.narrative ? '内容排序' : '诗句排序'}}</view>
      <view class="q-prompt">{{current.prompt}}</view>
      <view class="order-picked" wx:if="{{orderPickedTexts.length}}">
        <view class="order-picked-label">已选顺序</view>
        <view class="order-picked-line" wx:for="{{orderPickedTexts}}" wx:key="*this">
          {{index + 1}}. {{item}}
        </view>
      </view>
      <view class="options">
        <view
          class="option {{!orderAvailable[item.id] ? 'done-opt' : ''}}"
          wx:for="{{current.options}}"
          wx:key="id"
          data-id="{{item.id}}"
          data-text="{{item.text}}"
          bindtap="onTapOrderOption"
        >{{item.text}}</view>
      </view>
      <view class="match-actions">
        <button class="btn btn-ghost" size="mini" bindtap="onUndoOrder">重来</button>
        <button
          class="btn btn-primary"
          disabled="{{locked || orderPicked.length !== current.answerOrder.length}}"
          bindtap="onSubmitOrder"
        >确认顺序</button>
      </view>
    </view>
  </block>

  <view class="feedback-bar {{feedback}}" wx:if="{{feedback}}">
    <view class="feedback-inner">{{feedbackText}}</view>
  </view>
</view>
