<view class="safe-pad play">
  <view class="top">
    <view class="hud">
      <view class="poem-tag" wx:if="{{arcade}}">{{modeLabel}} · {{poemAuthor}}</view>
      <view class="poem-tag" wx:elif="{{isMathPack || isEnglishPack}}">{{poemTitle}} · {{poemAuthor}}</view>
      <view class="poem-tag" wx:else>《{{poemTitle}}》 · {{poemAuthor}}</view>
      <view class="hud-right">
        <view class="combo {{comboPulse ? 'pulse' : ''}}" wx:if="{{combo >= 2}}">连对 x{{combo}}</view>
        <view class="timer {{remainSec <= 10 ? 'urgent' : ''}}" wx:if="{{timed}}">{{remainSec}}s</view>
      </view>
    </view>

    <view class="duel-board" wx:if="{{duel}}">
      <view class="duel-side {{duelLead === 'win' ? 'lead' : ''}}">
        <view class="duel-name">我</view>
        <view class="duel-score">{{userScore}}</view>
      </view>
      <view class="duel-vs">VS</view>
      <view class="duel-side rival {{duelLead === 'lose' ? 'lead' : ''}}">
        <view class="duel-name">伙伴</view>
        <view class="duel-score">{{rivalScore}}</view>
      </view>
    </view>

    <view class="progress-text" wx:if="{{!duel}}">第 {{index + 1}} / {{total}} 题 · 攒了 {{sessionPoints}} 分</view>
    <view class="progress-text" wx:else>先得 {{total}} 分获胜 · 已答 {{index + 1}} 题</view>
    <view class="bar">
      <view class="bar-fill" style="width: {{total ? ((index + 1) / total * 100) : 0}}%;"></view>
    </view>
  </view>

  <block wx:if="{{current}}">
    <!-- mathVisual 看图口算 / 凑十 / 数轴 -->
    <view class="card q-card visual-card" wx:if="{{current.type === 'mathVisual'}}">
      <view class="q-type">
        <block wx:if="{{current.op === 'makeTen'}}">凑十法</block>
        <block wx:elif="{{current.op === 'compare'}}">数轴比大小</block>
        <block wx:else>看图口算</block>
      </view>
      <view class="q-prompt visual-desc">{{current.prompt}}</view>

      <block wx:if="{{current.op === 'sub'}}">
        <view class="visual-icons">
          <view
            class="visual-icon {{item.gone ? 'gone' : ''}}"
            wx:for="{{current.icons}}"
            wx:key="id"
          >{{current.icon}}</view>
        </view>
        <view class="visual-equation">
          <view class="visual-num">{{current.a}}</view>
          <view class="visual-op">-</view>
          <view class="visual-num">{{current.b}}</view>
          <view class="visual-op">=</view>
          <view class="visual-num visual-ans">{{visualInput || '?'}}</view>
        </view>
        <num-keypad wx:if="{{!locked}}" bind:key="onVisualKey" />
      </block>

      <block wx:elif="{{current.op === 'add'}}">
        <view class="visual-add-row">
          <view class="visual-icons">
            <view class="visual-icon" wx:for="{{current.iconsA}}" wx:key="id">{{current.icon}}</view>
          </view>
          <view class="visual-op">+</view>
          <view class="visual-icons">
            <view class="visual-icon" wx:for="{{current.iconsB}}" wx:key="id">{{current.icon}}</view>
          </view>
        </view>
        <view class="visual-equation">
          <view class="visual-num">{{current.a}}</view>
          <view class="visual-op">+</view>
          <view class="visual-num">{{current.b}}</view>
          <view class="visual-op">=</view>
          <view class="visual-num visual-ans">{{visualInput || '?'}}</view>
        </view>
        <num-keypad wx:if="{{!locked}}" bind:key="onVisualKey" />
      </block>

      <block wx:elif="{{current.op === 'makeTen'}}">
        <view class="make-ten-groups">
          <view class="make-ten-tag">{{current.a}}</view>
          <view class="visual-op">+</view>
          <view class="make-ten-tag make-ten-tag--b">{{current.b}}</view>
        </view>
        <view class="ten-frame">
          <view
            class="ten-cell {{item.filled ? 'on' : ''}} {{item.highlight ? 'hi' : ''}}"
            wx:for="{{current.tenFrame}}"
            wx:key="id"
          >
            <text wx:if="{{item.filled}}">●</text>
          </view>
        </view>
        <view class="ten-frame-label">凑满十格</view>
        <view class="ten-outside" wx:if="{{current.outsideDots.length}}">
          <text class="ten-outside-dot" wx:for="{{current.outsideDots}}" wx:key="id">●</text>
          <text class="ten-outside-tip">十格外 +{{current.outsideDots.length}}</text>
        </view>
        <view class="visual-equation">
          <view class="visual-num">{{current.a}}</view>
          <view class="visual-op">+</view>
          <view class="visual-num">{{current.b}}</view>
          <view class="visual-op">=</view>
          <view class="visual-num visual-ans">{{visualInput || '?'}}</view>
        </view>
        <num-keypad wx:if="{{!locked}}" bind:key="onVisualKey" />
      </block>

      <block wx:elif="{{current.op === 'compare'}}">
        <view class="numberline-wrap">
          <view class="numberline-bar"></view>
          <view
            class="numberline-tick"
            wx:for="{{current.lineTicks}}"
            wx:key="value"
            style="left: {{item.pct}}%;"
          >
            <view class="numberline-tick-mark"></view>
            <text class="numberline-tick-num">{{item.value}}</text>
          </view>
          <view class="numberline-marker left" style="left: {{current.leftPct}}%;">
            <view class="numberline-bubble">{{current.left}}</view>
            <view class="numberline-pin"></view>
          </view>
          <view class="numberline-marker right" style="left: {{current.rightPct}}%;">
            <view class="numberline-bubble">{{current.right}}</view>
            <view class="numberline-pin"></view>
          </view>
        </view>
        <view class="compare-pick">
          <view class="compare-num compare-num--left">{{current.left}}</view>
          <view class="compare-symbol-row" wx:if="{{!locked}}">
            <view class="compare-symbol-btn" data-symbol="gt" bindtap="onVisualCompare">＞</view>
            <view class="compare-symbol-btn" data-symbol="eq" bindtap="onVisualCompare">＝</view>
            <view class="compare-symbol-btn" data-symbol="lt" bindtap="onVisualCompare">＜</view>
          </view>
          <view class="compare-num compare-num--right">{{current.right}}</view>
        </view>
      </block>
    </view>

    <!-- mathSequence 数字排队 -->
    <view class="card q-card visual-card" wx:if="{{current.type === 'mathSequence'}}">
      <view class="q-type">数字排队</view>
      <view class="q-prompt visual-desc">{{current.prompt}}</view>
      <view class="seq-row">
        <view
          class="seq-slot {{item.show ? 'show' : 'blank'}} {{!item.show && sequenceFocusIndex === index ? 'focus' : ''}}"
          wx:for="{{sequenceSlots}}"
          wx:key="index"
          data-index="{{index}}"
          bindtap="onTapSequenceSlot"
        >
          <block wx:if="{{item.show}}">{{item.value}}</block>
          <block wx:else>{{item.filled || '?'}}</block>
        </view>
      </view>
      <num-keypad wx:if="{{!locked}}" bind:key="onSequenceKey" />
    </view>

    <!-- fillNext / titleAuthor / fillBlank -->
    <view
      class="card q-card"
      wx:if="{{current.type === 'fillNext' || current.type === 'titleAuthor' || current.type === 'fillBlank' || current.type === 'mathCalc' || current.type === 'mathCompare' || current.type === 'mathMissing' || current.type === 'mathMakeTen' || current.type === 'mathBreakTen' || current.type === 'mathFlatTen' || current.type === 'mathBorrowTen' || current.type === 'enWordMean' || current.type === 'enMeanWord' || current.type === 'enSpell'}}"
    >
      <view class="q-type">
        <block wx:if="{{current.type === 'fillNext'}}">下一句</block>
        <block wx:elif="{{current.type === 'fillBlank'}}">缺字填空</block>
        <block wx:elif="{{current.type === 'mathCalc'}}">速算</block>
        <block wx:elif="{{current.type === 'mathCompare'}}">比大小</block>
        <block wx:elif="{{current.type === 'mathMissing'}}">填空</block>
        <block wx:elif="{{current.type === 'mathMakeTen'}}">凑十法</block>
        <block wx:elif="{{current.type === 'mathBreakTen'}}">破十法</block>
        <block wx:elif="{{current.type === 'mathFlatTen'}}">平十法</block>
        <block wx:elif="{{current.type === 'mathBorrowTen'}}">借十法</block>
        <block wx:elif="{{current.type === 'enWordMean'}}">看词选义</block>
        <block wx:elif="{{current.type === 'enMeanWord'}}">看义选词</block>
        <block wx:elif="{{current.type === 'enSpell'}}">缺字母</block>
        <block wx:else>{{current.mode === 'title' ? '选诗名' : '选作者'}}</block>
      </view>
      <view class="q-prompt {{current.type === 'fillBlank' ? 'q-prompt-center' : ''}}">{{current.prompt}}</view>
      <view class="options {{current.type === 'fillBlank' || current.type === 'mathCompare' || current.type === 'enSpell' ? 'options-chars' : ''}}">
        <view
          class="option {{current.type === 'fillBlank' || current.type === 'mathCompare' || current.type === 'enSpell' ? 'option-char' : ''}} {{locked && item.id === current.answerId ? 'correct' : ''}} {{locked && feedback === 'bad' && item.id !== current.answerId ? 'dim' : ''}}"
          wx:for="{{current.options}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="onChooseOption"
        >{{item.text}}</view>
      </view>
    </view>

    <!-- matchPair -->
    <view class="card q-card" wx:if="{{current.type === 'matchPair'}}">
      <view class="q-type">{{isEnglishPack ? '中英配对' : '上下句配对'}}</view>
      <view class="q-prompt">点选左边一句，再点右边对应的下一句</view>
      <view class="match-board">
        <view class="match-col">
          <view
            class="match-item {{match.leftDone[item.id] ? 'done' : ''}} {{match.selectedLeft === item.id ? 'selected' : ''}}"
            wx:for="{{current.left}}"
            wx:key="id"
            data-id="{{item.id}}"
            bindtap="onTapLeft"
          >{{item.text}}</view>
        </view>
        <view class="match-col">
          <view
            class="match-item {{match.rightDone[item.id] ? 'done' : ''}} {{match.selectedRight === item.id ? 'selected' : ''}}"
            wx:for="{{current.right}}"
            wx:key="id"
            data-id="{{item.id}}"
            bindtap="onTapRight"
          >{{item.text}}</view>
        </view>
      </view>
      <view class="match-actions">
        <button class="btn btn-ghost" size="mini" bindtap="onUndoMatch">重来</button>
        <button class="btn btn-primary" disabled="{{!matchReady || locked}}" bindtap="onSubmitMatch">确认配对</button>
      </view>
    </view>

    <!-- orderLines -->
    <view class="card q-card" wx:if="{{current.type === 'orderLines'}}">
      <view class="q-type">诗句排序</view>
      <view class="q-prompt">{{current.prompt}}</view>
      <view class="order-picked" wx:if="{{orderPickedTexts.length}}">
        <view class="order-picked-label">已选顺序</view>
        <view class="order-picked-line" wx:for="{{orderPickedTexts}}" wx:key="*this">
          {{index + 1}}. {{item}}
        </view>
      </view>
      <view class="options">
        <view
          class="option {{!orderAvailable[item.id] ? 'done-opt' : ''}}"
          wx:for="{{current.options}}"
          wx:key="id"
          data-id="{{item.id}}"
          data-text="{{item.text}}"
          bindtap="onTapOrderOption"
        >{{item.text}}</view>
      </view>
      <view class="match-actions">
        <button class="btn btn-ghost" size="mini" bindtap="onUndoOrder">重来</button>
        <button
          class="btn btn-primary"
          disabled="{{locked || orderPicked.length !== current.answerOrder.length}}"
          bindtap="onSubmitOrder"
        >确认顺序</button>
      </view>
    </view>
  </block>

  <view class="feedback {{feedback}}" wx:if="{{feedback}}">{{feedbackText}}</view>
</view>
