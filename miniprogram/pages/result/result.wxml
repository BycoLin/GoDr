<view class="result-page">
  <view class="safe-pad result-body">
    <view class="card result-card">
      <view class="score-hero">
        <view class="label" wx:if="{{arcade || isMath || isEnglish}}">{{title}}</view>
        <view class="label" wx:else>《{{title}}》</view>
        <view class="stars">
          <text class="star {{stars >= 1 ? 'on' : ''}}">★</text>
          <text class="star {{stars >= 2 ? 'on' : ''}}">★</text>
          <text class="star {{stars >= 3 ? 'on' : ''}}">★</text>
        </view>
        <view class="score">{{ratioText}}</view>
        <view class="duel-note" wx:if="{{duel}}">你 {{userScore}} · 练习伙伴 {{rivalScore}}</view>
        <view class="points-chip">+{{points}} 分<text wx:if="{{bestCombo >= 2}}"> · 连对 x{{bestCombo}}</text></view>
      </view>

      <view class="feedback-block">
        <view class="encourage">{{encouragement}}</view>
        <view class="result-meta" wx:if="{{goalNote || progressNote}}">
          <view class="goal-note" wx:if="{{goalNote}}">{{goalNote}}</view>
          <view class="progress-note" wx:if="{{progressNote}}">{{progressNote}}</view>
        </view>
      </view>

      <view class="badge-new" wx:if="{{newBadges.length}}">
        <view class="badge-new-label">新成就</view>
        <view class="badge-row">
          <view class="badge-chip" wx:for="{{newBadges}}" wx:key="id">{{item.title}}</view>
        </view>
      </view>

      <view class="weak-panel" wx:if="{{showRematch}}">
        <view class="weak-head">
          <text class="weak-icon">!</text>
          <text class="weak-title">本局薄弱题型</text>
        </view>
        <view class="weak-tags">
          <text class="weak-tag" wx:for="{{rematchTags}}" wx:key="*this">{{item}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="result-dock">
    <button class="btn btn-primary dock-main" wx:if="{{pathNext}}" bindtap="onPathNext">{{pathNextText}}</button>
    <button class="btn btn-primary dock-main" wx:elif="{{pathDone}}" bindtap="onPathHub">回进阶路径</button>
    <button class="btn btn-primary dock-main" wx:elif="{{showRematch}}" bindtap="onRematchSame">再练同类</button>
    <button class="btn btn-primary dock-main" wx:else bindtap="onRetry">再闯一次</button>

    <view class="dock-row">
      <button class="dock-chip" open-type="share" hover-class="dock-chip--active">分享</button>
      <view
        class="dock-chip"
        wx:if="{{showBackLink}}"
        bindtap="onBackLevels"
        hover-class="dock-chip--active"
      >{{backLabel}}</view>
      <view class="dock-chip" bindtap="onHome" hover-class="dock-chip--active">回首页</view>
    </view>
  </view>
</view>
