.result-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.result-body {
  flex: 1;
  padding-bottom: 280rpx;
}

.result-card {
  text-align: center;
  padding: 36rpx 28rpx 32rpx;
  animation: riseIn 0.4s ease;
  background: linear-gradient(165deg, #e8fff8 0%, #ffffff 52%, #fff8eb 100%);
  overflow: hidden;
}

@keyframes riseIn {
  from {
    opacity: 0;
    transform: translateY(20rpx) scale(0.96);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.score-hero {
  padding-bottom: 8rpx;
}

.label {
  font-size: 28rpx;
  color: var(--color-muted);
  font-weight: 800;
}

.stars {
  margin-top: 16rpx;
}

.star {
  font-size: 64rpx;
  color: #d7dee8;
  margin: 0 8rpx;
}

.star.on {
  color: #ffc93c;
  animation: softPulse 0.6s ease;
}

.score {
  margin-top: 12rpx;
  font-size: 72rpx;
  font-weight: 900;
  color: var(--color-primary-deep);
  line-height: 1.1;
  letter-spacing: 2rpx;
}

.duel-note {
  margin-top: 10rpx;
  font-size: 26rpx;
  font-weight: 800;
  color: #4a4458;
}

.points-chip {
  display: inline-block;
  margin-top: 16rpx;
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  background: #fff5f3;
  border: 2rpx solid #ffd0c8;
  font-size: 26rpx;
  color: var(--color-accent);
  font-weight: 900;
}

.feedback-block {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #eef7f4;
}

.encourage {
  font-size: 30rpx;
  color: var(--color-ink);
  line-height: 1.5;
  font-weight: 800;
}

.result-meta {
  margin-top: 14rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.goal-note {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: #effffb;
  border: 2rpx solid #9ee5db;
  font-size: 24rpx;
  font-weight: 800;
  color: #0f8f82;
}

.progress-note {
  font-size: 22rpx;
  font-weight: 700;
  color: #9a93a8;
  line-height: 1.35;
}

.badge-new {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 2rpx dashed #ece7df;
}

.badge-new-label {
  font-size: 22rpx;
  color: var(--color-muted);
  margin-bottom: 12rpx;
  font-weight: 800;
}

.badge-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 10rpx;
}

.badge-chip {
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: var(--color-sun);
  color: #6a5000;
  font-size: 24rpx;
  font-weight: 900;
  box-shadow: 0 6rpx 0 #e0ad20;
}

.weak-panel {
  margin-top: 24rpx;
  padding: 20rpx 22rpx;
  border-radius: 28rpx;
  background: #f4fffc;
  border: 3rpx solid #d9efe9;
  text-align: left;
}

.weak-head {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.weak-icon {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #22b8a8;
  color: #fff;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 36rpx;
  text-align: center;
  flex-shrink: 0;
}

.weak-title {
  font-size: 26rpx;
  font-weight: 900;
  color: #1a1430;
}

.weak-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.weak-tag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #fff;
  border: 2rpx solid #9ee5db;
  font-size: 24rpx;
  font-weight: 800;
  color: #0f8f82;
}

.result-dock {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(230, 255, 246, 0) 0%, rgba(255, 255, 255, 0.94) 28%, #fff 100%);
  z-index: 20;
  box-sizing: border-box;
}

.dock-main {
  width: 100%;
  min-height: 104rpx;
  font-size: 34rpx;
}

.dock-row {
  display: flex;
  align-items: stretch;
  gap: 12rpx;
  margin-top: 16rpx;
}

.dock-chip {
  flex: 1;
  min-width: 0;
  min-height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: #fff;
  border: 3rpx solid #ece7df;
  font-size: 28rpx;
  font-weight: 800;
  color: #4a4458;
  box-shadow: 0 6rpx 0 rgba(26, 20, 48, 0.06);
  padding: 0 8rpx;
  margin: 0;
  line-height: 1.2;
  box-sizing: border-box;
}

button.dock-chip {
  width: auto;
}

.dock-chip::after {
  border: none;
}

.dock-chip--active {
  transform: translateY(4rpx);
  box-shadow: 0 2rpx 0 rgba(26, 20, 48, 0.06);
}

@keyframes softPulse {
  from {
    transform: scale(0.8);
  }
  to {
    transform: scale(1);
  }
}
