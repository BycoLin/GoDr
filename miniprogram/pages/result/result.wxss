.result {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  min-height: 100vh;
}

.result-card {
  text-align: center;
  padding: 52rpx 28rpx;
  margin-bottom: 8rpx;
  animation: riseIn 0.4s ease;
  background: linear-gradient(165deg, #e8fff8 0%, #ffffff 48%, #fff3d0 100%);
  overflow: hidden;
}

@keyframes riseIn {
  from {
    opacity: 0;
    transform: translateY(20rpx) scale(0.96);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.label {
  font-size: 28rpx;
  color: var(--color-muted);
  font-weight: 800;
}

.stars {
  margin-top: 18rpx;
}

.star {
  font-size: 68rpx;
  color: #d7dee8;
  margin: 0 6rpx;
}

.star.on {
  color: #ffc93c;
  animation: softPulse 0.6s ease;
}

.score {
  margin-top: 20rpx;
  font-size: 60rpx;
  font-weight: 900;
  color: var(--color-primary-deep);
}

.duel-note {
  margin-top: 8rpx;
  font-size: 26rpx;
  font-weight: 800;
  color: #4a4458;
}

.points-row {
  margin-top: 12rpx;
  font-size: 28rpx;
  color: var(--color-accent);
  font-weight: 900;
}

.badge-new {
  margin-top: 28rpx;
}

.badge-new-label {
  font-size: 22rpx;
  color: var(--color-muted);
  margin-bottom: 12rpx;
  font-weight: 800;
}

.badge-chip {
  display: inline-block;
  margin: 6rpx;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: var(--color-sun);
  color: #6a5000;
  font-size: 24rpx;
  font-weight: 900;
  box-shadow: 0 6rpx 0 #e0ad20;
}

.encourage {
  margin-top: 16rpx;
  font-size: 30rpx;
  color: var(--color-ink);
  line-height: 1.55;
  font-weight: 800;
}

.goal-note {
  margin-top: 14rpx;
  display: inline-block;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #effffb;
  border: 2rpx solid #9ee5db;
  font-size: 24rpx;
  font-weight: 800;
  color: #0f8f82;
}

.progress-note {
  margin-top: 12rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #4a4458;
  line-height: 1.4;
}

.rematch-box {
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 2rpx dashed #d9efe9;
}

.rematch-label {
  font-size: 22rpx;
  font-weight: 800;
  color: #9a93a8;
}

.rematch-types {
  margin-top: 8rpx;
  font-size: 28rpx;
  font-weight: 900;
  color: #0f8f82;
  line-height: 1.45;
}

.btn-rematch {
  margin-top: 18rpx;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  background: #22b8a8;
  color: #fff;
  font-size: 30rpx;
  font-weight: 900;
  box-shadow: 0 8rpx 0 #0f8f82;
}

.btn-rematch::after {
  border: none;
}

@keyframes softPulse {
  from {
    transform: scale(0.8);
  }
  to {
    transform: scale(1);
  }
}
