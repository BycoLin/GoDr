<view class="safe-pad mine">
  <view class="card profile">
    <view class="avatar-wrap">
      <view class="avatar">
        <view class="avatar-face">
          <view class="a-eye a-l"></view>
          <view class="a-eye a-r"></view>
          <view class="a-smile"></view>
        </view>
      </view>
      <view class="avatar-tag">小博士</view>
    </view>
    <view class="brand">我的练习记录</view>
    <view class="slogan">多练习，记得更牢！</view>
    <view class="stats">
      <view class="stat">
        <view class="stat-num">{{points}}</view>
        <view class="stat-label">积分</view>
      </view>
      <view class="stat">
        <view class="stat-num">{{clearedTotal}}</view>
        <view class="stat-label">已完成</view>
      </view>
      <view class="stat">
        <view class="stat-num">{{bestCombo}}</view>
        <view class="stat-label">连对</view>
      </view>
    </view>
    <view class="daily-tip">{{dailyTip}}</view>
  </view>

  <view class="section-title">练习成就</view>
  <view class="badge-grid">
    <view class="badge-item {{item.unlocked ? 'on' : ''}}" wx:for="{{badges}}" wx:key="id">
      <view class="badge-seal">{{item.unlocked ? '亮' : '？'}}</view>
      <view class="badge-title">{{item.title}}</view>
      <view class="badge-desc">{{item.desc}}</view>
    </view>
  </view>

  <view class="menu card">
    <view class="menu-item" bindtap="onGoWrongbook">
      <text>{{wrongbookLabel}}</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onGoGames">
      <text>去趣味练习</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onGoProgress">
      <text>看看我的进度</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item danger" bindtap="onClearAll">
      <text>清空全部进度</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <view class="about">
    <view>GoDr 小博士练习 · v{{version}}</view>
    <view class="about-desc">免费本地练习工具：语文、数学、英语趣味自测，记录学习进度。</view>
  </view>
</view>
