<view class="safe-pad mine">
  <view class="profile">
    <view class="avatar">
      <image class="avatar-img" src="/assets/miniprogram-avatar.png" mode="aspectFill" />
    </view>
    <view class="nick">闯关叭叭</view>
    <view class="level">{{rankTitle}} · {{subjectLabel}}</view>
  </view>

  <view class="check-bar">
    <view class="check-left">已连练 {{streakDays}} 天</view>
    <view class="check-right">最佳 {{streakBest}} 天</view>
  </view>

  <view class="goal-card {{goalDone ? 'done' : ''}}">
    <view class="goal-head">
      <text class="goal-title">今日目标</text>
      <text class="goal-count">{{goalAnswered}}/{{goalTarget}} 题</text>
    </view>
    <view class="goal-bar">
      <view class="goal-fill" style="width: {{goalBarWidth}};"></view>
    </view>
    <view class="goal-tip">{{goalTip}}</view>
  </view>

  <view class="week-card">
    <view class="week-head">
      <text class="week-title">本周小结</text>
      <text class="week-range">{{weekRangeLabel}}</text>
    </view>
    <view class="week-dots">
      <view
        class="week-dot {{item.practiced ? 'on' : ''}}"
        wx:for="{{weekDays}}"
        wx:key="date"
      >
        <view class="week-dot-mark"></view>
        <text class="week-dot-label">{{item.label}}</text>
      </view>
    </view>
    <view class="week-stats">
      <view class="week-stat">
        <view class="week-num">{{weekPracticeDays}}</view>
        <view class="week-label">练过天数</view>
      </view>
      <view class="week-stat">
        <view class="week-num">{{weekAnswered}}</view>
        <view class="week-label">答题数</view>
      </view>
      <view class="week-stat">
        <view class="week-num">{{weekCleared}}</view>
        <view class="week-label">新通关</view>
      </view>
    </view>
    <view class="week-extra">错题待练 {{wrongCount}} · {{weekTip}}</view>
    <button class="week-share" open-type="share">分享给家人看看本周练习</button>
  </view>

  <view class="stat-row">
    <view class="stat coin">
      <view class="stat-mark">分</view>
      <view class="stat-num">{{points}}</view>
      <view class="stat-label">积分</view>
    </view>
    <view class="stat clear">
      <view class="stat-mark">关</view>
      <view class="stat-num">{{clearedTotal}}</view>
      <view class="stat-label">已通关</view>
    </view>
    <view class="stat combo">
      <view class="stat-mark">连</view>
      <view class="stat-num">{{bestCombo}}</view>
      <view class="stat-label">最高连对</view>
    </view>
  </view>

  <view class="tip">{{dailyTip}} · {{reviewTip}}</view>

  <view class="sec-title" bindtap="onToggleFavorites">
    <text>收藏关{{favoriteCount > 0 ? ' ' + favoriteCount : ''}}</text>
    <text class="sec-more" wx:if="{{favCanExpand}}">{{favoritesExpanded ? '收起' : '展开'}}</text>
  </view>
  <view class="fav-box" wx:if="{{favoriteCount > 0}}">
    <view
      class="fav-row"
      wx:for="{{visibleFavorites}}"
      wx:key="key"
      data-pack-id="{{item.packId}}"
      data-item-id="{{item.itemId}}"
      data-grade="{{item.grade}}"
      bindtap="onPlayFavorite"
    >
      <view class="fav-mark">{{item.subjectShort}}</view>
      <view class="fav-body">
        <view class="fav-title">{{item.title}}</view>
        <view class="fav-meta">{{item.subject}} · {{item.grade}} 年级</view>
      </view>
      <view class="fav-go">练</view>
      <view
        class="fav-del"
        data-pack-id="{{item.packId}}"
        data-item-id="{{item.itemId}}"
        catchtap="onRemoveFavorite"
      >×</view>
    </view>
    <view
      class="fav-more"
      wx:if="{{favCanExpand && !favoritesExpanded}}"
      bindtap="onToggleFavorites"
    >还有 {{favoriteCount - 3}} 个，点开看全部</view>
  </view>
  <view class="fav-empty" wx:else>关卡页点☆可收藏难关，方便再练</view>

  <view class="sec-title" bindtap="onToggleBadges">
    <text>成就 {{badgeSummary}}</text>
    <text class="sec-more">{{badgesExpanded ? '收起' : '展开'}}</text>
  </view>
  <view class="badge-box" wx:if="{{badgesExpanded}}">
    <view class="badge-row {{item.unlocked ? 'on' : ''}}" wx:for="{{badges}}" wx:key="id">
      <text class="b-dot">{{item.unlocked ? '★' : '○'}}</text>
      <view class="b-body">
        <view class="b-title">{{item.title}}</view>
        <view class="b-desc">{{item.desc}}</view>
      </view>
    </view>
  </view>

  <view class="menu">
    <view class="menu-item" bindtap="onToggleSfx">
      <text>{{sfxLabel}}</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onToggleFocus">
      <text>{{focusLabel}}</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onGoWrongbook">
      <text>{{wrongbookLabel}}</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item danger" bindtap="onClearAll">
      <text>清空全部进度</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <view class="about">
    <view>闯关叭叭 · v{{version}}</view>
    <view class="about-desc">趣味闯关练习工具：语文、数学、英语自测，本地记录学习进度。</view>
  </view>
</view>
