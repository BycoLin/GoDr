.mine {
  min-height: 100vh;
}

.profile {
  margin-bottom: 28rpx;
}

.brand {
  font-size: 40rpx;
  font-weight: 800;
  color: #14553a;
}

.slogan {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: var(--color-muted);
}

.stats {
  display: flex;
  gap: 48rpx;
  margin-top: 32rpx;
}

.stat-num {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--color-primary);
}

.stat-label {
  margin-top: 4rpx;
  font-size: 24rpx;
  color: var(--color-muted);
}

.menu {
  padding: 0 32rpx;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 34rpx 0;
  border-bottom: 1rpx solid #e8eee9;
  font-size: 30rpx;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item.danger {
  color: var(--color-danger);
}

.arrow {
  color: var(--color-muted);
  font-size: 36rpx;
}

.about {
  margin-top: 48rpx;
  text-align: center;
  font-size: 24rpx;
  color: var(--color-muted);
  line-height: 1.6;
}

.about-desc {
  margin-top: 12rpx;
  padding: 0 24rpx;
}
