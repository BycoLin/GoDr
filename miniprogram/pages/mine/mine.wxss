.mine {
  min-height: 100vh;
}

.profile {
  margin-bottom: 28rpx;
  background: linear-gradient(145deg, #e8fffa 0%, #ffffff 55%, #dceeff 100%);
}

.brand {
  font-size: 40rpx;
  font-weight: 800;
  color: #0f6f6a;
}

.slogan {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: var(--color-muted);
}

.stats {
  display: flex;
  gap: 12rpx;
  margin-top: 28rpx;
}

.stat {
  flex: 1;
  text-align: center;
  background: rgba(255, 255, 255, 0.75);
  border-radius: 20rpx;
  padding: 16rpx 8rpx;
}

.stat-num {
  font-size: 38rpx;
  font-weight: 800;
  color: var(--color-primary-deep);
}

.stat-label {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: var(--color-muted);
}

.daily-tip {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: var(--color-muted);
  text-align: center;
}

.badge-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-bottom: 28rpx;
}

.badge-item {
  background: rgba(255, 255, 255, 0.7);
  border-radius: var(--radius);
  padding: 20rpx;
  box-shadow: none;
  opacity: 0.5;
  border: 2rpx solid transparent;
}

.badge-item.on {
  opacity: 1;
  background: #fff;
  border-color: var(--color-primary-soft);
  box-shadow: var(--shadow);
}

.badge-title {
  font-size: 26rpx;
  font-weight: 800;
}

.badge-desc {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--color-muted);
  line-height: 1.35;
}

.menu {
  padding: 0 28rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 0;
  border-bottom: 1rpx solid #e8eef5;
  font-size: 30rpx;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item.danger {
  color: var(--color-danger);
}

.arrow {
  color: #a8b5c6;
  font-size: 36rpx;
}

.about {
  margin-top: 48rpx;
  text-align: center;
  font-size: 24rpx;
  color: var(--color-muted);
  line-height: 1.6;
}

.about-desc {
  margin-top: 12rpx;
  padding: 0 24rpx;
}
