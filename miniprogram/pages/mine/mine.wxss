.mine {
  min-height: 100vh;
}

.profile {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 0 8rpx;
}

.avatar {
  width: 148rpx;
  height: 148rpx;
  border-radius: 50%;
  background: #22b8a8;
  box-shadow: 0 10rpx 0 #0f8f82;
  border: 6rpx dashed #ffc93c;
  position: relative;
  box-sizing: border-box;
}

.avatar-face {
  position: absolute;
  top: 40rpx;
  right: 36rpx;
  bottom: 40rpx;
  left: 36rpx;
}

.a-eye {
  position: absolute;
  top: 12rpx;
  width: 14rpx;
  height: 18rpx;
  background: #1a1430;
  border-radius: 50%;
}

.a-l { left: 16rpx; }
.a-r { right: 16rpx; }

.a-smile {
  position: absolute;
  left: 50%;
  bottom: 4rpx;
  width: 30rpx;
  height: 14rpx;
  margin-left: -15rpx;
  border: 4rpx solid #1a1430;
  border-top: 0;
  border-radius: 0 0 24rpx 24rpx;
}

.nick {
  margin-top: 20rpx;
  font-size: 40rpx;
  font-weight: 900;
  color: #1a1430;
}

.level {
  margin-top: 8rpx;
  font-size: 28rpx;
  font-weight: 800;
  color: #e08a12;
}

.check-bar {
  margin-top: 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-height: 96rpx;
  background: #fff;
  border: 3rpx solid #ece7df;
  border-radius: 999rpx;
  padding: 0 32rpx;
  box-shadow: 0 8rpx 0 rgba(26, 20, 48, 0.06);
}

.check-left,
.check-right {
  font-size: 28rpx;
  font-weight: 800;
  color: #1a1430;
}

.check-right {
  color: #22b8a8;
}

.stat-row {
  margin-top: 28rpx;
  display: flex;
  gap: 14rpx;
}

.stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 22rpx 8rpx 20rpx;
  border-radius: 28rpx;
  border: 3rpx solid #ece7df;
  box-shadow: 0 8rpx 0 rgba(26, 20, 48, 0.06);
  min-height: 180rpx;
  box-sizing: border-box;
}

.stat.coin {
  background: #fff8ef;
  border-color: #ffe08a;
}

.stat.clear {
  background: #effffb;
  border-color: #9ee5db;
}

.stat.combo {
  background: #fff5f3;
  border-color: #ffd0c8;
}

.stat-mark {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 900;
  color: #fff;
  margin-bottom: 12rpx;
}

.stat.coin .stat-mark {
  background: #ffc93c;
  box-shadow: 0 4rpx 0 #e0ad20;
  color: #5a4300;
}

.stat.clear .stat-mark {
  background: #22b8a8;
  box-shadow: 0 4rpx 0 #0f8f82;
}

.stat.combo .stat-mark {
  background: #ff6f61;
  box-shadow: 0 4rpx 0 #d4453f;
}

.stat-num {
  font-size: 44rpx;
  font-weight: 900;
  color: #1a1430;
  line-height: 1.1;
}

.stat.coin .stat-num { color: #e08a12; }
.stat.clear .stat-num { color: #0f8f82; }
.stat.combo .stat-num { color: #ff6f61; }

.stat-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  font-weight: 800;
  color: #4a4458;
}

.tip {
  margin-top: 18rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #4a4458;
  line-height: 1.45;
}

.sec-title {
  margin-top: 32rpx;
  margin-bottom: 14rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-height: 64rpx;
  font-size: 32rpx;
  font-weight: 900;
  color: #1a1430;
}

.sec-more {
  font-size: 26rpx;
  font-weight: 800;
  color: #22b8a8;
}

.badge-box {
  background: #fff;
  border: 3rpx solid #ece7df;
  border-radius: 28rpx;
  padding: 8rpx 24rpx;
  margin-bottom: 8rpx;
}

.badge-row {
  display: flex;
  gap: 14rpx;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f0ebe3;
}

.badge-row:last-child {
  border-bottom: none;
}

.b-dot {
  width: 44rpx;
  text-align: center;
  font-size: 32rpx;
  color: #c8c2d4;
  font-weight: 900;
}

.badge-row.on .b-dot {
  color: #ffc93c;
}

.b-title {
  font-size: 30rpx;
  font-weight: 900;
  color: #1a1430;
}

.badge-row:not(.on) .b-title {
  color: #9a93a8;
}

.b-desc {
  margin-top: 4rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #4a4458;
}

.menu {
  margin-top: 24rpx;
  background: #fff;
  border: 3rpx solid #ece7df;
  border-radius: 32rpx;
  padding: 0 28rpx;
  box-shadow: 0 10rpx 0 rgba(26, 20, 48, 0.06);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-height: 108rpx;
  border-bottom: 2rpx solid #ece7df;
  font-size: 32rpx;
  font-weight: 800;
  color: #1a1430;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item.danger {
  color: var(--color-danger);
}

.arrow {
  color: #9a93a8;
  font-size: 36rpx;
}

.about {
  margin-top: 40rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #9a93a8;
  line-height: 1.5;
}

.about-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #b0a9bc;
  padding: 0 24rpx;
}
