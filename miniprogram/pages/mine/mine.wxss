.mine {
  min-height: 100vh;
}

.profile,
.badge-card,
.menu {
  margin-bottom: 18rpx;
  background: #ffffff;
  overflow: hidden;
}

.profile-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.hero-badge {
  display: inline-block;
  background: var(--color-sun);
  color: #5a4300;
  font-size: 22rpx;
  font-weight: 900;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  margin-bottom: 10rpx;
}

.hero-badge.soft {
  background: var(--color-primary-soft);
  color: var(--color-primary-deep);
}

.brand {
  font-size: 36rpx;
  font-weight: 900;
  color: #1a1430;
}

.slogan {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #4a4458;
  font-weight: 700;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 46% 54% 50% 50%;
  background: #22b8a8;
  box-shadow: 0 8rpx 0 #0f8f82;
  position: relative;
  flex-shrink: 0;
}

.avatar-face {
  position: absolute;
  top: 26rpx;
  right: 24rpx;
  bottom: 28rpx;
  left: 24rpx;
}

.a-eye {
  position: absolute;
  top: 8rpx;
  width: 10rpx;
  height: 14rpx;
  background: #1a1430;
  border-radius: 50%;
}

.a-l {
  left: 12rpx;
}

.a-r {
  right: 12rpx;
}

.a-smile {
  position: absolute;
  left: 50%;
  bottom: 2rpx;
  width: 24rpx;
  height: 12rpx;
  margin-left: -12rpx;
  border: 3rpx solid #1a1430;
  border-top: 0;
  border-radius: 0 0 30rpx 30rpx;
}

.stats {
  display: flex;
  gap: 12rpx;
  margin-top: 24rpx;
}

.stat {
  flex: 1;
  text-align: center;
  background: #f7f4ee;
  border-radius: 24rpx;
  padding: 16rpx 8rpx;
  border: 2rpx solid #ece7df;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 900;
  color: #0f8f82;
}

.stat-label {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #4a4458;
  font-weight: 700;
}

.daily-tip {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: #4a4458;
  font-weight: 700;
}

.badge-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.badge-summary {
  font-size: 32rpx;
  font-weight: 900;
  color: #1a1430;
}

.link-more {
  flex-shrink: 0;
  margin-top: 8rpx;
  font-size: 26rpx;
  font-weight: 800;
  color: #22b8a8;
}

.bar {
  margin-top: 18rpx;
  height: 16rpx;
  background: #ece7df;
  border-radius: 999rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  background: #22b8a8;
}

.badge-preview {
  margin-top: 16rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #4a4458;
  line-height: 1.45;
}

.badge-list {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
}

.badge-row {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  padding: 18rpx 0;
  border-bottom: 2rpx solid #ece7df;
}

.badge-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.row-dot {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 900;
  background: #f7f4ee;
  color: #9a93a8;
  border: 3rpx solid #ece7df;
}

.badge-row.on .row-dot {
  background: #ffc93c;
  color: #5a4300;
  border-color: #ffc93c;
  box-shadow: 0 4rpx 0 #e0ad20;
}

.row-body {
  flex: 1;
  min-width: 0;
  padding-top: 2rpx;
}

.row-title {
  font-size: 28rpx;
  font-weight: 900;
  color: #1a1430;
}

.badge-row:not(.on) .row-title {
  color: #7a7390;
}

.row-desc {
  margin-top: 4rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #4a4458;
  line-height: 1.35;
}

.menu {
  padding: 0 28rpx;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 0;
  border-bottom: 2rpx solid #ece7df;
  font-size: 30rpx;
  font-weight: 800;
  color: #1a1430;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item.danger {
  color: var(--color-danger);
}

.arrow {
  color: #7a7390;
  font-size: 36rpx;
}

.about {
  margin-top: 28rpx;
  text-align: center;
  font-size: 24rpx;
  color: #4a4458;
  line-height: 1.6;
  font-weight: 700;
}

.about-desc {
  margin-top: 10rpx;
  padding: 0 24rpx;
}
