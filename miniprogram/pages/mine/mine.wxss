.mine {
  min-height: 100vh;
}

.profile {
  margin-bottom: 24rpx;
  background: #ffffff;
  text-align: center;
  overflow: hidden;
}

.avatar-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 16rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 46% 54% 50% 50%;
  background: #22b8a8;
  box-shadow: 0 10rpx 0 #0f8f82;
  position: relative;
}

.avatar-face {
  position: absolute;
  top: 34rpx;
  right: 30rpx;
  bottom: 36rpx;
  left: 30rpx;
}

.a-eye {
  position: absolute;
  top: 10rpx;
  width: 12rpx;
  height: 18rpx;
  background: #1a1430;
  border-radius: 50%;
}

.a-l {
  left: 14rpx;
}

.a-r {
  right: 14rpx;
}

.a-smile {
  position: absolute;
  left: 50%;
  bottom: 4rpx;
  width: 28rpx;
  height: 14rpx;
  margin-left: -14rpx;
  border: 3rpx solid #1a1430;
  border-top: 0;
  border-radius: 0 0 30rpx 30rpx;
}

.avatar-tag {
  margin-top: 10rpx;
  background: var(--color-sun);
  color: #5a4300;
  font-size: 20rpx;
  font-weight: 900;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}

.brand {
  font-size: 36rpx;
  font-weight: 900;
  color: #1a1430;
}

.slogan {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #4a4458;
  font-weight: 700;
}

.stats {
  display: flex;
  gap: 12rpx;
  margin-top: 24rpx;
}

.stat {
  flex: 1;
  text-align: center;
  background: #f7f4ee;
  border-radius: 24rpx;
  padding: 16rpx 8rpx;
  border: 2rpx solid #ece7df;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 900;
  color: #0f8f82;
}

.stat-label {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #4a4458;
  font-weight: 700;
}

.daily-tip {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: #4a4458;
  font-weight: 700;
}

.badge-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-bottom: 24rpx;
}

.badge-item {
  background: #f7f4ee;
  border-radius: 28rpx;
  padding: 20rpx 16rpx;
  border: 3rpx solid #ece7df;
  position: relative;
}

.badge-item.on {
  background: #fff;
  border: 3rpx solid #ece7df;
  box-shadow: 0 10rpx 0 rgba(26, 20, 48, 0.1);
}

.badge-seal {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #e8e3da;
  color: #7a7390;
  font-size: 22rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
}

.badge-item.on .badge-seal {
  background: #ffc93c;
  color: #5a4300;
}

.badge-title {
  font-size: 26rpx;
  font-weight: 900;
  color: #1a1430;
}

.badge-desc {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #4a4458;
  line-height: 1.35;
  font-weight: 600;
}

.menu {
  padding: 0 28rpx;
  overflow: hidden;
  background: #ffffff;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 0;
  border-bottom: 2rpx solid #ece7df;
  font-size: 30rpx;
  font-weight: 800;
  color: #1a1430;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item.danger {
  color: var(--color-danger);
}

.arrow {
  color: #7a7390;
  font-size: 36rpx;
}

.about {
  margin-top: 40rpx;
  text-align: center;
  font-size: 24rpx;
  color: #4a4458;
  line-height: 1.6;
  font-weight: 700;
}

.about-desc {
  margin-top: 10rpx;
  padding: 0 24rpx;
}
