.mine {
  min-height: 100vh;
}

.profile {
  margin-bottom: 28rpx;
}

.brand {
  font-size: 40rpx;
  font-weight: 800;
  color: #14553a;
}

.slogan {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: var(--color-muted);
}

.stats {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
}

.stat {
  flex: 1;
  text-align: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--color-primary);
}

.stat-label {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: var(--color-muted);
}

.daily-tip {
  margin-top: 24rpx;
  font-size: 24rpx;
  color: var(--color-muted);
  text-align: center;
}

.section-title {
  font-size: 28rpx;
  color: var(--color-muted);
  margin-bottom: 16rpx;
  font-weight: 600;
}

.badge-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.badge-item {
  background: var(--color-surface);
  border-radius: var(--radius);
  padding: 20rpx;
  box-shadow: var(--shadow);
  opacity: 0.45;
}

.badge-item.on {
  opacity: 1;
  border: 2rpx solid var(--color-primary-soft);
}

.badge-title {
  font-size: 26rpx;
  font-weight: 700;
}

.badge-desc {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--color-muted);
  line-height: 1.35;
}

.menu {
  padding: 0 32rpx;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 34rpx 0;
  border-bottom: 1rpx solid #e8eee9;
  font-size: 30rpx;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item.danger {
  color: var(--color-danger);
}

.arrow {
  color: var(--color-muted);
  font-size: 36rpx;
}

.about {
  margin-top: 48rpx;
  text-align: center;
  font-size: 24rpx;
  color: var(--color-muted);
  line-height: 1.6;
}

.about-desc {
  margin-top: 12rpx;
  padding: 0 24rpx;
}
