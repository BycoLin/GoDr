.keypad {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 16rpx;
}

.key {
  min-height: 96rpx;
  border-radius: 20rpx;
  background: #f3f4f8;
  color: #1a1430;
  font-size: 40rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 0 #d8dbe5;
}

.key:active {
  opacity: 0.88;
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 0 #d8dbe5;
}

.key-action {
  font-size: 28rpx;
}

.key-clear {
  background: #ffe8e4;
  color: #c94438;
  box-shadow: 0 6rpx 0 #f0c0b8;
}

.key-ok {
  background: #22b8a8;
  color: #fff;
  box-shadow: 0 6rpx 0 #0f8f82;
}
